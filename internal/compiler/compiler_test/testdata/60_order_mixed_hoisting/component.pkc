<template name="mixed-hoisting">
    <div>
        <p>Result A: {{ state.resultA }}</p>
        <p>Result B: {{ state.resultB }}</p>
        <button p-on:click="refresh">Refresh</button>
    </div>
</template>

<script lang="ts">
    const arrowUsingHoisted = () => hoistedHelper() * 2;

    const MULTIPLIER = 10;
    const arrowUsingConst = () => MULTIPLIER * 3;

    function hoistedHelper() {
        return 21;
    }

    const COMPUTED_A = arrowUsingHoisted();  // 42
    const COMPUTED_B = arrowUsingConst();    // 30

    const laterArrow = () => {
        return hoistedHelper() + MULTIPLIER;
    };

    const state = {
        resultA: COMPUTED_A as number,
        resultB: COMPUTED_B as number
    };

    function refresh() {
        state.resultA = laterArrow();
        state.resultB = arrowUsingHoisted() + arrowUsingConst();
    }

    function anotherHelper() {
        return 100;
    }
</script>
