<template name="ts-type-assertions">
    <div>
        <p>Type assertion test</p>
    </div>
</template>

<script lang="ts">
    const state = {
        items: [] as string[],
    };

    const getItems = (): HTMLElement[] => {
        const slot = pkc.shadowRoot?.querySelector('slot');
        if (!slot) return [];

        const assignedElements = slot.assignedElements({ flatten: true });
        return assignedElements.filter(el =>
            el instanceof HTMLElement
        ) as HTMLElement[];
    };

    const processItems = (): Map<string, HTMLElement> => {
        const result = new Map<string, HTMLElement>();
        const items = getItems();
        items.forEach(item => {
            const id = item.getAttribute('data-id');
            if (id) result.set(id, item);
        });
        return result;
    };

    const filterElements = <T extends Element>(elements: T[]): T[] => {
        return elements.filter(el => el.hasAttribute('data-filter')) as T[];
    };

    pkc.onConnected(() => {
        const items = getItems();
        console.log('Found items:', items.length);
    });
</script>

<style>
    :host {
        display: block;
    }
</style>
