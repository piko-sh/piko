<template>
    <pml-row background-color="#ffffff" padding="20px 0">
        <pml-col>
            <pml-p font-size="24px" font-weight="bold" color="#333333" align="center">
                Welcome to Our Newsletter
            </pml-p>
            <pml-p font-size="16px" color="#666666" padding="10px 25px">
                Thank you for subscribing! Here's what's new this month.
            </pml-p>
            <pml-img src="https://via.placeholder.com/600x300" alt="Newsletter Header" width="600px" padding="10px 0"/>
            <pml-hr border-color="#dddddd" border-width="2px" padding="20px 0"/>
            <pml-p font-size="14px" color="#666666" padding="10px 25px">
                We have exciting updates to share with you. Click the button below to learn more.
            </pml-p>
            <pml-button href="https://example.com" background-color="#007bff" color="#ffffff" padding="15px 30px">
                Learn More
            </pml-button>
            <pml-br height="20px"/>
        </pml-col>
    </pml-row>
</template>
