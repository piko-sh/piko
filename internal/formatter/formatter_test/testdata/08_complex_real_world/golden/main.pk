<template>
  <div class="product-card">
    <header>
      <img :alt="state.Product.Name" :src="state.Product.ImageURL" class="product-image" />
      <h2 class="product-title">{{ state.Product.Name }}</h2>
    </header>
    <div class="product-details">
      <p :class="{'discounted': state.Product.OnSale}" class="price" p-if="state.Product.OnSale">
        ${{ state.Product.SalePrice }}
      </p>
      <p class="price" p-else>${{ state.Product.RegularPrice }}</p>
      <ul class="features">
        <li p-for="feature in state.Product.Features" p-key="feature.ID">
          {{ feature.Description }}
        </li>
      </ul>
    </div>
    <form class="add-to-cart" p-on:submit="addToCart">
      <label>Quantity:</label>
      <input :max="state.Product.StockQuantity" min="1" p-model="state.Quantity" type="number" />
      <button :disabled="state.IsProcessing || state.Product.StockQuantity == 0" type="submit">
        <span p-if="state.IsProcessing">Adding...</span>
        <span p-else>Add to Cart</span>
      </button>
    </form>
    <div class="reviews" p-if="len(state.Reviews) > 0">
      <h3>Customer Reviews</h3>
      <div class="review" p-for="review in state.Reviews" p-key="review.ID">
        <div class="review-header">
          <strong>{{ review.AuthorName }}</strong>
          <span class="rating">{{ review.Rating }}/5</span>
        </div>
        <p p-text="review.Comment"></p>
      </div>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Product struct {
	Name          string
	ImageURL      string
	RegularPrice  float64
	SalePrice     float64
	OnSale        bool
	StockQuantity int
	Features      []Feature
}
type Feature struct {
	ID          int
	Description string
}
type Review struct {
	ID         int
	AuthorName string
	Rating     int
	Comment    string
}
type Response struct {
	Product      Product
	Reviews      []Review
	Quantity     int
	IsProcessing bool
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{}, piko.Metadata{}, nil
}
</script>

<style>
.product-card {
  border: 1px solid #ddd;
  padding: 1rem;
  border-radius: 8px;
}
.product-image {
  width: 100%;
  height: auto;
  border-radius: 4px;
}
.product-title {
  font-size: 1.5rem;
  margin: 0.5rem 0;
}
.price {
  font-size: 1.25rem;
  font-weight: bold;
  color: #333;
}
.price.discounted {
  color: #e74c3c;
}
.features {
  list-style: disc;
  padding-left: 1.5rem;
}
.add-to-cart {
  margin-top: 1rem;
}
button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.reviews {
  margin-top: 2rem;
  border-top: 1px solid #ddd;
  padding-top: 1rem;
}
.review {
  margin-bottom: 1rem;
}
.review-header {
  display: flex;
  justify-content: space-between;
}
</style>
