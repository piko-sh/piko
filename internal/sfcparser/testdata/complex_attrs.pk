<template p-collection="posts" p-provider="markdown" p-sort="date:desc" p-limit="10" p-offset="0">
	<div
		class="container mx-auto px-4 py-8 lg:px-8 xl:px-12"
		id="main-content"
		data-controller="posts"
		data-posts-url-value="/api/posts"
		data-posts-refresh-interval-value="30000"
		data-analytics-category="blog"
		data-analytics-action="view"
		aria-label="Main content area"
		role="main">
		<header
			class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8"
			data-testid="page-header">
			<h1
				class="text-3xl font-bold text-gray-900 dark:text-white mb-4 md:mb-0"
				p-bind:class="{ 'text-primary': isPrimary }"
				p-text="title">
				Page Title
			</h1>
			<nav
				class="flex space-x-4"
				aria-label="Breadcrumb navigation"
				data-nav-type="breadcrumb">
				<a
					href="/"
					class="text-blue-600 hover:text-blue-800 transition-colors duration-200"
					p-bind:href="homeUrl"
					p-bind:title="homeTooltip"
					aria-current="false">
					Home
				</a>
			</nav>
		</header>
		<main
			class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
			data-masonry="true"
			data-masonry-column-width="300"
			data-masonry-gutter="24">
			<article
				p-for="post in posts"
				p-key="post.id"
				class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden transform transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
				p-bind:class="{ 'border-l-4 border-primary': post.featured }"
				p-bind:id="'post-' + post.id"
				data-post-id="{{ post.id }}"
				data-post-category="{{ post.category }}"
				data-post-published="{{ post.publishedAt }}"
				itemscope
				itemtype="https://schema.org/BlogPosting">
				<img
					p-bind:src="post.image"
					p-bind:alt="post.imageAlt"
					class="w-full h-48 object-cover"
					loading="lazy"
					decoding="async"
					width="400"
					height="192"
					itemprop="image"
					p-bind:srcset="post.imageSrcset"
					sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"/>
				<div class="p-6">
					<h2
						class="text-xl font-semibold mb-2 line-clamp-2"
						p-text="post.title"
						itemprop="headline">
					</h2>
					<p
						class="text-gray-600 dark:text-gray-300 mb-4 line-clamp-3"
						p-text="post.excerpt"
						itemprop="description">
					</p>
					<footer class="flex justify-between items-center">
						<time
							p-bind:datetime="post.publishedAt"
							class="text-sm text-gray-500"
							itemprop="datePublished">
							{{ post.formattedDate }}
						</time>
						<a
							p-bind:href="post.url"
							class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium"
							p-bind:aria-label="'Read more about ' + post.title"
							itemprop="url">
							Read more
							<svg class="w-4 h-4 ml-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
								<path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
							</svg>
						</a>
					</footer>
				</div>
			</article>
		</main>
	</div>
</template>

<script
	type="application/x-go"
	name="posts-page"
	enable="ssr,hydration"
	cache="1h"
	preload="true">
package components

import (
	"net/http"
	"time"
)

type Post struct {
	ID           string
	Title        string
	Excerpt      string
	Image        string
	ImageAlt     string
	ImageSrcset  string
	URL          string
	Category     string
	PublishedAt  time.Time
	FormattedDate string
	Featured     bool
}

type PostsPageData struct {
	Title       string
	IsPrimary   bool
	HomeURL     string
	HomeTooltip string
	Posts       []Post
}

func GetPostsPageData(r *http.Request) (*PostsPageData, error) {
	return &PostsPageData{
		Title:       "Blog Posts",
		IsPrimary:   true,
		HomeURL:     "/",
		HomeTooltip: "Return to homepage",
		Posts:       []Post{},
	}, nil
}
</script>

<script
	type="application/javascript"
	defer
	async="false"
	crossorigin="anonymous"
	integrity="sha384-example">
// Client-side interactivity
document.addEventListener('DOMContentLoaded', () => {
	// Initialize masonry layout
	const grid = document.querySelector('[data-masonry]');
	if (grid) {
		new Masonry(grid, {
			columnWidth: parseInt(grid.dataset.masonryColumnWidth),
			gutter: parseInt(grid.dataset.masonryGutter),
			itemSelector: 'article'
		});
	}
});
</script>

<style
	scoped
	lang="postcss"
	media="screen"
	title="Posts Page Styles">
@tailwind base;
@tailwind components;
@tailwind utilities;

.line-clamp-2 {
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.line-clamp-3 {
	display: -webkit-box;
	-webkit-line-clamp: 3;
	-webkit-box-orient: vertical;
	overflow: hidden;
}
</style>
