	border-radius: 12px;
	padding: 2rem;
	position: relative;
}

.pricing-card.featured {
	border: 2px solid #007bff;
	transform: scale(1.05);
}

.pricing-badge {
	position: absolute;
	top: -12px;
	left: 50%;
	transform: translateX(-50%);
	background: #007bff;
	color: white;
	padding: 0.25rem 1rem;
	border-radius: 20px;
	font-size: 0.875rem;
	font-weight: 600;
}

.pricing-header {
