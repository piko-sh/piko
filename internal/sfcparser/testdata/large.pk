<script type="application/x-go">
package components

import (
	"fmt"
	"net/http"
	"time"
)

type FeatureCard struct {
	Icon        string
	Title       string
	Description string
	Link        string
}

type PricingPlan struct {
	Name        string
	Description string
	Price       int
	Period      string
	Features    []PricingFeature
	Featured    bool
	CTA         string
	CTALink     string
}

type PricingFeature struct {
	Text     string
	Included bool
}

type Testimonial struct {
	Content     string
	AuthorName  string
	AuthorTitle string
	AuthorImage string
}

type HeroStat struct {
	Value string
	Label string
}

type NavItem struct {
	Label  string
	Href   string
	Active bool
}

type FooterNavGroup struct {
	Title string
	Links []NavItem
}

type LargePageData struct {
	SiteName       string
	Tagline        string
	HeroTitle      string
	HeroSubtitle   string
	HeroStats      []HeroStat
	Features       []FeatureCard
	PricingPlans   []PricingPlan
	Testimonials   []Testimonial
	MainNav        []NavItem
	FooterNav      []FooterNavGroup
	CurrentYear    int
	SystemStatus   string
	IsAnnualBilling bool
}

func GetLargePageData(r *http.Request) (*LargePageData, error) {
	return &LargePageData{
		SiteName:     "Company Inc",
		Tagline:      "Building the future",
		HeroTitle:    "Welcome to Our Platform",
		HeroSubtitle: "Discover powerful tools and services designed to help your business grow.",
		HeroStats: []HeroStat{
			{Value: "10M+", Label: "Users"},
			{Value: "50K+", Label: "Companies"},
			{Value: "99.9%", Label: "Uptime"},
		},
		Features: []FeatureCard{
			{Title: "Lightning Fast", Description: "Optimised for speed"},
			{Title: "Enterprise Security", Description: "Bank-grade encryption"},
			{Title: "Auto Scaling", Description: "Zero configuration scaling"},
		},
		PricingPlans: []PricingPlan{
			{Name: "Starter", Price: 0, Featured: false},
			{Name: "Professional", Price: 29, Featured: true},
			{Name: "Enterprise", Price: 99, Featured: false},
		},
		CurrentYear:  time.Now().Year(),
		SystemStatus: "operational",
	}, nil
}

func FormatPrice(price int, currency string) string {
	return fmt.Sprintf("%s%d", currency, price)
}
</script>

<script type="application/javascript">
(function() {
	'use strict';

	// Billing toggle functionality
	const billingToggle = document.getElementById('billing-toggle');
	const priceAmounts = document.querySelectorAll('.price-amount');

	const monthlyPrices = [0, 29, 99];
	const annualPrices = [0, 23, 79]; // 20% discount

	if (billingToggle) {
		billingToggle.addEventListener('change', function() {
			const prices = this.checked ? annualPrices : monthlyPrices;
			priceAmounts.forEach((el, index) => {
				el.textContent = prices[index];
			});
		});
	}

	// Smooth scrolling for anchor links
	document.querySelectorAll('a[href^="#"]').forEach(anchor => {
		anchor.addEventListener('click', function(e) {
			e.preventDefault();
			const target = document.querySelector(this.getAttribute('href'));
			if (target) {
				target.scrollIntoView({
					behavior: 'smooth',
					block: 'start'
				});
			}
		});
	});

	// Intersection Observer for scroll animations
	const observerOptions = {
		root: null,
		rootMargin: '0px',
		threshold: 0.1
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				entry.target.classList.add('animate-in');
				observer.unobserve(entry.target);
			}
		});
	}, observerOptions);

	document.querySelectorAll('.feature-card, .pricing-card, .testimonial-card').forEach(el => {
		observer.observe(el);
	});

	// Mobile menu toggle
	const menuToggle = document.querySelector('.menu-toggle');
	const mainNav = document.querySelector('.main-nav');

	if (menuToggle && mainNav) {
		menuToggle.addEventListener('click', function() {
			mainNav.classList.toggle('is-open');
			this.setAttribute('aria-expanded', mainNav.classList.contains('is-open'));
		});
	}

	// Search functionality
	const searchBtn = document.querySelector('.btn-search');
	const searchModal = document.querySelector('.search-modal');

	if (searchBtn && searchModal) {
		searchBtn.addEventListener('click', function() {
			searchModal.classList.add('is-open');
			searchModal.querySelector('input').focus();
		});

		searchModal.querySelector('.close-btn')?.addEventListener('click', function() {
			searchModal.classList.remove('is-open');
		});

		document.addEventListener('keydown', function(e) {
			if (e.key === 'Escape' && searchModal.classList.contains('is-open')) {
				searchModal.classList.remove('is-open');
			}
			if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
				e.preventDefault();
				searchModal.classList.add('is-open');
				searchModal.querySelector('input').focus();
			}
		});
	}

	// Analytics tracking
	function trackEvent(category, action, label) {
		if (typeof gtag !== 'undefined') {
			gtag('event', action, {
				event_category: category,
				event_label: label
			});
		}
	}

	document.querySelectorAll('.btn-primary, .btn-outline').forEach(btn => {
		btn.addEventListener('click', function() {
			trackEvent('CTA', 'click', this.textContent.trim());
		});
	});
})();
</script>

<style>
/* Base styles */
*, *::before, *::after {
	box-sizing: border-box;
}

body {
	font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
	line-height: 1.6;
	color: #333;
	margin: 0;
	padding: 0;
}

/* Container */
.large-page-container {
	min-height: 100vh;
	display: flex;
	flex-direction: column;
}

/* Header */
.site-header {
	position: sticky;
	top: 0;
	background: white;
	border-bottom: 1px solid #eee;
	z-index: 100;
}

.header-top {
