<template>
	<div class="level-1">
		<div class="level-2">
			<div class="level-3">
				<div class="level-4">
					<div class="level-5">
						<div class="level-6">
							<div class="level-7">
								<div class="level-8">
									<div class="level-9">
										<div class="level-10">
											<p>Deeply nested content</p>
											<template v-if="showNested">
												<div class="conditional-1">
													<template v-for="item in items">
														<div class="item-wrapper">
															<template v-if="item.visible">
																<span class="item-content">{{ item.name }}</span>
															</template>
														</div>
													</template>
												</div>
											</template>
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<section class="another-section">
		<article>
			<header>
				<nav>
					<ul>
						<li>
							<a href="#">
								<span>
									<template v-if="hasIcon">
										<i class="icon"></i>
									</template>
									<span class="text">Link Text</span>
								</span>
							</a>
						</li>
					</ul>
				</nav>
			</header>
			<main>
				<div class="content-wrapper">
					<div class="content-inner">
						<div class="content-body">
							<template v-for="section in sections">
								<div class="section">
									<template v-if="section.hasHeader">
										<h2>{{ section.title }}</h2>
									</template>
									<div class="section-content">
										<template v-for="paragraph in section.paragraphs">
											<p>{{ paragraph }}</p>
										</template>
									</div>
								</div>
							</template>
						</div>
					</div>
				</div>
			</main>
		</article>
	</section>
</template>

<script type="application/x-go">
package components

type NestedPageData struct {
	ShowNested bool
	HasIcon    bool
	Items      []Item
	Sections   []Section
}

type Item struct {
	Name    string
	Visible bool
}

type Section struct {
	Title      string
	HasHeader  bool
	Paragraphs []string
}
</script>

<style>
.level-1 { padding: 1px; }
.level-2 { padding: 2px; }
.level-3 { padding: 3px; }
.level-4 { padding: 4px; }
.level-5 { padding: 5px; }
.level-6 { padding: 6px; }
.level-7 { padding: 7px; }
.level-8 { padding: 8px; }
.level-9 { padding: 9px; }
.level-10 { padding: 10px; }
</style>
