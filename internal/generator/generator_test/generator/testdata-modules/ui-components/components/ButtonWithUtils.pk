<template>
  <button class="btn" p-attr:class="state.CssClass">
    <span p-text="state.FormattedLabel"></span>
  </button>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    "github.com/example/ui-components/pkg/utils"
  )

  type Props struct {
    Label   string
    Variant string
  }

  type Response struct {
    FormattedLabel string
    CssClass       string
  }

  func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    formattedLabel := utils.FormatButtonLabel(props.Label)

    variant := utils.ButtonVariant(props.Variant)
    cssClass := utils.GetButtonClass(variant)

    return Response{
      FormattedLabel: formattedLabel,
      CssClass:       cssClass,
    }, piko.Metadata{}, nil
  }
</script>

<style>
  .btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 0.25rem;
    cursor: pointer;
    font-family: inherit;
  }
  .btn-primary {
    background-color: #007bff;
    color: white;
  }
  .btn-secondary {
    background-color: #6c757d;
    color: white;
  }
  .btn-danger {
    background-color: #dc3545;
    color: white;
  }
</style>
