<template>
  <div class="card">
    <div class="card-header" p-if="state.Header != ``">
      <h3 p-text="state.Header"></h3>
    </div>
    <div class="card-body">
      <p p-text="state.Content"></p>
    </div>
    <div class="card-footer" p-if="state.Footer != ``">
      <small p-text="state.Footer"></small>
    </div>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
  )

  type Props struct {
    Header  string
    Content string
    Footer  string
  }

  type Response struct {
    Header  string
    Content string
    Footer  string
  }

  func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    return Response{
      Header:  props.Header,
      Content: props.Content,
      Footer:  props.Footer,
    }, piko.Metadata{}, nil
  }
</script>

<style>
  .card {
    border: 1px solid #ddd;
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .card-header {
    background-color: #f8f9fa;
    padding: 1rem;
    border-bottom: 1px solid #ddd;
  }
  .card-body {
    padding: 1rem;
  }
  .card-footer {
    background-color: #f8f9fa;
    padding: 0.75rem 1rem;
    border-top: 1px solid #ddd;
    color: #6c757d;
  }
</style>
