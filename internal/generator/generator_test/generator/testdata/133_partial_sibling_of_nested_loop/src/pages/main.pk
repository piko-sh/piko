<template>
  <div class="container">
    <table>
      <tbody>
        <tr p-for="row in state.Rows" p-key="row.ID" class="row-wrapper">
          <td p-for="(idx, cell) in row.Cells" p-key="idx" class="data-cell">
            <span p-text="cell.Text"></span>
          </td>
          <td class="actions">
            <piko:partial is="row_actions"
              :container_id="state.ContainerID"
              :category_name="state.CategoryName"
              :row_id="row.ID"
              :row_title="row.Title">
            </piko:partial>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</template>

<script type="application/x-go">
package main

import (
    "piko.sh/piko"

    row_actions "testcase_133_partial_sibling_of_nested_loop/partials/row_actions.pk"
)

type Cell struct {
    Text string
}

type Row struct {
    ID    string
    Title string
    Cells []Cell
}

type Response struct {
    ContainerID  string
    CategoryName string
    Rows         []Row
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
        ContainerID:  "container-abc",
        CategoryName: "Category A",
        Rows: []Row{
            {ID: "1", Title: "First Row", Cells: []Cell{{Text: "A"}, {Text: "B"}}},
            {ID: "2", Title: "Second Row", Cells: []Cell{{Text: "C"}, {Text: "D"}}},
        },
    }, piko.Metadata{}, nil
}
</script>
