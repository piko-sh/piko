<template>
  <div class="row-actions">
    <button class="edit-btn">Edit {{ state.DisplayTitle }}</button>
    <a :href="state.EditURL" class="edit-link">Go to {{ state.DisplayTitle }}</a>
    <span class="category">{{ state.CategoryLabel }}</span>
  </div>
</template>

<script type="application/x-go">
package main

import (
    "fmt"

    "piko.sh/piko"
)

type Props struct {
    ContainerID  string `prop:"container_id"`
    CategoryName string `prop:"category_name"`
    RowID        string `prop:"row_id"`
    RowTitle     string `prop:"row_title"`
}

type Response struct {
    RowID         string
    DisplayTitle  string
    EditURL       string
    CategoryLabel string
}

func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    displayTitle := props.RowTitle
    if displayTitle == "" {
        displayTitle = "Untitled"
    }

    return Response{
        RowID:         props.RowID,
        DisplayTitle:  displayTitle,
        EditURL:       fmt.Sprintf("/containers/%s/rows/%s/edit", props.ContainerID, props.RowID),
        CategoryLabel: props.CategoryName,
    }, piko.Metadata{}, nil
}
</script>
