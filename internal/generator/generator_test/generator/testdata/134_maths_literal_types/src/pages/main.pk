<template>
  <div>
    <h1>Maths Literal Types Test</h1>

    <h2>RichText Rendering</h2>
    <p id="richtext-decimal">{{ state.Price }}</p>
    <p id="richtext-money">{{ state.Total }}</p>
    <p id="richtext-bigint">{{ state.Quantity }}</p>

    <h2>p-text Binding</h2>
    <p id="ptext-decimal" p-text="state.Price">decimal placeholder</p>
    <p id="ptext-money" p-text="state.Total">money placeholder</p>
    <p id="ptext-bigint" p-text="state.Quantity">bigint placeholder</p>

    <h2>Attribute Binding</h2>
    <p id="attr-decimal" :data-val="state.Price">decimal in attribute</p>
    <p id="attr-money" :data-val="state.Total">money in attribute</p>
    <p id="attr-bigint" :data-val="state.Quantity">bigint in attribute</p>

    <h2>Template Literal Interpolation</h2>
    <p id="template-decimal" p-text="`Price: ${state.Price}`">decimal in template</p>
    <p id="template-money" p-text="`Total: ${state.Total}`">money in template</p>
    <p id="template-bigint" p-text="`Quantity: ${state.Quantity}`">bigint in template</p>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    "piko.sh/piko/wdk/maths"
  )

  type Response struct {
    Price    maths.Decimal
    Total    maths.Money
    Quantity maths.BigInt
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
      Price:    maths.NewDecimalFromFloat(19.99),
      Total:    maths.NewMoneyFromMinorInt(150000, "USD"),
      Quantity: maths.NewBigIntFromString("9999999999999"),
    }, piko.Metadata{}, nil
  }
</script>
