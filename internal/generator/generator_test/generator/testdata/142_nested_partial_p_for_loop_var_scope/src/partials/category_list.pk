<template>
  <div class="category-list">
    <piko:partial is="item_row"
      p-for="item in state.Items" p-key="item.Label"
      :label="item.Label"
      :detail="item.Extra?.Detail">
    </piko:partial>
  </div>
</template>

<script type="application/x-go">
package main

import (
    "piko.sh/piko"
    item_row "testcase_142_nested_partial_p_for_loop_var_scope/partials/item_row.pk"
)

type Extra struct {
    Detail string
}

type Item struct {
    Label string
    Extra *Extra
}

type Props struct {
    CategoryName string `prop:"category_name"`
}

type Response struct {
    Items []Item
}

func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    return Response{
        Items: []Item{
            {Label: "Apple", Extra: &Extra{Detail: "Red"}},
            {Label: "Banana"},
        },
    }, piko.Metadata{}, nil
}
</script>
