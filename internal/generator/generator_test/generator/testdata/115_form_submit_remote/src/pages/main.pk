<template>
  <div>
    <h1>Form Submit Action Test</h1>
    <p>
      This page tests that p-on:submit with the action. prefix properly
      encodes the action payload as base64 JSON, not as a raw string.
    </p>

    <form id="static-form" p-on:submit="action.static_action()">
      <input type="text" name="email" placeholder="Enter email" />
      <button type="submit">Submit Static</button>
    </form>

    <piko:partial is="boxed_form" server.show_form="true">
      <input type="text" name="name" placeholder="Enter name" />
    </piko:partial>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    boxed_form "testcase_115_form_submit_remote/partials/boxed_form.pk"
  )

  func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
  }
</script>
