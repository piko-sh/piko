<template>
  <div class="action-button-wrapper">
    <p>Click the button to trigger the client-side handler:</p>
    <button class="action-btn" p-on:click="performAction()">
      Perform Action
    </button>
    <div class="result"></div>
  </div>
</template>

<style>
  .action-button-wrapper {
    padding: 1.5rem;
    border: 2px solid #333;
    border-radius: 8px;
    margin: 1rem 0;
  }
  .action-btn {
    padding: 0.75rem 1.5rem;
    background-color: #007bff;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
  }
  .action-btn:hover {
    background-color: #0056b3;
  }
  .result {
    margin-top: 1rem;
    padding: 0.5rem;
    background: #f0f0f0;
    border-radius: 4px;
  }
  .result.success {
    background: #d4edda;
    color: #155724;
  }
</style>

<script type="application/x-go">
  package main
  import "piko.sh/piko"

  func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
  }
</script>

<script lang="ts">
export function performAction(): void {
  const resultEl = document.querySelector('.result');
  if (resultEl) {
    resultEl.textContent = 'Action performed successfully!';
    resultEl.classList.add('success');
  }
  console.log('performAction() was called from embedded partial');
}
</script>
