<template>
  <div>
    <h1>Embedded Partial with Client Script Test</h1>
    <p>This page tests that p-on:click handlers in embedded partials work correctly.</p>
    <p>When a partial is embedded (not rendered as fragment), its client script must be available.</p>

    <piko:partial is="action_button"></piko:partial>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    action_button "testcase_088_embedded_partial_with_client_script/partials/action-button.pk"
  )

  func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
  }
</script>
