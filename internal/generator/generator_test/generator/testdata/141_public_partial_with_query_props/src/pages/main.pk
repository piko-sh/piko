<template>
  <div>
    <h1>Search Page</h1>
    <piko:partial is="search" :query="state.SearchTerm" :page="state.CurrentPage"></piko:partial>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    search "testcase_141_public_partial_with_query_props/partials/search.pk"
  )

  type Response struct {
    SearchTerm  string
    CurrentPage int
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
      SearchTerm:  "hello",
      CurrentPage: 1,
    }, piko.Metadata{}, nil
  }
</script>
