<template>
  <div>
    <h1>Division (/) and Modulo (%) Operators Test</h1>

    <h2>Integer Division</h2>
    <p id="int-div-int" p-text="state.Numerator / state.Denominator">100 / 4 = 25</p>
    <p id="int-div-literal" p-text="state.Numerator / 5">100 / 5 = 20</p>
    <p id="literal-div-int" p-text="200 / state.Denominator">200 / 4 = 50</p>

    <h2>Float Division</h2>
    <p id="float-div-float" p-text="state.FloatNum / state.FloatDenom">10.5 / 2.5 = 4.2</p>
    <p id="int-div-float" p-text="state.Numerator / state.FloatDenom">100 / 2.5 = 40</p>
    <p id="float-div-int" p-text="state.FloatNum / state.Denominator">10.5 / 4 = 2.625</p>

    <h2>Integer Modulo</h2>
    <p id="int-mod-int" p-text="state.Numerator % state.ModValue">100 % 7 = 2</p>
    <p id="int-mod-literal" p-text="state.Numerator % 3">100 % 3 = 1</p>
    <p id="literal-mod-int" p-text="17 % state.ModValue">17 % 7 = 3</p>

    <h2>Division in Complex Expressions</h2>
    <p id="div-in-ternary" :data-half="state.Numerator / 2 > 40 ? 'large' : 'small'">Ternary with division</p>
    <p id="div-add" p-text="state.Numerator / state.Denominator + 10">100/4 + 10 = 35</p>
    <p id="add-div" p-text="(state.Numerator + 20) / state.Denominator">(100+20)/4 = 30</p>

    <h2>Modulo in Complex Expressions</h2>
    <p id="mod-eq-zero" p-if="state.Numerator % 2 == 0">100 is even</p>
    <p id="mod-ne-zero" p-if="state.OddNumber % 2 != 0">17 is odd</p>
    <p id="mod-in-ternary" :data-parity="state.Numerator % 2 == 0 ? 'even' : 'odd'">Parity check</p>

    <h2>Chained Arithmetic</h2>
    <p id="mul-div" p-text="state.Numerator * 2 / state.Denominator">100*2/4 = 50</p>
    <p id="div-mul" p-text="state.Numerator / state.Denominator * 3">100/4*3 = 75</p>

    <h2>Division with Variables</h2>
    <p id="dynamic-div" p-text="state.Total / state.Count">Dynamic division</p>

    <h2>Common Patterns</h2>
    <p id="percentage" p-text="state.Completed * 100 / state.Total">Percentage: 75%</p>
    <p id="average" p-text="state.Sum / state.Count">Average calculation</p>
  </div>
</template>

<script type="application/x-go">
  package main

  import "piko.sh/piko"

  type Response struct {
    Numerator   int
    Denominator int
    FloatNum    float64
    FloatDenom  float64

    ModValue  int
    OddNumber int

    Total     int
    Count     int
    Completed int
    Sum       int
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
      Numerator:   100,
      Denominator: 4,
      FloatNum:    10.5,
      FloatDenom:  2.5,

      ModValue:  7,
      OddNumber: 17,

      Total:     100,
      Count:     4,
      Completed: 75,
      Sum:       200,
    }, piko.Metadata{}, nil
  }
</script>
