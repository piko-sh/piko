<template>
  <div>
    <h1>p-ref with p-on:click Interaction Test</h1>
    <p>
      This page tests that p-ref and p-on:click work together.
      The event handler should be able to access refs to manipulate DOM.
    </p>

    <input
      type="text"
      p-ref="searchInput"
      placeholder="Search..."
    />

    <button p-on:click="clearSearch()">
      Clear Search
    </button>

    <div>
      <span p-ref="counterDisplay">0</span>
      <button p-on:click="incrementCounter()">+</button>
      <button p-on:click="decrementCounter()">-</button>
    </div>

    <form p-ref="loginForm" p-on:submit="handleLogin($event)">
      <input type="email" p-ref="emailField" name="email" placeholder="Email" />
      <input type="password" p-ref="passwordField" name="password" placeholder="Password" />
      <button type="submit" p-ref="submitButton">Login</button>
    </form>
  </div>
</template>

<script type="application/x-go">
  package main

  import "piko.sh/piko"

  func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
  }
</script>

<script lang="ts">
/**
 * Client-side handlers that use refs to manipulate DOM.
 * The refs object provides scoped access to elements with p-ref.
 */

export function clearSearch(): void {
  const input = pk.refs.searchInput as HTMLInputElement;
  if (input) {
    input.value = '';
    input.focus();
  }
}

export function incrementCounter(): void {
  const display = pk.refs.counterDisplay as HTMLSpanElement;
  if (display) {
    const current = parseInt(display.textContent || '0', 10);
    display.textContent = String(current + 1);
  }
}

export function decrementCounter(): void {
  const display = pk.refs.counterDisplay as HTMLSpanElement;
  if (display) {
    const current = parseInt(display.textContent || '0', 10);
    display.textContent = String(current - 1);
  }
}

export function handleLogin(event: Event): void {
  event.preventDefault();

  const email = pk.refs.emailField as HTMLInputElement;
  const password = pk.refs.passwordField as HTMLInputElement;
  const form = pk.refs.loginForm as HTMLFormElement;
  const submit = pk.refs.submitButton as HTMLButtonElement;

  if (!email?.value || !password?.value) {
    console.error('Email and password are required');
    return;
  }

  submit.disabled = true;

  console.log('Login attempt:', email.value);
}
</script>
