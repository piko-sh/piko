<template>
  <div class="parent-wrapper">
    <div class="card">
      <span class="title">Parent Card Title</span>
      <button class="btn primary">Click Me</button>
    </div>
    <piko:partial is="child_card" />
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    child_card "testcase_090_css_scoping_proper_isolation/partials/child_card.pk"
  )

  type Response struct {
    Info string
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{Info: "Parent"}, piko.Metadata{}, nil
  }
</script>

<style>
.card {
    background: red;
    padding: 20px;
}

.card, .parent-wrapper {
    border: 1px solid black;
}

.btn:hover {
    background: darkred;
}

.btn:focus, .btn:active {
    outline: 2px solid blue;
}

.card::before {
    content: "Parent: ";
}

.title::after {
    content: " (parent)";
}

.parent-wrapper .card .title {
    font-weight: bold;
}

.parent-wrapper > .card {
    margin: 10px;
}

.card + .child-wrapper {
    margin-top: 20px;
}

.card ~ div {
    color: gray;
}

.btn[disabled] {
    opacity: 0.5;
}

.btn:not(.primary) {
    background: gray;
}

:is(.card, .parent-wrapper) {
    box-sizing: border-box;
}

:where(.btn, .title) {
    font-family: sans-serif;
}

.card:has(.title) {
    display: flex;
}

:deep(.title) {
    text-decoration: underline;
}

:deep(.card .title) {
    font-style: italic;
}

:deep(.btn:hover) {
    cursor: pointer;
}

:global(.global-reset) {
    margin: 0;
    padding: 0;
}

:global(body .global-class) {
    font-size: 16px;
}

@media (min-width: 768px) {
    .card {
        flex-direction: row;
    }

    .btn:hover {
        transform: scale(1.05);
    }
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.card {
    animation: fadeIn 0.3s ease-in;
}

.btn.primary {
    background: blue;
}

#unique-parent-element {
    z-index: 100;
}

.card:nth-child(odd) {
    background: #f5f5f5;
}

.card:first-child {
    border-top: none;
}

.card:last-of-type {
    border-bottom: none;
}
</style>
