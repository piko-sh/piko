<template>
  <div>
    <h1>External Module Component Test</h1>

    <p>This page uses components from external Go modules to verify the ChainedResolver works correctly.</p>

    <piko:partial is="container">
      <h2>Welcome Section</h2>

      <piko:partial is="card"></piko:partial>

      <p>Below is a button from an external module:</p>
      <piko:partial is="btn"></piko:partial>
    </piko:partial>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    container "github.com/example/layout-primitives/layouts/Container.pk"
    card "github.com/example/ui-components/components/Card.pk"
    btn "github.com/example/ui-components/components/Button.pk"
  )

  func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
  }
</script>
