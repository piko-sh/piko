    background-color: #e3f2fd;
  }

  .wrapper-description {
    color: blue;
    font-style: italic;
  }

  .wrapper-footer {
    border-top: 1px dashed gray;
    padding-top: 10px;
    color: gray;
  }
</style>

<script type="application/x-go">
