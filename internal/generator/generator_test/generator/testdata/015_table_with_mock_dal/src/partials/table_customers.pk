<template>
  <div class="table-wrapper">
    <table>
      <thead>
        <tr p-for="row in state.TableRows" p-if="row.Header">
          <th p-for="cell in row.TableCells" p-text="cell.Text"></th>
        </tr>
      </thead>
      <tbody>
        <tr p-for="row in state.TableRows" p-if="!row.Header">
          <td p-for="cell in row.TableCells" p-text="cell.Text"></td>
        </tr>
      </tbody>
    </table>
    <p p-if="len(state.TableRows) <= 1">No customers found.</p>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "context"
    "piko.sh/piko"
  )
  
  type PaginatedCustomerResult struct {
	  Customers []struct {
		  ID int64
		  CompanyName string
	  }
  }

  func ListCustomersPaginated(ctx context.Context, page, pageSize int, filter *string) (PaginatedCustomerResult, error) {
      return PaginatedCustomerResult{}, nil
  }


  type TableCell struct {
    Text string
  }
  type TableRow struct {
    ID         int64
    TableCells []TableCell
    Header     bool
  }
  type Response struct {
    TableRows []TableRow
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    customerData, _ := ListCustomersPaginated(r.Context(), 0, 25, nil)

    rows := []TableRow{
      {Header: true, TableCells: []TableCell{{Text: "ID"}, {Text: "Company Name"}}},
    }

    for _, data := range customerData.Customers {
      rows = append(rows, TableRow{
        ID: data.ID, 
        TableCells: []TableCell{{Text: "dummy"}, {Text: data.CompanyName}},
      })
    }

    return Response{ TableRows: rows }, piko.Metadata{}, nil
  }
</script>