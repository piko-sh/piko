<template>
  <div :class="'themed-card theme-' + state.Theme">
    <span p-text="state.Size"></span>
    <span p-text="state.Label"></span>
  </div>
</template>

<script type="application/x-go">
  package main

  import "piko.sh/piko"

  type Props struct {
    Theme string `prop:"theme" default:"light"`
    Size string `prop:"size" default:"medium"`
    Label string `prop:"label" default:"Click me"`
  }

  type Response struct {
    Theme string
    Size  string
    Label string
  }

  func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    return Response{
      Theme: props.Theme,
      Size:  props.Size,
      Label: props.Label,
    }, piko.Metadata{}, nil
  }
</script>
