<template>
  <div class="coerced-display">
    <span p-if="state.IsActive">Active</span>
    <span p-text="state.Count"></span>
    <span p-text="state.Price"></span>
  </div>
</template>

<script type="application/x-go">
  package main

  import "piko.sh/piko"

  type Props struct {
    IsActive bool `prop:"is-active" coerce:"true"`
    Count int `prop:"count" coerce:"true"`
    Price float64 `prop:"price" coerce:"true"`
  }

  type Response struct {
    IsActive bool
    Count    int
    Price    float64
  }

  func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    return Response{
      IsActive: props.IsActive,
      Count:    props.Count,
      Price:    props.Price,
    }, piko.Metadata{}, nil
  }
</script>
