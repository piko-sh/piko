<template>
  <div class="user-card">
    <p-if condition="state.HasProfile">
      <span p-text="state.ProfileName"></span>
      <span p-text="state.ProfileEmail"></span>
    </p-if>
    <p-else>
      <span>No profile provided</span>
    </p-else>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    "testcase_072_prop_tags_comprehensive/pkg/models"
  )

  type Props struct {
    Profile *models.UserProfile `prop:"profile"`
    Subtitle *string `prop:"subtitle"`
  }

  type Response struct {
    HasProfile   bool
    ProfileName  string
    ProfileEmail string
    Subtitle     string
  }

  func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    resp := Response{}

    if props.Profile != nil {
      resp.HasProfile = true
      resp.ProfileName = props.Profile.Name
      resp.ProfileEmail = props.Profile.Email
    }

    if props.Subtitle != nil {
      resp.Subtitle = *props.Subtitle
    }

    return resp, piko.Metadata{}, nil
  }
</script>
