<template>
  <div class="card">
    <h2 p-ref="cardTitle">{{ state.Title }}</h2>

    <input
      type="text"
      p-ref="inputField"
      :placeholder="'Input for ' + state.Title"
    />

    <div class="counter">
      <span p-ref="counterValue">0</span>
      <button p-on:click="increment()">+</button>
      <button p-on:click="decrement()">-</button>
    </div>

    <button p-on:click="focusCardInput()">Focus This Card's Input</button>
  </div>
</template>

<script type="application/x-go">
  package main

  import "piko.sh/piko"

  type Props struct {
    Title string `json:"title"`
  }

  type Response struct {
    Title string `json:"Title"`
  }

  func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    return Response{
      Title: props.Title,
    }, piko.Metadata{}, nil
  }
</script>

<script lang="ts">
/**
 * These handlers access refs scoped to THIS partial instance.
 * When Card A's increment() is called, it modifies Card A's counterValue.
 * When Card B's increment() is called, it modifies Card B's counterValue.
 * They do not conflict even though they use the same ref names.
 */

export function increment(): void {
  const counter = pk.refs.counterValue as HTMLSpanElement;
  if (counter) {
    const value = parseInt(counter.textContent || '0', 10);
    counter.textContent = String(value + 1);
  }
}

export function decrement(): void {
  const counter = pk.refs.counterValue as HTMLSpanElement;
  if (counter) {
    const value = parseInt(counter.textContent || '0', 10);
    counter.textContent = String(value - 1);
  }
}

export function focusCardInput(): void {
  const input = pk.refs.inputField as HTMLInputElement;
  if (input) {
    input.focus();
    input.select();
  }
}
</script>
