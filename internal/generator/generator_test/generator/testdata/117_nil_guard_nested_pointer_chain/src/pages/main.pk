<template>
  <div>
    <h1>Nested Pointer Chain Nil-Guard Test</h1>
    <p>
      This test verifies that nested p-if guards properly protect
      nested pointer dereferences in generated code. Each level
      should generate its own if-block without redundant safety checks.
    </p>

    <div p-if="state.User != nil">
      <span id="user-name">{{ state.User.Name }}</span>
      <div p-if="state.User.Profile != nil">
        <span id="profile-bio">{{ state.User.Profile.Bio }}</span>
        <div p-if="state.User.Profile.Avatar != nil">
          <img id="avatar-url" :src="state.User.Profile.Avatar.URL" />
        </div>
      </div>
    </div>

    <img p-if="state.Image != nil" id="image-guarded" :src="state.Image.URL" :alt="state.Image.Alt" />
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
  )

  type Avatar struct {
    URL string
    Alt string
  }

  type Profile struct {
    Bio    string
    Avatar *Avatar
  }

  type User struct {
    Name    string
    Profile *Profile
  }

  type Image struct {
    URL string
    Alt string
  }

  type PageData struct {
    User  *User
    Image *Image
  }

  func Render(r *piko.RequestData, props piko.NoProps) (PageData, piko.Metadata, error) {
    return PageData{
      User: &User{
        Name: "Test User",
        Profile: &Profile{
          Bio: "Test bio",
          Avatar: &Avatar{
            URL: "https://example.com/avatar.jpg",
            Alt: "Avatar",
          },
        },
      },
      Image: &Image{
        URL: "https://example.com/image.jpg",
        Alt: "Test Image",
      },
    }, piko.Metadata{}, nil
  }
</script>
