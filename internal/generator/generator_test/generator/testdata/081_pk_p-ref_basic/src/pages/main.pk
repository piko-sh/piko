<template>
  <div>
    <h1>Basic p-ref Test in PPFT</h1>
    <p>
      This page tests basic p-ref functionality in PPFT files.
      The p-ref directive should emit a data-pp-ref attribute for
      client-side JavaScript to query elements within the partial scope.
    </p>

    <input type="text" p-ref="emailInput" placeholder="Enter email" />

    <button p-ref="submitBtn" type="submit">Submit</button>

    <canvas p-ref="chartCanvas" width="400" height="200"></canvas>
  </div>
</template>

<script type="application/x-go">
  package main

  import "piko.sh/piko"

  func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
  }
</script>

<script lang="ts">
export function focusEmail(): void {
  pk.refs.emailInput?.focus();
}

export function disableSubmit(): void {
  if (pk.refs.submitBtn) {
    pk.refs.submitBtn.disabled = true;
  }
}

export function getCanvas(): HTMLCanvasElement | null {
  return pk.refs.chartCanvas as HTMLCanvasElement;
}
</script>
