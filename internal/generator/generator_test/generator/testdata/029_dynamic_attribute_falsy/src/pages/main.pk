<template>
  <div>
    <h1>Dynamic Attribute Falsy Test</h1>
    <input type="text" value="Bool False" :disabled="state.IsDisabled" />
    <input type="text" value="Bool True" :disabled="!state.IsDisabled" />
    <input type="text" value="Bool True" :disabled="state.IsEnabled" />
    <input type="text" value="Bool False" :disabled="!state.IsEnabled" />
    <p :data-optional="state.NilString">Nil Pointer</p>
    <p :data-optional="state.EmptyStringPtr">Empty String Pointer</p>
    <p :data-optional="state.ValidStringPtr">Valid String Pointer</p>
    <p :data-static-false="'false'">Static String "false"</p>
  </div>
</template>

<script type="application/x-go">
  package main

  import "piko.sh/piko"

  type Response struct {
    IsDisabled     bool
    IsEnabled      bool
    NilString      *string
    EmptyStringPtr *string
    ValidStringPtr *string
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    empty := ""
    valid := "I am valid"
    return Response{
      IsDisabled:     false,
      IsEnabled:      true,
      NilString:      nil,
      EmptyStringPtr: &empty,
      ValidStringPtr: &valid,
    }, piko.Metadata{}, nil
  }
</script>