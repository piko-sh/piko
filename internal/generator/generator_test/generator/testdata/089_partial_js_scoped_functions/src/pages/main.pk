<template>
  <div>
    <h1>Scoped Partial JS Functions Test</h1>
    <p>This page tests that multiple partials with the same exported function names are scoped correctly.</p>
    <p>Both modal-a and modal-b export an "open()" function - they should not collide.</p>

    <h2>Modal A</h2>
    <piko:partial is="modal_a"></piko:partial>

    <h2>Modal B</h2>
    <piko:partial is="modal_b"></piko:partial>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    modal_a "testcase_089_partial_js_scoped_functions/partials/modal-a.pk"
    modal_b "testcase_089_partial_js_scoped_functions/partials/modal-b.pk"
  )

  func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
  }
</script>
