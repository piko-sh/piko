<template>
  <div>
    <p>Total cost: ${{ state.Price * state.Quantity }}</p>
    <p>User: {{ state.FormatUser(state.User) }}</p>
  </div>
</template>

<script type="application/x-go">
  package main
  import (
	  "piko.sh/piko";
	  "fmt";
  )

  type User struct { FirstName, LastName string }

  type Response struct {
    Price float64; Quantity int; User User
    FormatUser func(u User) string
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
      Price: 9.99, Quantity: 2, User: User{FirstName: "John", LastName: "Doe"},
      FormatUser: func(u User) string { return fmt.Sprintf("%s %s", u.FirstName, u.LastName) },
    }, piko.Metadata{}, nil
  }
</script>