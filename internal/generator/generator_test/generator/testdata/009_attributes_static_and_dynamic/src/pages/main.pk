<template>
  <div class="card" :id="`item-${state.ID}`" :data-status="state.Status" p-class="{'card--active': state.IsActive, 'card--error': state.Status == 'error'}" p-style="{'background-color': state.BgColor,'font-size': '16px'}" :disabled="state.IsDisabled">
    <p p-text="state.Message"></p>
  </div>
  <div
    class="card"
    :id="`item-${state.ID}`"
    :data-status="state.Status"
    p-class="{
      'card--active': state.IsActive,
      'card--error': state.Status == 'error'
    }"
    p-style="{
      'background-color': state.BgColor,
      'font-size': '16px'
    }"
    :disabled="state.IsDisabled"
    >
    <p p-text="state.Message"></p>
  </div>
</template>

<script type="application/x-go">
  package main

  import "piko.sh/piko"

  type Response struct {
    ID         int
    Message    string
    Status     string
    IsActive   bool
    IsDisabled bool
    BgColor    string
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
      ID:         123,
      Message:    "Dynamic Content",
      Status:     "active",
      IsActive:   true,
      IsDisabled: false,
      BgColor:    "lightblue",
    }, piko.Metadata{}, nil
  }
</script>