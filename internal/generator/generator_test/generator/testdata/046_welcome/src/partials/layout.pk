<template>
  <header class="site-header">
    <div class="header-container">
      <a href="/" class="brand">
        🚀 my-piko-app
      </a>
      <nav class="main-nav">
        <a href="/">Home</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <piko:slot></piko:slot>
  </main>

  <footer class="site-footer">
    <div class="footer-container">
      <p>© {{ state.CurrentYear }} my-piko-app. All Rights Reserved.</p>
      <div class="social-links">
        <a href="#">Twitter</a>
        <span>·</span>
        <a href="#">GitHub</a>
        <span>·</span>
        <a href="#">LinkedIn</a>
      </div>
    </div>
  </footer>
</template>

<script type="application/x-go">
package main

import (
    "piko.sh/piko"
    "time"
)

type Props struct {
    PageTitle string `prop:"page_title"`
}

type Response struct {
    PageTitle   string
    CurrentYear int
}

func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    title := "my-piko-app"
    if props.PageTitle != "" {
        title = props.PageTitle + " | my-piko-app"
    }

    metadata := piko.Metadata{
        Title: title,
    }

    return Response{
        PageTitle:   title,
        CurrentYear: time.Now().Year(),
    }, metadata, nil
}
</script>

