<script type="application/x-go">
package main

import "piko.sh/piko"
import cfg "testcase_112_partial_import_const_var/partials/config.pk"

type Response struct {
	AppName    string
	MaxItems   int
	Version    string
	Status     string
	FirstTag   string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		AppName:    cfg.AppName,
		MaxItems:   cfg.MaxItems,
		Version:    cfg.Version,
		Status:     cfg.StatusLabels["active"],
		FirstTag:   cfg.DefaultTags[0],
	}, piko.Metadata{}, nil
}
</script>
<template>
	<div class="main">
		<h1>{{ cfg.AppName }}</h1>
		<p>Version: {{ cfg.Version }}</p>
		<p>Max Items: {{ cfg.MaxItems }}</p>
		<p>Status: {{ cfg.StatusLabels["pending"] }}</p>
		<p>From Render: {{ state.Status }}</p>
	</div>
</template>
