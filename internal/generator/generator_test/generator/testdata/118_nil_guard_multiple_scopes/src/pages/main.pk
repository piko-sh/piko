<template>
  <div>
    <h1>Multiple Independent Guard Scopes Test</h1>
    <p>
      This test verifies that multiple independent p-if guards generate
      correctly isolated code blocks. Guards should not leak across siblings.
    </p>

    <div p-if="state.Image != nil">
      <img id="first-image" :src="state.Image.URL" :alt="state.Image.Alt" />
    </div>

    <span id="unguarded-between">{{ state.Unguarded.Value }}</span>

    <div p-if="state.Video != nil">
      <video id="video-src">
        <source :src="state.Video.URL" type="video/mp4" />
      </video>
    </div>

    <div p-if="state.Image != nil">
      <img id="image-inside-guard" :src="state.Image.URL" />
      <span id="unguarded-inside-guard">{{ state.Video.Title }}</span>
    </div>

    <div p-if="state.Image != nil && state.Video != nil">
      <img id="combined-image" :src="state.Image.URL" />
      <span id="combined-video">{{ state.Video.Title }}</span>
    </div>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
  )

  type Image struct {
    URL string
    Alt string
  }

  type Video struct {
    URL   string
    Title string
  }

  type Data struct {
    Value string
  }

  type PageData struct {
    Image     *Image
    Video     *Video
    Unguarded *Data
  }

  func Render(r *piko.RequestData, props piko.NoProps) (PageData, piko.Metadata, error) {
    return PageData{
      Image: &Image{
        URL: "https://example.com/image.jpg",
        Alt: "Test Image",
      },
      Video: &Video{
        URL:   "https://example.com/video.mp4",
        Title: "Test Video",
      },
      Unguarded: &Data{
        Value: "Unguarded Value",
      },
    }, piko.Metadata{}, nil
  }
</script>
