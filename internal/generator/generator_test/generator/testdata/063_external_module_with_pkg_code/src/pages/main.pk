<template>
  <div>
    <h1>External Module pkg/ Code Test</h1>

    <p>This page uses ButtonWithUtils component from ui-components module.</p>
    <p>That component imports helper functions from github.com/example/ui-components/pkg/utils.</p>
    <p>This tests that external components can reference their own module's Go packages.</p>

    <hr />

    <div class="button-showcase">
      <h2>Primary Button</h2>
      <piko:partial is="btn"></piko:partial>

      <h2>Secondary Button</h2>
      <piko:partial is="btn_secondary"></piko:partial>

      <h2>Danger Button</h2>
      <piko:partial is="btn_danger"></piko:partial>
    </div>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    btn "github.com/example/ui-components/components/ButtonWithUtils.pk"
    btn_secondary "github.com/example/ui-components/components/ButtonWithUtils.pk"
    btn_danger "github.com/example/ui-components/components/ButtonWithUtils.pk"
  )

  func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
  }
</script>

<style>
  .button-showcase {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 2rem;
  }
  .button-showcase h2 {
    margin-bottom: 0.5rem;
