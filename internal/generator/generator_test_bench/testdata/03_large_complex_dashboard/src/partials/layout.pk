<template>
  <div class="dashboard-layout">
    <sidebar is="sidebar"
      :brand_name="state.AppName"
      :nav_label="props.Username"
      :nav_href="state.DashboardUrl"
      :footer_text="state.Copyright">
    </sidebar>
    <main class="dashboard-main">
      <header class="dashboard-header">
        <h1 p-text="props.PageTitle"></h1>
        <div class="header-user">
          <span p-text="props.Username"></span>
        </div>
      </header>
      <div class="dashboard-content">
        <piko:slot></piko:slot>
      </div>
    </main>
  </div>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    sidebar "testcase_large_complex_dashboard/partials/sidebar.pk"
  )

  type Props struct {
    PageTitle string `prop:"page_title"`
    Username  string `prop:"username"`
  }

  type Response struct {
    AppName      string
    DashboardUrl string
    Copyright    string
  }

  func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    return Response{
      AppName:      "Piko Dashboard",
      DashboardUrl: "/dashboard",
      Copyright:    "2024 PolitePixes",
    }, piko.Metadata{}, nil
  }
</script>
