    },
    {
      "description": "The 'Pair' type should have two type parameters.",
      "select": "packages.testcase_08_generics_definition.named_types.Pair.type_params.1",
      "expect": "V"
    },
    {
      "description": "The 'Key' field on 'Pair' should have the type string 'K'.",
      "select": "packages.testcase_08_generics_definition.named_types.Pair.fields.0.type_string",
      "expect": "K"
    }
  ]
