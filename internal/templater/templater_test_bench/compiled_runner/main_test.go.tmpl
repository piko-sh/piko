func BenchmarkCompiledRender(b *testing.B) {
	manifestPath := filepath.Join("dist", "manifest.json")
	manifestProvider := generator_adapters.NewJsonManifestProvider(manifestPath)
	manifestStore, err := templater_adapters.NewManifestStore(context.Background(), manifestProvider)
	if err != nil {
		b.Fatalf("Failed to load manifest: %v", err)
	}

	pageToBenchmark := os.Getenv("PIKO_BENCH_TARGET_PAGE")
	if pageToBenchmark == "" {
		b.Fatal("PIKO_BENCH_TARGET_PAGE environment variable not set")
	}

	testSandbox, _ := safedisk.NewNoOpSandbox(".", safedisk.ModeReadOnly)
	i18nService, _ := i18n_adapters.NewFSService(context.Background(), testSandbox, "", "")
	csrfService, _ := security_domain.NewCSRFTokenService(security_domain.SecurityConfig{HMACSecretKey: []byte("test-secret-key-32-bytes-long")}, security_adapters.NewIPBinderAdapter())
	fakeRegistry := &fakeRegistryService{}
	renderRegistry := render_adapters.NewDataLoaderRegistryAdapter(fakeRegistry, nil, "")
	renderer := render_domain.NewRenderOrchestrator(nil, renderRegistry, csrfService)
	compiledRunner := templater_adapters.NewCompiledManifestRunner(manifestStore, i18nService)
	astCache, _ := ast_adapters.NewASTCacheService(context.Background(), ast_adapters.ASTCacheConfig{L1CacheCapacity: 100, L1CacheTTL: 5 * time.Minute})
	cachingRunner := templater_adapters.NewCachingManifestRunner(compiledRunner, astCache)
	templaterService := templater_domain.NewTemplaterService(cachingRunner, templater_adapters.NewDrivenRenderer(renderer), i18nService)

	req, _ := http.NewRequest("GET", "/test-path", nil)

	rctx := chi.NewRouteContext()
	req = req.WithContext(context.WithValue(req.Context(), chi.RouteCtxKey, rctx))

	pageDef := templater_dto.PageDefinition{OriginalPath: pageToBenchmark}
	websiteConfig := &config.WebsiteConfig{}

	b.ReportAllocs()
	b.ResetTimer()

	for i := 0; i < b.N; i++ {
		err := templaterService.RenderPage(context.Background(), pageDef, io.Discard, req, false, websiteConfig)
		if err != nil {
			b.Fatalf("RenderPage failed during benchmark: %v", err)
		}
	}
}
