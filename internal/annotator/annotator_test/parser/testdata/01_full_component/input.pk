<script type="application/x-go">
package main

import (
	template_dto "piko.sh/piko/internal/templater/templater_dto"
	card "partials/card.pk"
)

type Response struct {
	Title string
	Users []string
}

type Props struct {
	IsAdmin bool `prop:"is-admin"`
}

func Render(r *template_dto.RequestData, props Props) (Response, template_dto.Metadata, error) {
	return Response{}, template_dto.Metadata{}, nil
}

func Middlewares() []string {
	return []string{"auth"}
}

func CachePolicy() template_dto.CachePolicy {
	return template_dto.CachePolicy{MaxAgeSeconds: 60}
}
</script>

<template>
	<div>Hello</div>
</template>

<style>
	div { color: red; }
</style>

<i18n lang="json">
{
  "en": { "greeting": "Hello" },
  "fr": { "greeting": "Bonjour" }
}
</i18n>