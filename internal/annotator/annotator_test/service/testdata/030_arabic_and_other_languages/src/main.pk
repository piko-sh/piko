<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct {
	ArabicText   string
	HebrewText   string
	ThaiText     string
	GeorgianText string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		ArabicText:   "مرحباً بالعالم",
		HebrewText:   "שלום עולם",
		ThaiText:     "สวัสดีชาวโลก",
		GeorgianText: "გამარჯობა მსოფლიო",
	}, piko.Metadata{}, nil
}
</script>

<template>
    <div>
        <h1>Testing Complex Scripts</h1>

        <p id="static-arabic" dir="rtl">مرحباً بالعالم</p>
        <p id="static-hebrew" dir="rtl">שלום עולם</p>

        <p id="static-thai">สวัสดีชาวโลก</p>
        <p id="static-georgian">გამარჯობა მსოფლიო</p>

        <hr />

        <p id="dynamic-arabic" dir="rtl">{{ state.ArabicText }}</p>
        <p id="dynamic-hebrew" dir="rtl">{{ state.HebrewText }}</p>
        <p id="dynamic-thai">{{ state.ThaiText }}</p>
        <p id="dynamic-georgian">{{ state.GeorgianText }}</p>
    </div>
</template>