<script type="application/x-go">
package main

import (
	"time"

	"piko.sh/piko"
)

type MyStruct struct {
	Name string
}

type Response struct {
	StructVal MyStruct
	BoolVal   bool
	FloatVal  float64
	TimeVal   time.Time
	IntVal    int
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		StructVal: MyStruct{Name: "test"},
		BoolVal:   true,
		FloatVal:  3.14,
		TimeVal:   time.Now(),
		IntVal:    42,
	}, piko.Metadata{}, nil
}
</script>

<template>
  <div>
    <h1>Coercion Error Test</h1>

    <p id="struct-to-decimal">{{ decimal(state.StructVal) }}</p>

    <p id="bool-to-decimal">{{ decimal(state.BoolVal) }}</p>

    <p id="float-to-bigint">{{ bigint(state.FloatVal) }}</p>

    <p id="time-to-int">{{ int(state.TimeVal) }}</p>

    <p id="no-args">{{ string() }}</p>

    <p id="too-many-args">{{ int(state.IntVal, state.IntVal) }}</p>
  </div>
</template>
