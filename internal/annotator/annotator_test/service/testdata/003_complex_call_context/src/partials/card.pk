<script type="application/x-go">
package card

import "piko.sh/piko"

type Props struct {
    Greeting string `prop:"greeting" validate:"required"`
}

type Response struct {
    Message string
}

func Hello(fromState, fromProps string) string {
    return "Card received: (" + fromState + ") and (" + fromProps + ")"
}

func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    return Response{Message: "Hello from card state"}, piko.Metadata{}, nil
}
</script>

<template>
    <div class="card">
        <p>
            {{ Hello(state.Message, props.Greeting) }}
        </p>
    </div>
</template>