<script type="application/x-go">
package main

import (
	"piko.sh/piko"
	outer_layout "testcase_54_prop_binding_on_layout_invocation_in_slot/partials/outer_layout.pk"
	inner_layout "testcase_54_prop_binding_on_layout_invocation_in_slot/partials/inner_layout.pk"
	child "testcase_54_prop_binding_on_layout_invocation_in_slot/partials/child.pk"
)

type Response struct {
	ShowSidebar bool
	ContentData string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{ShowSidebar: true, ContentData: "Main content"}, piko.Metadata{}, nil
}
</script>

<template>
	<piko:partial is="outer_layout">
		<piko:partial id="inner-layout" is="inner_layout" :sidebar_visible="state.ShowSidebar">
			<piko:partial id="nested-child" is="child" :data="state.ContentData"></piko:partial>
		</piko:partial>
	</piko:partial>
</template>
