<template>
  <div>
    <img id="guarded-same-element" p-if="props.Image != nil" :src="props.Image.URL" />

    <div id="guarded-children" p-if="props.User != nil">
      <span id="guarded-child-name">{{ props.User.Name }}</span>
    </div>

    <div id="nested-guard-outer" p-if="props.User != nil">
      <span id="nested-outer-field">{{ props.User.Name }}</span>
      <div id="nested-guard-inner" p-if="props.User.Profile != nil">
        <span id="nested-inner-field">{{ props.User.Profile.Bio }}</span>
      </div>
      <span id="nested-unguarded-inner">{{ props.User.Profile.Bio }}</span>
    </div>

    <span id="unguarded">{{ props.Unguarded.Name }}</span>

    <div id="combined-guard" p-if="props.User != nil && props.Image != nil">
      <span id="combined-user">{{ props.User.Name }}</span>
      <span id="combined-image">{{ props.Image.URL }}</span>
    </div>

    <div id="loop-guard-outer" p-if="props.Team != nil">
      <div p-for="(idx, member) in props.Team.Members" p-key="idx">
        <span id="loop-member-name">{{ member.Name }}</span>
      </div>
    </div>

    <div id="alternate-guard" p-if="props.MaybeUser != nil">
      <span id="alternate-guarded">{{ props.MaybeUser.Name }}</span>
    </div>

    <div id="negated-guard" p-if="!(props.Other == nil)">
      <span id="negated-guarded">{{ props.Other.Value }}</span>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type User struct {
    Name    string
    Profile *Profile
}

type Profile struct {
    Bio string
}

type Image struct {
    URL string
}

type Team struct {
    Members []User
}

type Other struct {
    Value string
}

type Props struct {
    Image     *Image `prop:"image"`
    User      *User  `prop:"user"`
    Unguarded *User  `prop:"unguarded"`
    Team      *Team  `prop:"team"`
    MaybeUser *User  `prop:"maybeUser"`
    Other     *Other `prop:"other"`
}

func Render(r *piko.RequestData, props Props) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
}
</script>
