<script type="application/x-go">
package main

import (
	templater_dto "piko.sh/piko/internal/templater/templater_dto"
	"testcase_07_advanced_expressions/models"
)

type Response struct {
	Score       int
	IsAdmin     bool
	CurrentUser *models.User
}

func IsAdmin(user *models.User) bool {
	if user == nil {
		return false
	}
	return user.IsAdmin
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	user := &models.User{
		Name:    "Alice",
		IsAdmin: true,
		Address: &models.Address{
			Street: "123 Main St",
			City:   "Anytown",
		},
	}
	return Response{Score: 95, IsAdmin: true, CurrentUser: user}, piko.Metadata{}, nil
}
</script>

<template>
    <div id="grade-check">
        Grade: {{ state.Score > 50 ? (state.Score > 90 ? 'A' : 'B') : 'C' }}
    </div>
    <div id="admin-check" p-if="state.IsAdmin && IsAdmin(state.CurrentUser)">
        Welcome, Admin!
    </div>
    <div id="address-check">
        Street: {{ state.CurrentUser?.Address?.Street }}
    </div>
</template>