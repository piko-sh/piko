<script type="application/x-go">
package main

import "piko.sh/piko"

type State struct {
    Counter int
    Message string
}

func Render(r *piko.RequestData, props piko.NoProps) (State, piko.Metadata, error) {
    return State{Counter: 0, Message: "Hello"}, piko.Metadata{}, nil
}
</script>

<script lang="ts">
export function handleClick(): void {
    console.log('clicked');
}

export function handleSubmit(event: Event): void {
    event.preventDefault();
    console.log('submitted');
}

export const handleChange = (): void => {
    console.log('changed');
};

export function unusedHandler(): void {
    console.log('this is not used');
}

function privateHelper(): void {
    console.log('private');
}
</script>

<template>
    <div>
        <button id="btn-valid-click" p-on:click="handleClick()">Click Me</button>

        <form id="form-valid" p-on:submit="handleSubmit($event)">
            <input type="text" />
            <button type="submit">Submit</button>
        </form>

        <input id="input-valid" p-on:change="handleChange()" />

        <button id="btn-invalid" p-on:click="nonExistentHandler()">Invalid</button>

        <button id="btn-remote" p-on:click="action.actions.DeleteUser()">Action Call</button>

        <button id="btn-helper" p-on:click="helpers.toggleModal()">Helper Call</button>
    </div>
</template>
