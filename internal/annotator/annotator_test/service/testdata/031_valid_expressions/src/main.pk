<script type="application/x-go">
package main

import (
	"piko.sh/piko/wdk/maths"
	templater_dto "piko.sh/piko/internal/templater/templater_dto"
	"testcase_31_valid_expressions/models"
)

type Response struct {
	StringField  string
	IntField     int
	FloatField   float64
	BoolField    bool
	DecimalField maths.Decimal
	MoneyField   maths.Money
	StringSlice  []string
	StringMap    map[string]string
	CurrentUser  models.User
}

func Add(a, b int) int {
	return a + b
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		StringField: "hello",
		IntField:    100,
		FloatField:  50.5,
		BoolField:   true,
		DecimalField: maths.TenDecimal(),
		MoneyField:  maths.NewMoneyFromString("1000", "GBP"),
		StringSlice: []string{"first", "second"},
		StringMap:   map[string]string{"key": "value"},
		CurrentUser: models.User{Name: "Alice"},
	}, piko.Metadata{}, nil
}
</script>

<template>
    <div id="wrapper">
        <p :data-string="state.StringField" :data-int="state.IntField" :data-money="state.MoneyField"></p>

        <div p-if="state.IntField > 50 && state.StringField == 'hello'">Binary Ops OK</div>
        <p>Addition: {{ state.IntField + state.FloatField }}</p>
        <p>Concatenation: {{ state.StringField + " world" }}</p>
        <p>Money Math: {{ state.MoneyField + state.DecimalField }} and {{ state.MoneyField * 2 }}</p>
        <p>Decimal Math: {{ state.DecimalField / state.DecimalField }} and {{ state.DecimalField * 2 }}</p>
        <p>Modulo: {{ 10 % 3 }}</p>

        <div p-if="!false">Unary OK</div>
        <p>Negation: {{ -state.IntField }}</p>

        <p>Slice Index: {{ state.StringSlice[0] }}</p>
        <p>Map Index: {{ state.StringMap["key"] }}</p>

        <p>Top-level Call: {{ Add(5, 3) }}</p>
        <p>Method Call: {{ state.CurrentUser.Greet() }}</p>
    </div>
</template>