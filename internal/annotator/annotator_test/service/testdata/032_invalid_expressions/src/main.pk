<script type="application/x-go">
package main

import (
	templater_dto "piko.sh/piko/internal/templater/templater_dto"
	"testcase_32_invalid_expressions/models"
)

type Response struct {
	StringField  string
	IntField     int
	MoneyField   models.Money
	StringSlice  []string
	User         models.User
}

func Add(a, b int) int {
	return a + b
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{}, piko.Metadata{}, nil
}
</script>

<template>
    <div>
        <div :data-bad="state.User"></div>

        <p p-if="state.StringField > 10">String greater than int</p>
        <p>{{ state.StringField + state.IntField }}</p>
        <p>{{ state.MoneyField * state.MoneyField }}</p>

        <div p-if="!state.IntField">Negating an integer</div>

        <p>{{ state.StringSlice["a"] }}</p>
        <p>{{ state.IntField[0] }}</p>

        <p>{{ Add(1, "a") }}</p>
        <p>{{ state.StringField() }}</p>
        <p>{{ Add(1) }}</p>
    </div>
</template>