<script type="application/x-go">
package main

import (
	templater_dto "piko.sh/piko/internal/templater/templater_dto"
	"testcase_37_isolated_invocation_context/models"
	card "testcase_37_isolated_invocation_context/partials/card.pk"
)

type Response struct {
	FirstCardTitle  string
	SecondCardTitle string
	Users           []models.User
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		FirstCardTitle:  "First Static Card",
		SecondCardTitle: "Second Static Card",
		Users: []models.User{
			{Name: "Alice"},
			{Name: "Bob"},
		},
	}, piko.Metadata{}, nil
}
</script>

<template>
    <div>
        <div id="test-1">
            <h2>Static Invocations</h2>
            <piko:partial is="card" :title="state.FirstCardTitle"></piko:partial>
            <piko:partial is="card" :title="state.SecondCardTitle"></piko:partial>
        </div>

        <div id="test-2">
            <h2>Looped Invocations</h2>
            <ul>
                <li p-for="user in state.Users">
                    <piko:partial is="card" :title="user.Name"></piko:partial>
                </li>
            </ul>
        </div>
    </div>
</template>