<template>
  <div>
    <div p-if="props.User != nil">
      <span id="outer-guarded">{{ props.User.Name }}</span>

      <div p-for="(idx, User) in props.Users" p-key="idx">
        <span id="loop-shadowed">{{ User.Name }}</span>
      </div>
    </div>

    <div p-for="(idx, member) in props.Team" p-key="idx">
      <div p-if="member.Profile != nil">
        <span id="loop-item-guarded">{{ member.Profile.Bio }}</span>
      </div>
      <span id="loop-item-unguarded">{{ member.Profile.Bio }}</span>
    </div>

    <div p-for="(i, item) in props.Items" p-key="i">
      <div p-for="(j, item) in item.Children" p-key="j">
        <span id="inner-loop-shadowed">{{ item.Name }}</span>
      </div>
    </div>

    <div p-for="(idx, ptr) in props.Pointers" p-key="idx">
      <div p-if="ptr != nil">
        <span id="pointer-loop-item-guarded">{{ ptr.Value }}</span>
      </div>
      <span id="pointer-loop-item-unguarded">{{ ptr.Value }}</span>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type User struct {
    Name    string
    Profile *Profile
}

type Profile struct {
    Bio string
}

type Item struct {
    Name     string
    Children []Item
}

type Data struct {
    Value string
}

type Props struct {
    User     *User   `prop:"user"`
    Users    []User  `prop:"users"`
    Team     []User  `prop:"team"`
    Items    []Item  `prop:"items"`
    Pointers []*Data `prop:"pointers"`
}

func Render(r *piko.RequestData, props Props) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
}
</script>
