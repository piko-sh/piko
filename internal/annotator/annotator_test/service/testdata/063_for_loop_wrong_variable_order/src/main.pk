<template>
  <div>
    <h1>Client Event Handler Type Checking</h1>

    <div class="scenario-1">
      <img
        class="photo-item"
        p-for="(img, index) in state.ThumbnailImages"
        p-key="img"
        p-on:click="openLightbox($event, index + 1)"
        :src="img"
      />
    </div>

    <div class="scenario-2">
      <button p-on:click="handleBadEvent($event + 1)">Bad Event Usage</button>
    </div>

    <div class="scenario-3">
      <button p-on:click="handleGoodEvent($event)">Good Event Usage</button>
    </div>

    <div class="scenario-4">
      <img
        class="photo-item"
        p-for="(index, img) in state.ThumbnailImages"
        p-key="img"
        p-on:click="openLightbox($event, index + 1)"
        :src="img"
      />
    </div>

    <div class="scenario-5">
      <button p-on:click="handleBadBool(!state.Counter)">Bad Boolean</button>
    </div>
  </div>
</template>

<script type="application/x-go">
  package main

  import "piko.sh/piko"

  type Response struct {
    ThumbnailImages []string
    Counter         int
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
      ThumbnailImages: []string{
        "/img/photo1.jpg",
        "/img/photo2.jpg",
        "/img/photo3.jpg",
      },
      Counter: 42,
    }, piko.Metadata{}, nil
  }
</script>

<script type="application/javascript">
function openLightbox(e, slideIndex) {
    console.log('Opening lightbox at slide', slideIndex);
}

function handleBadEvent(badArg) {
    console.log('This should not be called:', badArg);
}

function handleGoodEvent(event) {
    console.log('Good event:', event);
}

function handleBadBool(badArg) {
    console.log('This should not be called:', badArg);
}
</script>
