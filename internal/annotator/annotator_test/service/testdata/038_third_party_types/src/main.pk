<template>
    <div>
        <p id="direct-implicit">{{ state.DirectUUID }}</p>
        <p id="direct-explicit">{{ state.DirectUUID.String() }}</p>

        <p id="model-implicit">{{ state.ModelData.UserID }}</p>
        <p id="model-explicit">{{ state.ModelData.UserID.String() }}</p>

        <p id="aliased-implicit">{{ state.AliasedUUID }}</p>
        <p id="aliased-explicit">{{ state.AliasedUUID.String() }}</p>

        <p id="aliased-implicit">{{ state.Deep.Data.UserID }}</p>
        <p id="aliased-explicit">{{ state.Deep.Data.UserID.String() }}</p>
        <p id="aliased-implicit" :test="state.Deep.Data.UserID"></p>
        <p id="aliased-implicit" :test="state.Deep.Data.UserID.String()"></p>

        <p id="model-implicit">{{ state.MoreModelData.UserID }}</p>
        <p id="model-implicit">{{ state.FinalModelData.UserID }}</p>

        <piko:partial is="consumer" id="prop-implicit-string" :title="state.DirectUUID" />

        <piko:partial is="consumer" id="prop-exact-match" :uuid="state.DirectUUID" />

        <piko:partial is="consumer" id="prop-explicit-string" :title="state.DirectUUID.String()" />
    </div>
</template>

<script type="application/x-go">
package main

import (
	"github.com/google/uuid"
	"testcase_38_third_party_types/deep"
	"testcase_38_third_party_types/models"
	templater_dto "piko.sh/piko/internal/templater/templater_dto"
  consumer "testcase_38_third_party_types/partials/prop_consumer.pk"
)

type MyUUID = uuid.UUID

type Response struct {
	Deep        deep.Deep
	DirectUUID  uuid.UUID
	ModelData   models.Data
	MoreModelData   models.MoreData
	FinalModelData   models.FinalData
	AliasedUUID MyUUID
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Deep:        deep.Deep{},
		DirectUUID:  uuid.New(),
		ModelData:   models.NewData(),
		MoreModelData:   models.MoreData{},
		FinalModelData:   models.FinalData{},
		AliasedUUID: MyUUID(uuid.New()),
	}, piko.Metadata{}, nil
}
</script>