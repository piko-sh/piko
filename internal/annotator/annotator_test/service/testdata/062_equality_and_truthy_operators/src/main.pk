<template>
    <div>
        <h1>Equality and Truthy Operator Tests</h1>

        <p id="strict-eq-same-type" p-if="state.Count == 5">
            Strict equality: 5 == 5
        </p>

        <p id="loose-eq-diff-types" p-if="state.Count ~= '5'">
            Loose equality: 5 ~= '5' (coerced)
        </p>

        <p id="truthy-string" p-if="~state.Message">
            Truthy string: non-empty message is truthy
        </p>
        <p id="truthy-int" p-if="~state.Count">
            Truthy int: non-zero count is truthy
        </p>

        <p id="strict-ne" p-if="state.Name != 'unknown'">
            Strict inequality: 'Alice' != 'unknown'
        </p>

        <p id="loose-ne" p-if="state.Count !~= '0'">
            Loose inequality: 5 !~= '0' (coerced)
        </p>

        <p id="combined" p-if="~state.Message && state.Count == 5">
            Combined: truthy message AND count equals 5
        </p>

        <p :class="state.Status == 'active' ? 'enabled' : 'disabled'">
            Status-based class
        </p>

        <p :data-has-message="~state.Message ? 'yes' : 'no'">
            Truthy in ternary
        </p>
    </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct {
    Count   int
    Name    string
    Message string
    Status  string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
        Count:   5,
        Name:    "Alice",
        Message: "Hello, World!",
        Status:  "active",
    }, piko.Metadata{}, nil
}
</script>
