<template>
    <div>
        <p id="deep-path">{{ state.L1Data.L2Data.L3Data.FinalItem.Name }}</p>

        <p id="alias-path">{{ state.L2Alias.FinalItem.Name }}</p>

        <p id="shallow-path">{{ state.L3Data.FinalItem.Name }}</p>
    </div>
</template>

<script type="application/x-go">
package main

import (
    "piko.sh/piko/internal/templater/templater_dto"
    "testcase_40_recursive_resolution_bug/layer1"
    "testcase_40_recursive_resolution_bug/layer2"
    "testcase_40_recursive_resolution_bug/layer3"
    "testcase_40_recursive_resolution_bug/models"
)

type Response struct {
    L1Data  layer1.Layer1Response
    L2Alias layer2.L3Alias
    L3Data  layer3.Layer3Response
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
        L1Data: layer1.Layer1Response{
            L2Data: layer2.Layer2Response{
                L3Data: layer3.Layer3Response{
                    FinalItem: models.Data{Name: "Deep Success"},
                },
            },
        },
        L2Alias: layer2.L3Alias{
            FinalItem: models.Data{Name: "Alias Success"},
        },
        L3Data: layer3.Layer3Response{
            FinalItem: models.Data{Name: "Shallow Success"},
        },
    }, piko.Metadata{}, nil
}
</script>