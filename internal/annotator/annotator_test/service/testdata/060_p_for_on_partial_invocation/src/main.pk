<script type="application/x-go">
package main

import (
	"piko.sh/piko"
	card "testcase_60_p_for_on_partial_invocation/partials/item_card.pk"
)

type Item struct {
	ID   string
	Name string
}

type Response struct {
	Items []Item
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	items := []Item{
		{ID: "1", Name: "First Item"},
		{ID: "2", Name: "Second Item"},
	}
	return Response{Items: items}, piko.Metadata{}, nil
}
</script>

<template>
	<div class="container">
		<piko:partial
			is="card"
			p-for="item in state.Items"
			p-key="item.ID"
			:item_id="item.ID"
			:item_name="item.Name">
		</piko:partial>
	</div>
</template>
