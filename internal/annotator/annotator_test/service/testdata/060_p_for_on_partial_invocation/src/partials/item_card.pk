<script type="application/x-go">
package item_card

import (
	"piko.sh/piko"
)

type Props struct {
	ItemID   string `prop:"item_id"`
	ItemName string `prop:"item_name"`
}

type Response struct {
	DisplayID   string
	DisplayName string
}

func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
	return Response{
		DisplayID:   props.ItemID,
		DisplayName: props.ItemName,
	}, piko.Metadata{}, nil
}
</script>

<template>
	<div class="item-card">
		<span class="item-id">{{ state.DisplayID }}</span>
		<span class="item-name">{{ state.DisplayName }}</span>
	</div>
</template>
