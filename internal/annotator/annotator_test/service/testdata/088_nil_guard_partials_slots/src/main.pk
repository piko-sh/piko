<script type="application/x-go">
package main

import "piko.sh/piko"
import data_display "testcase_88_nil_guard_partials_slots/partials/data_display.pk"
import slot_wrapper "testcase_88_nil_guard_partials_slots/partials/slot_wrapper.pk"

type Item struct {
    Name string
}

type Props struct {
    Item *Item `prop:"item"`
}

func Render(r *piko.RequestData, props Props) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{}, nil
}
</script>

<template>
  <div>
    <piko:partial is="data_display"></piko:partial>

    <div p-if="props.Item != nil">
      <piko:partial is="slot_wrapper">
        <span id="slot-in-guarded-context">{{ props.Item.Name }}</span>
      </piko:partial>
    </div>

    <div p-if="props.Item != nil">
      <span id="main-guarded">{{ props.Item.Name }}</span>
    </div>
    <span id="main-unguarded">{{ props.Item.Name }}</span>
  </div>
</template>
