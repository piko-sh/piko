<template name="template-literal-deps">
    <div>
        <p>{{ state.greeting }}</p>
        <p>{{ state.fullUrl }}</p>
        <button p-on:click="updateName">Update</button>
    </div>
</template>

<script lang="ts">
    const firstName = "John";
    const lastName = "Doe";

    const fullName = firstName + " " + lastName;

    const title = "Mr.";
    const formalName = title + " " + fullName;
    const greeting = "Hello, " + formalName + "!";

    const protocol = "https";
    const domain = "example.com";
    const path = "/api/v1";
    const baseUrl = protocol + "://" + domain;
    const fullUrl = baseUrl + path + "/users";

    const state = {
        greeting: greeting as string,
        fullUrl: fullUrl as string
    };

    function updateName() {
        state.greeting = "Welcome back, " + formalName + "!";
    }
</script>
