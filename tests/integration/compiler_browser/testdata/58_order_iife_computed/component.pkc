<template name="iife-computed">
    <div>
        <p>Config Value: {{ state.configValue }}</p>
        <p>Computed: {{ state.computed }}</p>
    </div>
</template>

<script lang="ts">
    const CONFIG = (() => {
        const base = 10;
        const multiplier = 2;
        return {
            value: base * multiplier,
            name: "computed"
        };
    })();

    const CONFIG_VALUE = CONFIG.value;
    const CONFIG_NAME = CONFIG.name;

    const COMPUTED_SUM = (() => {
        let sum = 0;
        sum += 10;
        sum += 20;
        sum += 30;
        return sum;
    })();

    const state = {
        configValue: CONFIG_VALUE as number,
        computed: COMPUTED_SUM as number
    };

    function doubleConfig() {
        state.configValue = CONFIG.value * 2;
    }
</script>
