<template name="error-form">
  <div class="error-form">
    <form id="test-form" p-show="!state.hasError && !state.success">
      <input type="email" name="email" id="input-email" placeholder="Email" />
      <input type="number" name="age" id="input-age" placeholder="Age" />
      <button type="button" id="submit-btn" p-on:click="handleSubmit">Submit</button>
    </form>
    <div id="error-container" p-show="state.hasError">
      <h3>Validation Errors</h3>
      <p id="error-message" p-text="state.errorMessage"></p>
      <p>Error Status: <span id="error-status" p-text="state.errorStatus"></span></p>
    </div>
    <div id="success-container" p-show="state.success">
      <h3>Success!</h3>
    </div>
  </div>
</template>

<script lang="ts">
const state = {
  hasError: false,
  success: false,
  errorMessage: '' as string,
  errorStatus: '' as string,
};

async function handleSubmit() {
  const emailInput = this.shadowRoot?.querySelector('#input-email') as HTMLInputElement;
  const ageInput = this.shadowRoot?.querySelector('#input-age') as HTMLInputElement;

  const data = {
    email: emailInput?.value || '',
    age: parseInt(ageInput?.value || '0', 10),
  };

  try {
    await action.validate.Fail(data).call();
    state.success = true;
    state.hasError = false;
  } catch (err: any) {
    state.errorStatus = err.status?.toString() || '422';
    state.errorMessage = err.message || 'Validation failed';
    state.hasError = true;
    state.success = false;
  }
}
</script>
