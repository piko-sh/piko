<template>
  <div id="app">
    <h1>Suppress Helpers Test</h1>

    <button id="suppress-btn" p-on:click="callWithSuppression()">Call Suppressed</button>
    <button id="normal-btn" p-on:click="callWithoutSuppression()">Call Normal</button>

    <div id="toast" style="display:none"></div>
    <div id="result-container" style="display:none">
      <p>Suppressed call done: <span id="suppress-done">false</span></p>
      <p>Normal call done: <span id="normal-done">false</span></p>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Suppress Helpers Test",
    }, nil
}
</script>

<script lang="ts">
piko.registerHelper('showToast', (el, ev, message, variant) => {
    const toast = document.getElementById('toast');
    if (toast) {
        toast.textContent = message;
        toast.style.display = 'block';
        toast.dataset.variant = variant;
    }
});

piko.registerHelper('updateBadge', (el, ev, count) => {
});

export async function callWithSuppression(): Promise<void> {
    try {
        await action.notify.Send({ title: 'Test' })
            .suppressHelpers()
            .call();
        document.getElementById('suppress-done')!.textContent = 'true';
        document.getElementById('result-container')!.style.display = 'block';
    } catch (e: unknown) {
        document.getElementById('suppress-done')!.textContent = 'error';
        document.getElementById('result-container')!.style.display = 'block';
    }
}

export async function callWithoutSuppression(): Promise<void> {
    try {
        await action.notify.Send({ title: 'Test' })
            .call();
        document.getElementById('normal-done')!.textContent = 'true';
    } catch (e: unknown) {
        document.getElementById('normal-done')!.textContent = 'error';
    }
}
</script>
