{
  "description": "Tests that fully static literal args (no state refs) are correctly pre-encoded and passed to the action",
  "requestURL": "/test",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
      "action": "comment",
      "value": "Wait for DOMBinder to bind the p-event handler"
    },
    {
      "action": "waitForSelector",
      "selector": "#target[pk-ev-bound]",
      "timeout": 5000
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "comment",
      "value": "Click the button to dispatch the do-static custom event"
    },
    {
      "action": "click",
      "selector": "#trigger-btn"
    },
    {
      "action": "wait",
      "value": "3000"
    },
    {
      "action": "comment",
      "value": "Verify the static literal values arrived correctly"
    },
    {
      "action": "checkText",
      "selector": "#result-name",
      "expected": "hello"
    },
    {
      "action": "checkText",
      "selector": "#result-count",
      "expected": "42"
    },
    {
      "action": "checkText",
      "selector": "#result-flag",
      "expected": "true"
    }
  ]
}
