{
  "description": "Tests array mutations (push, pop, splice, shift, unshift) triggering reactive updates",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "Array Reactivity Test"
    },
    {
      "action": "waitForSelector",
      "selector": "array-list"
    },
    {
      "action": "checkText",
      "selector": "array-list >>> #count",
      "expected": "Count: 3"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "array-list >>> #push-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "array-list >>> #count",
      "expected": "Count: 4"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_push.html"
    },
    {
      "action": "click",
      "selector": "array-list >>> #shift-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "array-list >>> #count",
      "expected": "Count: 3"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_shift.html"
    },
    {
      "action": "click",
      "selector": "array-list >>> #splice-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "array-list >>> #count",
      "expected": "Count: 4"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_splice.html"
    }
  ]
}
