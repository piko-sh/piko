<template name="array-list">
    <div class="container">
        <div class="controls">
            <button id="push-btn" p-on:click="pushItem">Push (add end)</button>
            <button id="pop-btn" p-on:click="popItem">Pop (remove end)</button>
            <button id="shift-btn" p-on:click="shiftItem">Shift (remove first)</button>
            <button id="unshift-btn" p-on:click="unshiftItem">Unshift (add first)</button>
            <button id="splice-btn" p-on:click="spliceMiddle">Splice (insert middle)</button>
        </div>
        <div class="list-section">
            <p id="count">Count: {{ state.items.length }}</p>
            <ul id="item-list">
                <li p-for="item in state.items" p-key="item" class="list-item">{{ item }}</li>
            </ul>
        </div>
    </div>
</template>

<style>
    .container {
        padding: 1rem;
    }
    .controls {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }
    button {
        padding: 0.5rem 1rem;
        background: #e91e63;
        color: white;
        border: none;
        cursor: pointer;
    }
    .list-section {
        padding: 1rem;
        border: 1px solid #eee;
    }
    .list-item {
        padding: 0.5rem;
        border-bottom: 1px solid #eee;
    }
    .list-item:last-child {
        border-bottom: none;
    }
</style>

<script lang="ts">
    const state = {
        items: ['A', 'B', 'C'],
        counter: 0 as number
    };

    function pushItem() {
        state.counter++;
        state.items.push(`Push-${state.counter}`);
    }

    function popItem() {
        if (state.items.length > 0) {
            state.items.pop();
        }
    }

    function shiftItem() {
        if (state.items.length > 0) {
            state.items.shift();
        }
    }

    function unshiftItem() {
        state.counter++;
        state.items.unshift(`Unshift-${state.counter}`);
    }

    function spliceMiddle() {
        state.counter++;
        const midIndex = Math.floor(state.items.length / 2);
        state.items.splice(midIndex, 0, `Splice-${state.counter}`);
    }
</script>
