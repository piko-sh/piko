<template>
  <div id="app">
    <h1>Action p-event Static Object Test</h1>

    <div id="target"
         p-event:do-profile="action.user.Profile({name: 'Alice', age: 30, active: true})">
      <button id="trigger-btn" p-on:click="triggerProfile()">Trigger Profile</button>
    </div>

    <div id="results">
      <span id="result-name">pending</span>
      <span id="result-age">pending</span>
      <span id="result-active">pending</span>
    </div>

    <div id="error-output" style="display:none"></div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct {}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Action p-event Static Object Test",
    }, nil
}
</script>

<script lang="ts">
piko.registerHelper('showResult', (el, ev, name, age, active) => {
    const rName = document.getElementById('result-name');
    const rAge = document.getElementById('result-age');
    const rActive = document.getElementById('result-active');
    if (rName) rName.textContent = String(name);
    if (rAge) rAge.textContent = String(age);
    if (rActive) rActive.textContent = String(active);
});

export function triggerProfile(): void {
    const target = document.getElementById('target');
    if (target) {
        target.dispatchEvent(new CustomEvent('do-profile', { bubbles: true }));
    }
}
</script>
