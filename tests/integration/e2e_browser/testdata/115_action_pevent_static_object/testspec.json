{
  "description": "Tests that an object literal with mixed static types (string, int, bool) is correctly passed to the action",
  "requestURL": "/test",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
      "action": "comment",
      "value": "Wait for DOMBinder to bind the p-event handler"
    },
    {
      "action": "waitForSelector",
      "selector": "#target[pk-ev-bound]",
      "timeout": 5000
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "comment",
      "value": "Click the button to dispatch the do-profile custom event"
    },
    {
      "action": "click",
      "selector": "#trigger-btn"
    },
    {
      "action": "wait",
      "value": "3000"
    },
    {
      "action": "comment",
      "value": "Verify the static object literal mixed-type values arrived correctly"
    },
    {
      "action": "checkText",
      "selector": "#result-name",
      "expected": "Alice"
    },
    {
      "action": "checkText",
      "selector": "#result-age",
      "expected": "30"
    },
    {
      "action": "checkText",
      "selector": "#result-active",
      "expected": "true"
    }
  ]
}
