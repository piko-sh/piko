<template>
  <div id="app">
    <h1>Required Field Validation Test</h1>
    <p>This test verifies struct input with all required fields works correctly.</p>

    <button id="run-btn" p-on:click="runAction()">Register User</button>

    <div id="result-container" p-ref="resultContainer" style="display: none;">
      <h2>Result:</h2>
      <p>Message: <span id="result-message" p-ref="resultMessage"></span></p>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Required Field Validation Test",
    }, nil
}
</script>

<script lang="ts">
async function runAction(): Promise<void> {
  const result = await action.user.Register({ name: 'Test User', email: 'test@example.com' }).call();
  pk.refs.resultMessage.textContent = result.message || '';
  pk.refs.resultContainer.style.display = 'block';
}
</script>
