    {
      "action": "wait",
      "value": "50"
    },
    {
      "action": "click",
      "selector": "#rapid-btn"
    },
    {
      "action": "wait",
      "value": "50"
    },
    {
      "action": "click",
      "selector": "#rapid-btn"
    },
    {
      "action": "comment",
      "value": "Wait for debounce to fire and server to respond"
