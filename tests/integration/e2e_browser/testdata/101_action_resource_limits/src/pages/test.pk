<template>
  <div id="app">
    <h1>Resource Limits Test</h1>
    <button id="test-btn" p-on:click="runTest()">Run Tests</button>
    <div id="result" p-ref="result">idle</div>
    <div id="fast-status" p-ref="fastStatus">-</div>
    <div id="timeout-status" p-ref="timeoutStatus">-</div>
    <div id="body-status" p-ref="bodyStatus">-</div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Resource Limits Test",
    }, nil
}
</script>

<script lang="ts">
async function runTest(): Promise<void> {
  pk.refs.result.textContent = 'testing';

  try {
    await action.slow.Process({ delayMs: 100 }).call();
    pk.refs.fastStatus.textContent = 'ok';
  } catch (e: any) {
    pk.refs.fastStatus.textContent = 'fail:' + (e.status || 0);
  }

  try {
    await action.slow.Process({ delayMs: 2000 }).call();
    pk.refs.timeoutStatus.textContent = 'unexpected_ok';
  } catch (e: any) {
    pk.refs.timeoutStatus.textContent = 'timeout:' + (e.status || 0);
  }

  try {
    await action.slow.Process({ delayMs: 100, padding: 'x'.repeat(300) }).call();
    pk.refs.bodyStatus.textContent = 'unexpected_ok';
  } catch (e: any) {
    pk.refs.bodyStatus.textContent = 'rejected:' + (e.status || 0);
  }

  const fastOk = pk.refs.fastStatus.textContent === 'ok';
  const timeoutOk = pk.refs.timeoutStatus.textContent?.startsWith('timeout:');
  const bodyOk = pk.refs.bodyStatus.textContent?.startsWith('rejected:');
  pk.refs.result.textContent = (fastOk && timeoutOk && bodyOk) ? 'pass' : 'fail';
}
</script>
