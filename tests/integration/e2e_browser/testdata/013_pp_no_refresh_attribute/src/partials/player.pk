<template public>
  <div class="player-partial">
    <p>Server render count: <span p-text="state.RenderCount"></span></p>
    <div class="counter-container">
      <span id="client-counter" pk-no-refresh data-count="0">0</span>
      <button id="increment-btn" p-on:click="increment()">Increment</button>
    </div>
    <p class="note">The counter above has pk-no-refresh and should preserve its value on partial reload</p>
  </div>
</template>

<style>
  .player-partial {
    border: 1px solid #ccc;
    padding: 1rem;
  }
  .counter-container {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin: 1rem 0;
  }
  #client-counter {
    font-size: 2rem;
    font-weight: bold;
    min-width: 50px;
    text-align: center;
  }
  .note {
    color: #666;
    font-size: 0.875rem;
    font-style: italic;
  }
</style>

<script type="application/x-go">
package main

import (
    "strconv"
    "piko.sh/piko"
)

type Response struct {
    RenderCount int
}

var renderCount int

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    countStr := r.QueryParam("_render_count")
    if countStr != "" {
        renderCount, _ = strconv.Atoi(countStr)
    }
    renderCount++

    return Response{
        RenderCount: renderCount,
    }, piko.Metadata{}, nil
}
</script>

<script lang="ts">
export function increment(): void {
    const el = document.getElementById('client-counter');
    if (el) {
        const count = parseInt(el.getAttribute('data-count') ?? '0') + 1;
        el.setAttribute('data-count', String(count));
        el.textContent = String(count);
    }
}
</script>
