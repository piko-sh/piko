{
  "description": "Tests elements with pk-no-refresh preserve state during morph",
  "requestURL": "/counter",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "pk-no-refresh Test"
    },
    {
      "action": "waitForSelector",
      "selector": "#client-counter"
    },
    {
      "action": "checkText",
      "selector": "#client-counter",
      "expected": "0"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "#increment-btn"
    },
    {
      "action": "checkText",
      "selector": "#client-counter",
      "expected": "1"
    },
    {
      "action": "click",
      "selector": "#increment-btn"
    },
    {
      "action": "checkText",
      "selector": "#client-counter",
      "expected": "2"
    },
    {
      "action": "click",
      "selector": "#reload-btn"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": "#client-counter",
      "expected": "2"
    },
    {
      "action": "checkAttribute",
      "selector": "#client-counter",
      "name": "data-count",
      "expected": "2"
    }
  ]
}
