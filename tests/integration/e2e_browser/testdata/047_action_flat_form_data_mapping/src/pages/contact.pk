<template>
  <div id="app">
    <h1>Contact Form Test</h1>

    <form id="contact-form" p-on:submit.prevent="handleSubmit()">
      <div>
        <label for="firstname">First Name:</label>
        <input type="text" id="firstname" name="firstname" p-ref="firstnameInput" required />
      </div>

      <div>
        <label for="lastname">Last Name:</label>
        <input type="text" id="lastname" name="lastname" p-ref="lastnameInput" required />
      </div>

      <div>
        <label for="email">Email:</label>
        <input type="email" id="email" name="email" p-ref="emailInput" required />
      </div>

      <div>
        <label for="message">Message:</label>
        <textarea id="message" name="message" p-ref="messageInput" required></textarea>
      </div>

      <button type="submit" id="submit-btn">Submit</button>
    </form>

    <div id="result-container" p-ref="resultContainer" style="display: none;">
      <h2>Result:</h2>
      <div id="result">
        <p>First Name: <span id="result-firstname" p-ref="resultFirstname"></span></p>
        <p>Last Name: <span id="result-lastname" p-ref="resultLastname"></span></p>
        <p>Email: <span id="result-email" p-ref="resultEmail"></span></p>
        <p>Message: <span id="result-message" p-ref="resultMessage"></span></p>
      </div>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Contact Form Test",
    }, nil
}
</script>

<script lang="ts">
async function handleSubmit(): Promise<void> {
  const result = await action.contact.Submit({
    firstname: pk.refs.firstnameInput.value,
    lastname: pk.refs.lastnameInput.value,
    email: pk.refs.emailInput.value,
    message: pk.refs.messageInput.value,
  }).call();
  pk.refs.resultFirstname.textContent = result.firstname || '';
  pk.refs.resultLastname.textContent = result.lastname || '';
  pk.refs.resultEmail.textContent = result.email || '';
  pk.refs.resultMessage.textContent = result.message || '';
  pk.refs.resultContainer.style.display = 'block';
}
</script>
