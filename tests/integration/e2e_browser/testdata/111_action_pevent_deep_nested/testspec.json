{
  "description": "Tests that 3-level deep nested object literals in p-event are correctly bound to nested Go structs",
  "requestURL": "/test",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
      "action": "comment",
      "value": "Wait for DOMBinder to bind the p-event handler"
    },
    {
      "action": "waitForSelector",
      "selector": "#target[pk-ev-bound]",
      "timeout": 5000
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "comment",
      "value": "Click the button to dispatch the do-create custom event"
    },
    {
      "action": "click",
      "selector": "#trigger-btn"
    },
    {
      "action": "wait",
      "value": "3000"
    },
    {
      "action": "comment",
      "value": "Verify all 3 nesting levels received correct values"
    },
    {
      "action": "checkText",
      "selector": "#result-org",
      "expected": "Acme Corp"
    },
    {
      "action": "checkText",
      "selector": "#result-dept",
      "expected": "Engineering"
    },
    {
      "action": "checkText",
      "selector": "#result-team",
      "expected": "Platform"
    },
    {
      "action": "checkText",
      "selector": "#result-size",
      "expected": "7"
    }
  ]
}
