<template>
  <div>
    <h1>Programmatic Navigation Test</h1>
    <p class="page-indicator">Current Page: Index</p>
    <p id="nav-hint">Use piko.nav.navigate() to navigate</p>

    <button id="nav-target" p-on:click="goToTarget()">Go to Target</button>
    <button id="nav-params" p-on:click="goToParams()">Go with Params</button>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{
        Title: "Index Page",
    }, nil
}
</script>

<script lang="ts">
function goToTarget(): void {
  piko.nav.navigate('/target');
}

function goToParams(): void {
  piko.nav.navigate('/with-params?foo=bar&count=42');
}
</script>
