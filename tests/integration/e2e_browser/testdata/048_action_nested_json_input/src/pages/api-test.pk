<template>
  <div id="app">
    <h1>Nested JSON Input Test</h1>
    <p>This test verifies nested JSON input works correctly.</p>

    <button id="run-btn" p-on:click="runAction()">Create Item</button>

    <div id="result-container" p-ref="resultContainer" style="display: none;">
      <h2>Result:</h2>
      <p>Name: <span id="result-name" p-ref="resultName"></span></p>
      <p>Value: <span id="result-value" p-ref="resultValue"></span></p>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Nested JSON Input Test",
    }, nil
}
</script>

<script lang="ts">
async function runAction(): Promise<void> {
  const result = await action.api.Create({ name: 'TestItem', value: 42 }).call();
  pk.refs.resultName.textContent = result.name || '';
  pk.refs.resultValue.textContent = String(result.value || '');
  pk.refs.resultContainer.style.display = 'block';
}
</script>
