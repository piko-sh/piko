<template name="lazy-content">
  <div class="lazy-content-wrapper">
    <div id="status-display">
      <p id="visibility-status" p-text="state.status"></p>
      <p id="load-count">Load count: <span p-text="state.loadCount.toString()"></span></p>
      <button id="simulate-visible" p-on:click="simulateVisible">Mark as Visible</button>
      <button id="simulate-hidden" p-on:click="simulateHidden">Mark as Hidden</button>
    </div>

    <div class="spacer"></div>

    <div id="lazy-target">
      <p p-if="state.isLoaded" id="loaded-message">Content loaded when visible!</p>
      <p p-if="!state.isLoaded" id="not-loaded-message">Content not loaded yet</p>
    </div>
  </div>
</template>

<script lang="ts">
const state = {
    status: "Initial" as string,
    isLoaded: false as boolean,
    loadCount: 0 as number
};

function simulateVisible() {
    state.status = "Visible!";
    if (!state.isLoaded) {
        state.isLoaded = true;
        state.loadCount = state.loadCount + 1;
    }
}

function simulateHidden() {
    state.status = "Hidden";
}
</script>

<style>
.lazy-content-wrapper {
    padding: 20px;
}

#status-display {
    position: fixed;
    top: 10px;
    left: 10px;
    background: white;
    padding: 10px;
    border: 1px solid #ccc;
    z-index: 100;
}

.spacer {
    height: 2000px;
    background: linear-gradient(to bottom, #f0f0f0, #e0e0e0);
}

#lazy-target {
    padding: 20px;
    background: #e0ffe0;
    border: 2px solid #00aa00;
    min-height: 100px;
}
</style>
