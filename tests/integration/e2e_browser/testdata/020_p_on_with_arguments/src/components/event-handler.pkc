<template name="event-handler">
    <div class="container">
        <div class="controls">
            <button id="simple-btn" p-on:click="increment">Simple Click</button>
            <button id="args-btn" p-on:click="setMessage('Hello', 42)">Click with Args</button>
            <button id="event-btn" p-on:click="logEvent($event)">Click with $event</button>
        </div>
        <div class="output">
            <p id="count">Count: {{ state.count }}</p>
            <p id="message">Message: {{ state.message }}</p>
            <p id="event-type">Event type: {{ state.eventType }}</p>
        </div>
        <div class="loop-section">
            <h3>Click items in loop:</h3>
            <ul id="item-list">
                <li p-for="(index, item) in state.items" p-key="item" class="clickable-item" p-on:click="selectItem(index, item)">
                    {{ item }}
                </li>
            </ul>
            <p id="selected">Selected: {{ state.selected }}</p>
        </div>
    </div>
</template>

<style>
    .container {
        padding: 1rem;
    }
    .controls, .output, .loop-section {
        margin: 1rem 0;
        padding: 1rem;
        border: 1px solid #eee;
    }
    button {
        padding: 0.5rem 1rem;
        margin-right: 0.5rem;
        background: #673ab7;
        color: white;
        border: none;
        cursor: pointer;
    }
    .clickable-item {
        padding: 0.5rem;
        cursor: pointer;
        border-bottom: 1px solid #eee;
    }
    .clickable-item:hover {
        background: #f0f0f0;
    }
</style>

<script lang="ts">
    const state = {
        count: 0 as number,
        message: 'None' as string,
        eventType: 'None' as string,
        items: ['Apple', 'Banana', 'Cherry'],
        selected: 'None' as string
    };

    function increment() {
        state.count++;
    }

    function setMessage(greeting: string, num: number) {
        state.message = `${greeting} #${num}`;
    }

    function logEvent(event: Event) {
        state.eventType = event.type;
    }

    function selectItem(index: number, item: string) {
        state.selected = `Index ${index}: ${item}`;
    }
</script>
