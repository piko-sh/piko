{
  "description": "Tests p-on:click handlers with arguments and $event access",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "p-on with Arguments Test"
    },
    {
      "action": "waitForSelector",
      "selector": "event-handler"
    },
    {
      "action": "checkText",
      "selector": "event-handler >>> #count",
      "expected": "Count: 0"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "event-handler >>> #simple-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "event-handler >>> #count",
      "expected": "Count: 1"
    },
    {
      "action": "click",
      "selector": "event-handler >>> #args-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "event-handler >>> #message",
      "expected": "Message: Hello #42"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_args_click.html"
    },
    {
      "action": "click",
      "selector": "event-handler >>> #event-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "event-handler >>> #event-type",
      "expected": "Event type: click"
    },
    {
      "action": "click",
      "selector": "event-handler >>> .clickable-item:nth-child(2)"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "event-handler >>> #selected",
      "expected": "Selected: Index 1: Banana"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_loop_click.html"
    }
  ]
}
