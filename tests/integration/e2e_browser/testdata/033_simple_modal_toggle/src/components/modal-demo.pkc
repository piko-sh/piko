<template name="modal-demo">
  <div class="modal-demo">
    <button id="open-btn" p-on:click="openModal">Open Modal</button>
    <p id="status">Status: <span p-text="state.isOpen ? 'Modal Open' : 'Modal Closed'"></span></p>

    <div class="overlay" p-if="state.isOpen">
      <div class="modal-content">
        <h2>Modal Title</h2>
        <p id="modal-message" p-text="state.message"></p>
        <input type="text" id="modal-input" p-model="state.inputValue" placeholder="Enter something..." />
        <div class="modal-actions">
          <button id="update-btn" p-on:click="updateMessage">Update Message</button>
          <button id="close-btn" p-on:click="closeModal">Close</button>
        </div>
      </div>
    </div>
  </div>
</template>

<script lang="ts">
const state = {
    isOpen: false as boolean,
    message: "Welcome to the modal!" as string,
    inputValue: "" as string
};

const openModal = () => {
    state.isOpen = true;
    state.message = "Welcome to the modal!";
    state.inputValue = "";
};

const closeModal = () => {
    state.isOpen = false;
};

const updateMessage = () => {
    if (state.inputValue) {
        state.message = "You typed: " + state.inputValue;
    }
};
</script>

<style>
.modal-demo {
    padding: 20px;
}

.overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}

.modal-content {
    background: white;
    padding: 20px;
    border-radius: 8px;
    min-width: 300px;
}

.modal-actions {
    margin-top: 15px;
    display: flex;
    gap: 10px;
}

button {
    padding: 8px 16px;
    cursor: pointer;
}
</style>
