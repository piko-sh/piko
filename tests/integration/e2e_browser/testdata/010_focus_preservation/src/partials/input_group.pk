<template public>
  <div class="input-group">
    <div class="field">
      <label for="field1">First Name</label>
      <input type="text" id="field1" name="field1" class="input-field" autocomplete="off" pk-no-refresh>
    </div>
    <div class="field">
      <label for="field2">Last Name</label>
      <input type="text" id="field2" name="field2" class="input-field" autocomplete="off" pk-no-refresh>
    </div>
    <div class="field">
      <label for="field3">Email</label>
      <input type="email" id="field3" name="field3" class="input-field" autocomplete="off" pk-no-refresh>
    </div>
    <p class="update-counter">Updates: {{ state.UpdateCount }}</p>
  </div>
</template>

<style>
  .input-group {
    padding: 1rem;
    border: 1px solid #ddd;
  }
  .field {
    margin-bottom: 1rem;
  }
  .field label {
    display: block;
    margin-bottom: 0.25rem;
  }
  .input-field {
    padding: 0.5rem;
    font-size: 1rem;
    width: 200px;
  }
  .update-counter {
    color: #666;
    font-size: 0.875rem;
  }
</style>

<script type="application/x-go">
package main

import (
    "strconv"
    "piko.sh/piko"
)

type Response struct {
    UpdateCount int
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    countStr := r.QueryParam("_update_count")
    count := 0
    if countStr != "" {
        count, _ = strconv.Atoi(countStr)
    }
    count++

    return Response{
        UpdateCount: count,
    }, piko.Metadata{}, nil
}
</script>
