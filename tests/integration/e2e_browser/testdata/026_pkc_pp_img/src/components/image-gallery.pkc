<template name="image-gallery">
    <div class="gallery">
        <h2>Image Gallery Component</h2>
        <div class="gallery-item">
            <piko:img src="@/lib/images/test-red.png" alt="Red test image" class="gallery-image" data-testid="static-img"></piko:img>
            <span class="caption">Static Image</span>
        </div>
        <div class="gallery-item">
            <piko:img :src="state.dynamicSrc" alt="Dynamic image" class="gallery-image" data-testid="dynamic-img"></piko:img>
            <span class="caption">Dynamic Image</span>
        </div>
        <button p-on:click="toggleImage" data-testid="toggle-btn">Toggle Image</button>
    </div>
</template>

<style>
    .gallery {
        padding: 1rem;
    }
    .gallery-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin: 1rem 0;
    }
    .gallery-image {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border: 2px solid #ccc;
    }
    .caption {
        margin-top: 0.5rem;
        font-size: 0.875rem;
        color: #666;
    }
</style>

<script lang="ts">
    const state = {
        dynamicSrc: '@/lib/images/test-red.png'
    };

    function toggleImage() {
        if (state.dynamicSrc === '@/lib/images/test-red.png') {
            state.dynamicSrc = '@/lib/images/test-blue.png';
        } else {
            state.dynamicSrc = '@/lib/images/test-red.png';
        }
    }
</script>
