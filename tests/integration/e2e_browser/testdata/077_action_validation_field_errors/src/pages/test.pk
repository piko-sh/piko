<template>
  <div id="app">
    <h1>Validation Field Errors Test</h1>

    <form id="register-form">
      <input id="username" name="username" />
      <input id="password" name="password" type="password" />
      <button id="register-btn" type="button" p-on:click="register()">Register</button>
    </form>

    <div id="success" style="display:none">Registered!</div>
    <div id="error-info" style="display:none">
      <span id="error-status"></span>
      <span id="error-field"></span>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Validation Field Errors Test",
    }, nil
}
</script>

<script lang="ts">
export async function register(): Promise<void> {
    const username = (document.getElementById('username') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    try {
        const result = await action.user.Register({ username, password }).call();
        document.getElementById('success')!.style.display = 'block';

        document.getElementById('username')!.removeAttribute('error');
        document.getElementById('password')!.removeAttribute('error');
    } catch (e: any) {
        const errorInfo = document.getElementById('error-info')!;
        errorInfo.style.display = 'block';
        document.getElementById('error-status')!.textContent = String(e.status || 'unknown');

        if (e.validationErrors) {
            for (const [field, message] of Object.entries(e.validationErrors)) {
                const fieldEl = document.getElementById(field);
                if (fieldEl) {
                    fieldEl.setAttribute('error', String(message));
                }
                document.getElementById('error-field')!.textContent = field;
            }
        }
    }
}
</script>
