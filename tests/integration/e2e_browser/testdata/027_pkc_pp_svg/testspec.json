{
  "description": "Tests piko:svg element rendering in PPC components with inline SVG for CSS styling",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "PPC piko:svg Test"
    },
    {
      "action": "waitForSelector",
      "selector": "icon-display"
    },
    {
      "action": "wait",
      "value": "1000"
    },
    {
      "action": "waitForSelector",
      "selector": "icon-display >>> svg.star-icon",
      "comment": "piko-svg-inline replaces itself with inline SVG, verify star icon loads"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "icon-display >>> [data-testid='toggle-btn']"
    },
    {
      "action": "wait",
      "value": "1000"
    },
    {
      "action": "waitForSelector",
      "selector": "icon-display >>> svg.dynamic-icon",
      "comment": "After toggle, dynamic icon should be loaded"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_toggle.html"
    }
  ]
}
