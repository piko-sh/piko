{
  "description": "Tests piko:picture element rendering in PPC components with picture wrapper and fallback img",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "PPC piko:picture Test"
    },
    {
      "action": "waitForSelector",
      "selector": "picture-gallery"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "waitForSelector",
      "selector": "picture-gallery >>> picture"
    },
    {
      "action": "waitForSelector",
      "selector": "picture-gallery >>> picture img"
    },
    {
      "action": "checkAttribute",
      "selector": "picture-gallery >>> picture img[data-testid='static-picture']",
      "attribute": "src",
      "contains": "/_piko/assets/testmodule/lib/images/test-photo.png"
    },
    {
      "action": "checkAttribute",
      "selector": "picture-gallery >>> picture img[data-testid='static-picture']",
      "attribute": "alt",
      "expected": "Static photo"
    },
    {
      "action": "checkAttribute",
      "selector": "picture-gallery >>> picture img[data-testid='static-picture']",
      "attribute": "class",
      "expected": "gallery-image"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    }
  ]
}
