{
  "description": "Tests p-show directive toggling CSS display property (element stays in DOM)",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "p-show Visibility Test"
    },
    {
      "action": "waitForSelector",
      "selector": "toggle-visibility"
    },
    {
      "action": "checkText",
      "selector": "toggle-visibility >>> #state-display",
      "expected": "Visible: Yes"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial_visible.html"
    },
    {
      "action": "click",
      "selector": "toggle-visibility >>> #toggle-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "toggle-visibility >>> #state-display",
      "expected": "Visible: No"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_hide.html"
    },
    {
      "action": "click",
      "selector": "toggle-visibility >>> #toggle-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "toggle-visibility >>> #state-display",
      "expected": "Visible: Yes"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_show_again.html"
    }
  ]
}
