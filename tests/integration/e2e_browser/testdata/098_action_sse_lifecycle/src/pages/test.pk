<template>
  <div id="app">
    <h1>SSE Lifecycle Test</h1>
    <button id="start-btn" p-on:click="startLifecycle()">Start</button>
    <div id="phase-events">0</div>
    <div id="progress-events">0</div>
    <div id="data-events">0</div>
    <div id="complete-received">false</div>
    <div id="complete-data"></div>
    <div id="total-events">0</div>
    <div id="lifecycle-status">idle</div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "SSE Lifecycle Test",
    }, nil
}
</script>

<script lang="ts">
export async function startLifecycle(): Promise<void> {
    let phaseCount = 0;
    let progressCount = 0;
    let dataCount = 0;
    let totalEvents = 0;
    const statusEl = document.getElementById('lifecycle-status')!;
    statusEl.textContent = 'connecting';

    try {
        const result = await action.lifecycle.Run({})
            .withOnProgress((data: unknown, eventType: string) => {
                totalEvents++;
                if (eventType === 'phase') phaseCount++;
                if (eventType === 'progress') progressCount++;
                if (eventType === 'message') dataCount++;

                document.getElementById('phase-events')!.textContent = String(phaseCount);
                document.getElementById('progress-events')!.textContent = String(progressCount);
                document.getElementById('data-events')!.textContent = String(dataCount);
                document.getElementById('total-events')!.textContent = String(totalEvents);
                statusEl.textContent = 'streaming';
            })
            .call();

        document.getElementById('complete-received')!.textContent = 'true';
        document.getElementById('complete-data')!.textContent = JSON.stringify(result);
        statusEl.textContent = 'complete';
    } catch {
        statusEl.textContent = 'fetch-error';
    }
}
</script>
