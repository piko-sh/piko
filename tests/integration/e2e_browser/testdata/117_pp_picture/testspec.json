{
  "description": "Tests piko:picture element rendering with picture wrapper, source elements, and fallback img",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "piko:picture Test"
    },
    {
      "action": "waitForSelector",
      "selector": "picture"
    },
    {
      "action": "waitForSelector",
      "selector": "picture img"
    },
    {
      "action": "checkAttribute",
      "selector": "picture img",
      "attribute": "alt",
      "expected": "Test photo"
    },
    {
      "action": "checkAttribute",
      "selector": "picture img",
      "attribute": "class",
      "expected": "hero-image"
    },
    {
      "action": "checkAttribute",
      "selector": "picture img",
      "attribute": "loading",
      "expected": "lazy"
    },
    {
      "action": "checkAttribute",
      "selector": "picture img",
      "attribute": "src",
      "contains": "/_piko/assets/testmodule/lib/images/test-photo.png"
    },
    {
      "action": "checkElementCount",
      "selector": "picture",
      "expected": "1"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "page.html"
    }
  ]
}
