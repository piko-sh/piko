{
  "description": "Tests that .once modifier causes handler to fire only on first event, ignoring subsequent events",
  "requestURL": "/test",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "comment",
      "value": "Click the .once button three times"
    },
    {
      "action": "click",
      "selector": "#once-btn"
    },
    {
      "action": "wait",
      "value": "300"
    },
    {
      "action": "click",
      "selector": "#once-btn"
    },
    {
      "action": "wait",
      "value": "300"
    },
    {
      "action": "click",
      "selector": "#once-btn"
    },
    {
      "action": "wait",
      "value": "300"
    },
    {
      "action": "comment",
      "value": "Only first click should have fired - count should be 1"
    },
    {
      "action": "checkText",
      "selector": "#once-count",
      "expected": "1"
    },
    {
      "action": "comment",
      "value": "Click the normal button three times for comparison"
    },
    {
      "action": "click",
      "selector": "#normal-btn"
    },
    {
      "action": "wait",
      "value": "300"
    },
    {
      "action": "click",
      "selector": "#normal-btn"
    },
    {
      "action": "wait",
      "value": "300"
    },
    {
      "action": "click",
      "selector": "#normal-btn"
    },
    {
      "action": "wait",
      "value": "300"
    },
    {
      "action": "comment",
      "value": "All three clicks should have fired - count should be 3"
    },
    {
      "action": "checkText",
      "selector": "#normal-count",
      "expected": "3"
    }
  ]
}
