<template>
  <div id="app">
    <h1>Action p-event Object Arg Test</h1>

    <div id="target"
         p-event:do-delete="action.item.Delete({item_id: state.ItemID, category_id: state.CategoryID, label: state.Label})">
      <button id="trigger-btn" p-on:click="triggerDelete()">Trigger Delete</button>
    </div>

    <div id="results">
      <span id="result-item">pending</span>
      <span id="result-category">pending</span>
      <span id="result-label">pending</span>
    </div>

    <div id="error-output" style="display:none"></div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct {
    ItemID     string
    CategoryID string
    Label      string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{
        ItemID:     "item-123",
        CategoryID: "cat-456",
        Label:      "My Label",
    }, piko.Metadata{
        Title: "Action p-event Object Arg Test",
    }, nil
}
</script>

<script lang="ts">
piko.registerHelper('showResult', (el, ev, itemID, categoryID, label) => {
    const resultItem = document.getElementById('result-item');
    const resultCategory = document.getElementById('result-category');
    const resultLabel = document.getElementById('result-label');
    if (resultItem) resultItem.textContent = String(itemID);
    if (resultCategory) resultCategory.textContent = String(categoryID);
    if (resultLabel) resultLabel.textContent = String(label);
});

export function triggerDelete(): void {
    const target = document.getElementById('target');
    if (target) {
        target.dispatchEvent(new CustomEvent('do-delete', { bubbles: true }));
    }
}
</script>
