{
  "description": "Tests that .stop modifier calls stopPropagation, preventing parent handlers from firing",
  "requestURL": "/test",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "comment",
      "value": "Click child with .stop - should NOT propagate to parent"
    },
    {
      "action": "click",
      "selector": "#child-stop"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": "#child-stop-count",
      "expected": "1"
    },
    {
      "action": "checkText",
      "selector": "#parent-count",
      "expected": "0"
    },
    {
      "action": "comment",
      "value": "Click child without .stop - SHOULD propagate to parent"
    },
    {
      "action": "click",
      "selector": "#child-normal"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": "#child-normal-count",
      "expected": "1"
    },
    {
      "action": "checkText",
      "selector": "#parent-count",
      "expected": "1"
    }
  ]
}
