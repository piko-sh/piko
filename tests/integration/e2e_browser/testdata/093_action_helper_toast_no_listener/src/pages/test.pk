<template>
  <div id="app">
    <h1>Toast No Listener Test</h1>

    <form id="contact-form" p-on:submit.prevent="action.contact.Send($form)">
      <input id="name" name="name" required value="" />
      <textarea id="message" name="message" required></textarea>
      <button id="submit-btn" type="submit">Send</button>
    </form>

    <div id="toast" style="display:none">No toast should appear here</div>
    <div id="action-result" style="display:none"></div>
    <div id="event-probe" style="display:none"></div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Toast No Listener Test",
    }, nil
}
</script>

<script lang="ts">
piko.registerHelper('showToast', (el, ev, message, variant) => {
    if (!message) {
        return;
    }

    document.dispatchEvent(new CustomEvent('pk-show-toast', {
        detail: {
            message,
            variant: variant ?? 'info',
            duration: 5000,
        }
    }));
});

piko.registerHelper('_trackResult', () => {
    const result = document.getElementById('action-result');
    if (result) {
        result.textContent = 'success';
        result.style.display = 'block';
    }
});

document.addEventListener('pk-show-toast', () => {
    const probe = document.getElementById('event-probe');
    if (probe) {
        probe.textContent = 'dispatched';
        probe.style.display = 'block';
    }
});
</script>
