{
  "description": "Tests PK event dispatching triggers partial updates",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "Event Dispatch Test"
    },
    {
      "action": "waitForSelector",
      "selector": ".trigger-partial"
    },
    {
      "action": "waitForSelector",
      "selector": ".receiver-partial"
    },
    {
      "action": "checkText",
      "selector": ".count-value",
      "expected": "1"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "#trigger-btn"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": ".count-value",
      "expected": "2"
    },
    {
      "action": "click",
      "selector": "#trigger-btn"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": ".count-value",
      "expected": "3"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_events.html"
    }
  ]
}
