<template>
  <div id="app">
    <h1>Optional Fields Test</h1>
    <p>This test verifies optional pointer fields default to nil when not provided.</p>

    <button id="run-btn" p-on:click="runAction()">Update Profile</button>

    <div id="result-container" p-ref="resultContainer" style="display: none;">
      <h2>Result:</h2>
      <p>Name: <span id="result-name" p-ref="resultName"></span></p>
      <p>Has Bio: <span id="result-has-bio" p-ref="resultHasBio"></span></p>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Optional Fields Test",
    }, nil
}
</script>

<script lang="ts">
async function runAction(): Promise<void> {
  const result = await action.profile.Update({ name: 'Alice' }).call();
  pk.refs.resultName.textContent = result.name || '';
  pk.refs.resultHasBio.textContent = result.hasBio ? 'yes' : 'no';
  pk.refs.resultContainer.style.display = 'block';
}
</script>
