<template>
  <div id="app">
    <h1>Array Input Test</h1>
    <p>This test verifies array/slice inputs work correctly with JSON arrays.</p>

    <button id="run-btn" p-on:click="runAction()">Save Tags</button>

    <div id="result-container" p-ref="resultContainer" style="display: none;">
      <h2>Result:</h2>
      <p>Name: <span id="result-name" p-ref="resultName"></span></p>
      <p>Tag Count: <span id="result-count" p-ref="resultCount"></span></p>
      <p>Tags: <span id="result-tags" p-ref="resultTags"></span></p>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Array Input Test",
    }, nil
}
</script>

<script lang="ts">
async function runAction(): Promise<void> {
  const result = await action.tags.Save({ name: 'My Article', tags: ['go', 'web', 'piko'] }).call();
  pk.refs.resultName.textContent = result.name || '';
  pk.refs.resultCount.textContent = String(result.tagCount || 0);
  pk.refs.resultTags.textContent = (result.tags || []).join(', ');
  pk.refs.resultContainer.style.display = 'block';
}
</script>
