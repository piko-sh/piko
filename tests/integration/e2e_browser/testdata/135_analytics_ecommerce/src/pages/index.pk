<template>
    <div id="app">
        <h1>Piko Shop</h1>
        <p id="user-badge">Logged in as: Alex Demo</p>

        <div id="products">
            <div class="product" data-product-id="prod-001" data-product-name="Wireless Headphones" data-product-price="79.99">
                <span class="product-name">Wireless Headphones</span>
                <span class="product-price">$79.99</span>
                <button class="add-to-cart-btn" id="add-prod-001">Add to Cart</button>
            </div>
            <div class="product" data-product-id="prod-002" data-product-name="Mechanical Keyboard" data-product-price="129.00">
                <span class="product-name">Mechanical Keyboard</span>
                <span class="product-price">$129.00</span>
                <button class="add-to-cart-btn" id="add-prod-002">Add to Cart</button>
            </div>
            <div class="product" data-product-id="prod-003" data-product-name="USB-C Hub" data-product-price="49.99">
                <span class="product-name">USB-C Hub</span>
                <span class="product-price">$49.99</span>
                <button class="add-to-cart-btn" id="add-prod-003">Add to Cart</button>
            </div>
        </div>

        <pp-cart id="cart"></pp-cart>
    </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    piko.AddAnalyticsProperty(r.Context(), "page_category", "storefront")
    piko.AddAnalyticsProperty(r.Context(), "user_id", "user-alex-demo")

    return piko.NoResponse{}, piko.Metadata{
        Title: "Piko Shop - Analytics Demo",
    }, nil
}
</script>
