<template>
  <div id="app">
    <h1>HTML5 Form Validation Test</h1>

    <form id="test-form">
      <input id="email-input" name="email" type="email" required />
      <input id="name-input" name="name" required minlength="3" />
      <button id="submit-btn" type="button" p-on:click="submitForm()">Submit</button>
    </form>

    <div id="result" style="display:none">
      <span id="result-text"></span>
    </div>

    <div id="blocked" style="display:none">Blocked by validation</div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "HTML5 Form Validation Test",
    }, nil
}
</script>

<script lang="ts">
export async function submitForm(): Promise<void> {
    const form = document.getElementById('test-form') as HTMLFormElement;

    if (!form.reportValidity()) {
        const blocked = document.getElementById('blocked');
        if (blocked) blocked.style.display = 'block';
        return;
    }

    try {
        const formData = Object.fromEntries(new FormData(form));
        const result = await action.echo.Message(formData).call();

        const resultEl = document.getElementById('result');
        const resultText = document.getElementById('result-text');
        if (resultEl && resultText) {
            resultText.textContent = `${result.name} (${result.email})`;
            resultEl.style.display = 'block';
        }
    } catch (e) {
        console.error('Action failed:', e);
    }
}
</script>
