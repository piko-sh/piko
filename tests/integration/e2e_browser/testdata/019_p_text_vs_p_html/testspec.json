{
  "description": "Tests p-text (XSS-safe) vs p-html (raw HTML) directives",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "p-text vs p-html Test"
    },
    {
      "action": "waitForSelector",
      "selector": "content-display"
    },
    {
      "action": "checkText",
      "selector": "content-display >>> #text-content",
      "expected": "<strong>Bold</strong> and <em>italic</em> text"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "content-display >>> #set-html"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_html_set.html"
    },
    {
      "action": "click",
      "selector": "content-display >>> #set-script"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "content-display >>> #text-content",
      "expected": "<script>alert(\"XSS\")</script>Safe text"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_script_set.html"
    }
  ]
}
