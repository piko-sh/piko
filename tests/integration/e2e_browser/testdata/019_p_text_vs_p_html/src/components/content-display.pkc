<template name="content-display">
    <div class="container">
        <div class="section">
            <h3>p-text (XSS-safe, escapes HTML)</h3>
            <div id="text-content" class="content" p-text="state.htmlContent">Loading...</div>
        </div>
        <div class="section">
            <h3>p-html (renders raw HTML)</h3>
            <div id="html-content" class="content" p-html="state.htmlContent">Loading...</div>
        </div>
        <div class="controls">
            <button id="set-html" p-on:click="setHtmlContent">Set HTML Content</button>
            <button id="set-script" p-on:click="setScriptContent">Set Script Tag</button>
        </div>
    </div>
</template>

<style>
    .container {
        padding: 1rem;
    }
    .section {
        margin: 1rem 0;
        padding: 1rem;
        border: 1px solid #eee;
    }
    .section h3 {
        margin-top: 0;
        color: #666;
    }
    .content {
        padding: 0.5rem;
        background: #fafafa;
        min-height: 2rem;
    }
    button {
        padding: 0.5rem 1rem;
        margin-right: 0.5rem;
        background: #ff5722;
        color: white;
        border: none;
        cursor: pointer;
    }
</style>

<script lang="ts">
    const state = {
        htmlContent: '<strong>Bold</strong> and <em>italic</em> text' as string
    };

    function setHtmlContent() {
        state.htmlContent = '<a href="#">Link</a> with <span style="color:red">red text</span>';
    }

    function setScriptContent() {
        state.htmlContent = '<script>alert("XSS")</script>Safe text';
    }
</script>
