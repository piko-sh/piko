<template>
  <div id="app">
    <h1>Batch Actions Test</h1>

    <button id="batch-btn" type="button" p-on:click="runBatch()">Run Batch</button>

    <div id="results" style="display:none">
      <span id="result-add"></span>
      <span id="result-multiply"></span>
      <span id="batch-complete"></span>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Batch Actions Test",
    }, nil
}
</script>

<script lang="ts">
export async function runBatch(): Promise<void> {
    try {
        const [addResult, multiplyResult] = await Promise.all([
            action.math.Add({ a: 10, b: 20 }).call(),
            action.math.Multiply({ a: 6, b: 7 }).call()
        ]);

        document.getElementById('result-add')!.textContent = String(addResult.result);
        document.getElementById('result-multiply')!.textContent = String(multiplyResult.result);
        document.getElementById('batch-complete')!.textContent = 'complete';
        document.getElementById('results')!.style.display = 'block';
    } catch (e) {
        document.getElementById('batch-complete')!.textContent = 'error:' + (e as Error).message;
        document.getElementById('results')!.style.display = 'block';
    }
}
</script>
