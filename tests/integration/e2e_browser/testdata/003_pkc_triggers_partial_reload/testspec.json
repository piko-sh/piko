{
  "description": "Tests PPC component triggering remote partial reload",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "PPC Remote Render Test"
    },
    {
      "action": "waitForSelector",
      "selector": "add-to-cart"
    },
    {
      "action": "waitForSelector",
      "selector": ".cart-summary"
    },
    {
      "action": "checkText",
      "selector": "[partial] .item-count",
      "expected": "0"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "wait",
      "value": "2000"
    },
    {
      "action": "waitForSelector",
      "selector": "add-to-cart >>> button"
    },
    {
      "action": "click",
      "selector": "add-to-cart >>> button"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": "[partial] .item-count",
      "expected": "1"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_click.html"
    }
  ]
}
