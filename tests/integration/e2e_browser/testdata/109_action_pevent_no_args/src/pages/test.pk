<template>
  <div id="app">
    <h1>Action p-event No Args Test</h1>

    <div id="target"
         p-event:do-ping="action.calc.Ping()">
      <button id="trigger-btn" p-on:click="triggerPing()">Trigger Ping</button>
    </div>

    <div id="results">
      <span id="result">pending</span>
    </div>

    <div id="error-output" style="display:none"></div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct {}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Action p-event No Args Test",
    }, nil
}
</script>

<script lang="ts">
piko.registerHelper('showResult', (el, ev, result) => {
    const resultEl = document.getElementById('result');
    if (resultEl) resultEl.textContent = String(result);
});

export function triggerPing(): void {
    const target = document.getElementById('target');
    if (target) {
        target.dispatchEvent(new CustomEvent('do-ping', { bubbles: true }));
    }
}
</script>
