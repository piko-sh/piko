<template>
  <div id="app">
    <h1>Network Timeout Test</h1>
    <p>Tests client-side timeout handling with AbortController</p>

    <button id="test-btn" p-on:click="runTest()">Run Test</button>

    <div id="result-container" p-ref="resultContainer" style="display: none;">
      <h2>Unexpected Success:</h2>
      <p id="result-message" p-ref="resultMessage"></p>
    </div>

    <div id="error-container" p-ref="errorContainer" style="display: none;">
      <h2>Timeout Error:</h2>
      <p>Timed Out: <span id="error-timeout">true</span></p>
      <p>Error Name: <span id="error-name" p-ref="errorName"></span></p>
      <p>Error Status: <span id="error-status" p-ref="errorStatus"></span></p>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Network Timeout Test",
    }, nil
}
</script>

<script lang="ts">
async function runTest(): Promise<void> {
  try {
    const data = await action.slow.Forever({}).setTimeout(500).call();

    pk.refs.resultMessage.textContent = data.message;
    pk.refs.resultContainer.style.display = 'block';
  } catch (e: any) {
    pk.refs.errorName.textContent = e.status === 408 ? 'TimeoutError' : (e.name || 'Error');
    pk.refs.errorStatus.textContent = String(e.status || 'unknown');
    pk.refs.errorContainer.style.display = 'block';
  }
}
</script>
