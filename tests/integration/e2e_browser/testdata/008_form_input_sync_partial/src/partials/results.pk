<template public>
  <form class="search-form" pk-no-track>
    <input type="text" name="query" id="search-input" placeholder="Type to search..." autocomplete="off" :value="state.Query" pk-no-refresh>
    <div class="results">
      <div p-if="state.HasQuery">
        <p class="status">Results for: <span class="query-text" p-text="state.Query"></span></p>
        <ul class="result-list">
          <li>Result 1 for <span p-text="state.Query"></span></li>
          <li>Result 2 for <span p-text="state.Query"></span></li>
        </ul>
      </div>
      <p p-else class="status no-results">No results - enter a search term</p>
    </div>
  </form>
</template>

<style>
  .results {
    padding: 1rem;
    border: 1px solid #ccc;
    margin-top: 1rem;
  }
  .no-results {
    color: #666;
    font-style: italic;
  }
  .query-text {
    font-weight: bold;
  }
</style>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct {
    Query    string
    HasQuery bool
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    query := r.FormValue("query")

    return Response{
        Query:    query,
        HasQuery: query != "",
    }, piko.Metadata{}, nil
}
</script>
