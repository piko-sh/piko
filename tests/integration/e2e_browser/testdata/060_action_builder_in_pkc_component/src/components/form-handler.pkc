<template name="form-handler">
  <div class="form-handler">
    <form id="contact-form">
      <input type="text" name="name" id="input-name" placeholder="Name" />
      <input type="email" name="email" id="input-email" placeholder="Email" />
      <textarea name="message" id="input-message" placeholder="Message"></textarea>
      <button type="button" id="submit-btn" p-on:click="handleSubmit">Submit</button>
    </form>
    <div id="form-result" p-show="state.submitted">
      <p>Success: <span id="result-success" p-text="state.success"></span></p>
      <p>ID: <span id="result-id" p-text="state.id"></span></p>
      <p>Summary: <span id="result-summary" p-text="state.summary"></span></p>
    </div>
  </div>
</template>

<script lang="ts">
const state = {
  submitted: false,
  success: '' as string,
  id: '' as string,
  summary: '' as string,
};

async function handleSubmit() {
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formData = new FormData(form);

  const data = {
    name: formData.get('name') as string,
    email: formData.get('email') as string,
    message: formData.get('message') as string,
  };

  try {
    const result = await action.form.Submit(data).call();
    state.success = result.success ? 'true' : 'false';
    state.id = result.id;
    state.summary = result.summary;
    state.submitted = true;
  } catch (err) {
    console.error('Form submission failed:', err);
  }
}
</script>
