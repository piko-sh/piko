<template>
  <div>
    <h1>Template For Test</h1>
    <h2>Server-Rendered (PK)</h2>
    <dl id="server-dl">
      <template p-for="item in state.Definitions" p-key="item.ID">
        <dt p-text="item.Term"></dt>
        <dd p-text="item.Definition"></dd>
      </template>
    </dl>
    <h2>Client-Rendered (PKC)</h2>
    <definition-list></definition-list>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Definition struct {
  ID         int
  Term       string
  Definition string
}

type Response struct {
  Definitions []Definition
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
  return Response{
    Definitions: []Definition{
      {ID: 1, Term: "HTML", Definition: "HyperText Markup Language"},
      {ID: 2, Term: "CSS", Definition: "Cascading Style Sheets"},
    },
  }, piko.Metadata{
    Title: "Template For Test",
  }, nil
}
</script>
