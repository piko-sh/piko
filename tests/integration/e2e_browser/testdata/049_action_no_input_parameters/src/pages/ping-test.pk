<template>
  <div id="app">
    <h1>No Input Parameters Test</h1>
    <p>This test verifies actions with no input parameters work correctly.</p>

    <button id="run-btn" p-on:click="runAction()">Run Health Check</button>

    <div id="result-container" p-ref="resultContainer" style="display: none;">
      <h2>Result:</h2>
      <p>Status: <span id="result-status" p-ref="resultStatus"></span></p>
      <p>Message: <span id="result-message" p-ref="resultMessage"></span></p>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "No Input Parameters Test",
    }, nil
}
</script>

<script lang="ts">
async function runAction(): Promise<void> {
  const result = await action.ping.Health().call();
  pk.refs.resultStatus.textContent = result.status || '';
  pk.refs.resultMessage.textContent = result.message || '';
  pk.refs.resultContainer.style.display = 'block';
}
</script>
