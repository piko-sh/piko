{
  "description": "Tests PK lifecycle hooks: onConnected, onDisconnected, onAfterRender, onUpdated",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "PK Lifecycle Hooks Test"
    },
    {
      "action": "waitForSelector",
      "selector": ".lifecycle-partial"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": "#connected-count",
      "expected": "Connected: 1"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial_connected.html"
    },
    {
      "action": "click",
      "selector": "#reload-btn"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "click",
      "selector": "#reload-btn"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": "#before-render-count",
      "expected": "BeforeRender: 1"
    },
    {
      "action": "checkText",
      "selector": "#after-render-count",
      "expected": "AfterRender: 1"
    },
    {
      "action": "checkText",
      "selector": "#updated-count",
      "expected": "Updated: 1"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_reload.html"
    },
    {
      "action": "click",
      "selector": "#nav-other"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "Other Page"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "other_page.html"
    },
    {
      "action": "click",
      "selector": "#nav-main"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "PK Lifecycle Hooks Test"
    },
    {
      "action": "checkText",
      "selector": "#connected-count",
      "expected": "Connected: 1"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "reconnected.html"
    }
  ]
}
