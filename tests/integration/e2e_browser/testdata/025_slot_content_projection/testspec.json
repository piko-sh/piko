{
  "description": "Tests named slots, default slots, and slot content projection",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "Slot Content Projection Test"
    },
    {
      "action": "waitForSelector",
      "selector": "card-component"
    },
    {
      "action": "checkText",
      "selector": "card-component >>> #card-header",
      "expected": "Custom Header Content"
    },
    {
      "action": "checkText",
      "selector": "card-component >>> #card-footer",
      "expected": "Default Footer"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    }
  ]
}
