{
  "description": "Tests that object literals with mixed types (string, int, bool) are correctly encoded and bound",
  "requestURL": "/test",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
      "action": "comment",
      "value": "Wait for DOMBinder to bind the p-event handler"
    },
    {
      "action": "waitForSelector",
      "selector": "#target[pk-ev-bound]",
      "timeout": 5000
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "comment",
      "value": "Click the button to dispatch the do-create custom event"
    },
    {
      "action": "click",
      "selector": "#trigger-btn"
    },
    {
      "action": "wait",
      "value": "3000"
    },
    {
      "action": "comment",
      "value": "Verify all mixed-type fields arrived correctly"
    },
    {
      "action": "checkText",
      "selector": "#result-label",
      "expected": "Widget"
    },
    {
      "action": "checkText",
      "selector": "#result-count",
      "expected": "42"
    },
    {
      "action": "checkText",
      "selector": "#result-active",
      "expected": "true"
    }
  ]
}
