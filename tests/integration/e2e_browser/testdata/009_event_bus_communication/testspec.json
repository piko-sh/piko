{
  "description": "Tests event bus communication between PPC and partial",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "Event Bus Test"
    },
    {
      "action": "waitForSelector",
      "selector": "event-emitter"
    },
    {
      "action": "waitForSelector",
      "selector": ".listener-partial"
    },
    {
      "action": "checkText",
      "selector": ".listener-partial .status",
      "expected": "Waiting..."
    },
    {
      "action": "checkText",
      "selector": ".listener-partial .message",
      "expected": "No events received yet"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "event-emitter >>> button"
    },
    {
      "action": "wait",
      "value": "200"
    },
    {
      "action": "checkText",
      "selector": ".listener-partial .status",
      "expected": "Received: 1 events"
    },
    {
      "action": "checkText",
      "selector": ".listener-partial .message",
      "expected": "Item 1 added"
    },
    {
      "action": "click",
      "selector": "event-emitter >>> button"
    },
    {
      "action": "wait",
      "value": "200"
    },
    {
      "action": "checkText",
      "selector": ".listener-partial .status",
      "expected": "Received: 2 events"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_events.html"
    }
  ]
}
