<template>
  <div id="app">
    <h1>Programmatic callAction Test</h1>

    <button id="call-btn" p-on:click="callDirectly()">Call Action</button>

    <div id="result" style="display:none">
      <p>Echo: <span id="data-echo"></span></p>
      <p>Status: <span id="data-status"></span></p>
      <p>Helpers: <span id="has-helpers"></span></p>
    </div>

    <div id="toast" style="display:none"></div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Programmatic callAction Test",
    }, nil
}
</script>

<script lang="ts">
piko.registerHelper('showToast', (el, ev, message, variant) => {
    const toast = document.getElementById('toast');
    if (toast) {
        toast.textContent = message;
        toast.style.display = 'block';
        toast.dataset.variant = variant;
    }
});

export async function callDirectly(): Promise<void> {
    try {
        const result = await action.echo.Message({
            text: 'programmatic',
            repeat: 5
        }).suppressHelpers().call();

        document.getElementById('data-echo')!.textContent = result.echo;
        document.getElementById('data-status')!.textContent = '200';
        document.getElementById('has-helpers')!.textContent = 'suppressed';
        document.getElementById('result')!.style.display = 'block';
    } catch (e: unknown) {
        const msg = e instanceof Error ? e.message : String(e);
        console.error('action call failed:', msg);
    }
}
</script>
