<template>
  <div id="app">
    <h1>Event Args Parity Test</h1>

    <h2>PKC</h2>
    <event-args></event-args>

    <h2>PK</h2>
    <div>
      <button id="pk-bare-btn" p-on:click="handleBare">Bare</button>
      <button id="pk-event-btn" p-on:click="handleEvent($event)">Event</button>
      <button id="pk-empty-btn" p-on:click="handleEmpty()">Empty</button>
      <button id="pk-arg-btn" p-on:click="handleArg(42)">Arg</button>
      <button id="pk-mixed-btn" p-on:click="handleMixed(42, $event)">Mixed</button>
      <span id="pk-bare-result">pending</span>
      <span id="pk-event-result">pending</span>
      <span id="pk-empty-result">pending</span>
      <span id="pk-arg-result">pending</span>
      <span id="pk-mixed-result">pending</span>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Event Args Parity Test",
    }, nil
}
</script>

<script lang="ts">
export function handleBare(event?: Event) {
    document.getElementById('pk-bare-result')!.textContent = event?.type ?? 'no-event';
}

export function handleEvent(event?: Event) {
    document.getElementById('pk-event-result')!.textContent = event?.type ?? 'no-event';
}

export function handleEmpty(event?: Event) {
    document.getElementById('pk-empty-result')!.textContent = event?.type ?? 'no-event';
}

export function handleArg(arg1: any, event?: Event) {
    document.getElementById('pk-arg-result')!.textContent = `${arg1}:${event?.type ?? 'no-event'}`;
}

export function handleMixed(arg1: any, event?: Event) {
    document.getElementById('pk-mixed-result')!.textContent = `${arg1}:${event?.type ?? 'no-event'}`;
}
</script>
