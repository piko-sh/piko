<template name="checkbox-form">
    <div class="container">
        <div class="checkbox-group">
            <label>
                <input type="checkbox" id="agree-checkbox" p-model="state.agreed">
                I agree to the terms
            </label>
        </div>
        <div class="status">
            <p id="status">Agreement status: {{ state.agreed ? 'Agreed' : 'Not agreed' }}</p>
        </div>
        <div class="controls">
            <button id="toggle-btn" p-on:click="toggleAgreement">Toggle Programmatically</button>
        </div>
    </div>
</template>

<style>
    .container {
        padding: 1rem;
    }
    .checkbox-group {
        margin: 1rem 0;
        padding: 1rem;
        border: 1px solid #eee;
    }
    label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }
    input[type="checkbox"] {
        width: 1.2rem;
        height: 1.2rem;
    }
    .status {
        margin: 1rem 0;
        padding: 1rem;
        background: #f5f5f5;
    }
    button {
        padding: 0.5rem 1rem;
        background: #009688;
        color: white;
        border: none;
        cursor: pointer;
    }
</style>

<script lang="ts">
    const state = {
        agreed: false as boolean
    };

    function toggleAgreement() {
        state.agreed = !state.agreed;
    }
</script>
