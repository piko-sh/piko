{
  "description": "Tests p-model two-way binding for checkbox inputs",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "p-model Checkbox Test"
    },
    {
      "action": "waitForSelector",
      "selector": "checkbox-form"
    },
    {
      "action": "checkText",
      "selector": "checkbox-form >>> #status",
      "expected": "Agreement status: Not agreed"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "checkbox-form >>> #agree-checkbox"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "checkbox-form >>> #status",
      "expected": "Agreement status: Agreed"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_check.html"
    },
    {
      "action": "click",
      "selector": "checkbox-form >>> #agree-checkbox"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "checkbox-form >>> #status",
      "expected": "Agreement status: Not agreed"
    },
    {
      "action": "click",
      "selector": "checkbox-form >>> #toggle-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "checkbox-form >>> #status",
      "expected": "Agreement status: Agreed"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_programmatic_toggle.html"
    }
  ]
}
