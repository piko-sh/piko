<template>
  <div id="app">
    <h1>Action Error Properties Test</h1>

    <button id="validation-btn" p-on:click="triggerValidation()">Trigger Validation Error</button>
    <button id="auth-btn" p-on:click="triggerAuth()">Trigger Auth Error</button>

    <div id="validation-result" style="display:none">
      <span id="v-status"></span>
      <span id="v-isValidation"></span>
      <span id="v-isAuth"></span>
      <span id="v-hasErrors"></span>
    </div>

    <div id="auth-result" style="display:none">
      <span id="a-status"></span>
      <span id="a-isAuth"></span>
      <span id="a-isValidation"></span>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Action Error Properties Test",
    }, nil
}
</script>

<script lang="ts">
export async function triggerValidation(): Promise<void> {
    try {
        await action.errtest.Validation({}).call();
    } catch (e: any) {
        document.getElementById('v-status')!.textContent = String(e.status);
        document.getElementById('v-isValidation')!.textContent = String(e.isValidationError);
        document.getElementById('v-isAuth')!.textContent = String(e.isAuthError);
        document.getElementById('v-hasErrors')!.textContent = String(e.validationErrors !== undefined);
        document.getElementById('validation-result')!.style.display = 'block';
    }
}

export async function triggerAuth(): Promise<void> {
    try {
        await action.errtest.Auth({}).call();
    } catch (e: any) {
        document.getElementById('a-status')!.textContent = String(e.status);
        document.getElementById('a-isAuth')!.textContent = String(e.isAuthError);
        document.getElementById('a-isValidation')!.textContent = String(e.isValidationError);
        document.getElementById('auth-result')!.style.display = 'block';
    }
}
</script>
