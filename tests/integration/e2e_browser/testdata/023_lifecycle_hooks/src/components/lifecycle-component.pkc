<template name="lifecycle-component">
    <div class="container">
        <div class="log-section">
            <h3>Lifecycle Log</h3>
            <ul id="lifecycle-log">
                <li p-for="entry in state.log" p-key="entry">{{ entry }}</li>
            </ul>
        </div>
        <div class="controls">
            <button id="trigger-update" p-on:click="triggerUpdate">Trigger Update</button>
        </div>
        <div class="counters">
            <p id="connect-count">Connected count: {{ state.connectCount }}</p>
            <p id="update-count">Update count: {{ state.updateCount }}</p>
        </div>
    </div>
</template>

<style>
    .container {
        padding: 1rem;
    }
    .log-section {
        margin: 1rem 0;
        padding: 1rem;
        border: 1px solid #eee;
        max-height: 200px;
        overflow-y: auto;
    }
    .log-section h3 {
        margin-top: 0;
    }
    #lifecycle-log {
        margin: 0;
        padding-left: 1.5rem;
    }
    #lifecycle-log li {
        padding: 0.25rem 0;
        font-family: monospace;
    }
    button {
        padding: 0.5rem 1rem;
        background: #3f51b5;
        color: white;
        border: none;
        cursor: pointer;
    }
    .counters {
        margin-top: 1rem;
        padding: 1rem;
        background: #f5f5f5;
    }
</style>

<script lang="ts">
    const state = {
        log: [] as string[],
        connectCount: 0 as number,
        updateCount: 0 as number
    };

    let internalUpdateCount = 0;

    pkc.onConnected(() => {
        state.connectCount++;
        state.log = [...state.log, `onConnected called (count: ${state.connectCount})`];
    });

    pkc.onDisconnected(() => {
        console.log('onDisconnected called');
    });

    pkc.onUpdated((changedProps: Set<string>) => {
        console.log(`onUpdated called, changed: ${Array.from(changedProps).join(', ')}`);
    });

    function triggerUpdate() {
        internalUpdateCount++;
        state.updateCount = internalUpdateCount;
        state.log = [...state.log, `Update triggered (count: ${internalUpdateCount})`];
    }
</script>
