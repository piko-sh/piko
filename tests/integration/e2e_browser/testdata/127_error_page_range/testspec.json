{
  "description": "Verifies range error page !400-499.pk catches 404 and 403 errors but not 500",
  "requestURL": "/nonexistent-page",
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#error-page"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "Client Error"
    },
    {
      "action": "checkText",
      "selector": "#status-code",
      "expected": "404"
    },
    {
      "action": "navigate",
      "value": "/trigger-forbidden"
    },
    {
      "action": "waitForSelector",
      "selector": "#error-page"
    },
    {
      "action": "checkText",
      "selector": "#status-code",
      "expected": "403"
    },
    {
      "action": "checkText",
      "selector": "#error-message",
      "expected": "access denied"
    },
    {
      "action": "navigate",
      "value": "/trigger-bad-request"
    },
    {
      "action": "waitForSelector",
      "selector": "#error-page"
    },
    {
      "action": "checkText",
      "selector": "#status-code",
      "expected": "400"
    },
    {
      "action": "checkText",
      "selector": "#error-message",
      "expected": "missing field"
    }
  ]
}
