<template>
  <div id="app">
    <h1>ActionBuilder Options Test</h1>
    <p>Tests ActionBuilder options like timeout</p>

    <button id="run-btn" p-on:click="runAction()">Run Action</button>

    <div id="result-container" style="display: none;">
      <h2>Result:</h2>
      <p>Status: <span id="result-status">pending</span></p>
      <p>Message: <span id="result-message"></span></p>
    </div>

    <div id="error-container" style="display: none;">
      <h2>Error:</h2>
      <p id="error-message"></p>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "ActionBuilder Options Test",
    }, nil
}
</script>

<script lang="ts">
export async function runAction(): Promise<void> {
  try {
    const result = await action.slow.Process({ delayMs: 100 }).call();

    const statusSpan = document.getElementById('result-status');
    const messageSpan = document.getElementById('result-message');
    const resultContainer = document.getElementById('result-container');

    if (statusSpan) statusSpan.textContent = result.completed ? 'completed' : 'pending';
    if (messageSpan) messageSpan.textContent = result.message || '';
    if (resultContainer) resultContainer.style.display = 'block';
  } catch (e) {
    const errorMessage = document.getElementById('error-message');
    const errorContainer = document.getElementById('error-container');

    if (errorMessage) errorMessage.textContent = (e as Error).message;
    if (errorContainer) errorContainer.style.display = 'block';
  }
}
</script>
