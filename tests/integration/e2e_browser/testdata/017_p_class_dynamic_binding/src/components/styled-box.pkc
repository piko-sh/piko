<template name="styled-box">
    <div class="container">
        <div id="target-box" class="box" p-class="{ active: state.isActive, highlighted: state.isHighlighted }">
            Dynamic Class Box
        </div>
        <div class="controls">
            <button id="toggle-active" p-on:click="toggleActive">Toggle Active</button>
            <button id="toggle-highlight" p-on:click="toggleHighlight">Toggle Highlight</button>
        </div>
        <p id="status">Active: {{ state.isActive ? 'Yes' : 'No' }}, Highlighted: {{ state.isHighlighted ? 'Yes' : 'No' }}</p>
    </div>
</template>

<style>
    .container {
        padding: 1rem;
    }
    .box {
        padding: 2rem;
        margin: 1rem 0;
        border: 2px solid #ccc;
        background: #f5f5f5;
        transition: all 0.2s;
    }
    .box.active {
        border-color: #4caf50;
        background: #e8f5e9;
    }
    .box.highlighted {
        box-shadow: 0 0 10px #ff9800;
    }
    button {
        padding: 0.5rem 1rem;
        margin-right: 0.5rem;
        background: #2196f3;
        color: white;
        border: none;
        cursor: pointer;
    }
</style>

<script lang="ts">
    const state = {
        isActive: true as boolean,
        isHighlighted: false as boolean
    };

    function toggleActive() {
        state.isActive = !state.isActive;
    }

    function toggleHighlight() {
        state.isHighlighted = !state.isHighlighted;
    }
</script>
