{
  "description": "Tests p-class directive with object syntax for dynamic class binding",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "p-class Dynamic Binding Test"
    },
    {
      "action": "waitForSelector",
      "selector": "styled-box"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkClass",
      "selector": "styled-box >>> #target-box",
      "expected": "box active"
    },
    {
      "action": "checkText",
      "selector": "styled-box >>> #status",
      "expected": "Active: Yes, Highlighted: No"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "styled-box >>> #toggle-active"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkClass",
      "selector": "styled-box >>> #target-box",
      "expected": "box"
    },
    {
      "action": "checkText",
      "selector": "styled-box >>> #status",
      "expected": "Active: No, Highlighted: No"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_toggle_active.html"
    },
    {
      "action": "click",
      "selector": "styled-box >>> #toggle-highlight"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkClass",
      "selector": "styled-box >>> #target-box",
      "expected": "box highlighted"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_toggle_highlight.html"
    }
  ]
}
