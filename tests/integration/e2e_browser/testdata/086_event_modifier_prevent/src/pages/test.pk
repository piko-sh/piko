<template>
  <div id="app">
    <h1>Event Modifier: .prevent</h1>

    <a id="link" href="/other-page" p-on:click.prevent="handleLink()">Prevented Link</a>
    <p id="link-result">not clicked</p>

    <a id="link-no-prevent" href="/other-page" p-on:click="handleLinkNoPrevent()">Normal Link</a>
    <p id="no-prevent-result">not clicked</p>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Event Modifier: .prevent",
    }, nil
}
</script>

<script lang="ts">
export function handleLink(): void {
    const el = document.getElementById('link-result');
    if (el) el.textContent = 'clicked';
}

export function handleLinkNoPrevent(): void {
    const el = document.getElementById('no-prevent-result');
    if (el) el.textContent = 'clicked';
}
</script>
