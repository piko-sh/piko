{
  "description": "Tests that PPC components can import JavaScript files using the @/ alias, including multi-line imports",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "PPC JavaScript Import Test"
    },
    {
      "action": "waitForSelector",
      "selector": "pp-calculator"
    },
    {
      "action": "wait",
      "value": "1000"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> h3",
      "expected": "Calculator Component"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-sum",
      "expected": "Sum: (click Add)"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-product",
      "expected": "Product: (click Multiply)"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-text",
      "expected": "Result: (click a button)"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "pp-calculator >>> #btn-add"
    },
    {
      "action": "wait",
      "value": "200"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-sum",
      "expected": "Sum: 8"
    },
    {
      "action": "click",
      "selector": "pp-calculator >>> #btn-multiply"
    },
    {
      "action": "wait",
      "value": "200"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-product",
      "expected": "Product: 15"
    },
    {
      "action": "click",
      "selector": "pp-calculator >>> #btn-upper"
    },
    {
      "action": "wait",
      "value": "200"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-text",
      "expected": "Result: HELLO WORLD"
    },
    {
      "action": "click",
      "selector": "pp-calculator >>> #btn-lower"
    },
    {
      "action": "wait",
      "value": "200"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-text",
      "expected": "Result: hello world"
    },
    {
      "action": "click",
      "selector": "pp-calculator >>> #btn-cap"
    },
    {
      "action": "wait",
      "value": "200"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-text",
      "expected": "Result: Hello world"
    },
    {
      "action": "fill",
      "selector": "pp-calculator >>> #input-a",
      "value": "10"
    },
    {
      "action": "fill",
      "selector": "pp-calculator >>> #input-b",
      "value": "7"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "click",
      "selector": "pp-calculator >>> #btn-add"
    },
    {
      "action": "wait",
      "value": "200"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-sum",
      "expected": "Sum: 17"
    },
    {
      "action": "click",
      "selector": "pp-calculator >>> #btn-multiply"
    },
    {
      "action": "wait",
      "value": "200"
    },
    {
      "action": "checkText",
      "selector": "pp-calculator >>> #result-product",
      "expected": "Product: 70"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_calculations.html"
    }
  ]
}
