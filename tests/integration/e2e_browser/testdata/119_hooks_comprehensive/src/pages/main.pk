<template>
  <div>
    <h1>Hooks Test</h1>

    <span id="hook-nav-start"></span>
    <span id="hook-nav-complete"></span>
    <span id="hook-pageview-nav"></span>
    <span id="hook-form-dirty"></span>
    <span id="hook-form-clean"></span>
    <span id="hook-network-offline"></span>
    <span id="hook-network-online"></span>

    <form id="test-form">
      <input type="text" id="test-input" name="field">
    </form>
  </div>
</template>

<script lang="ts">
piko.hooks.on('page:view', (payload) => {
  if (!payload.isInitialLoad) {
    sessionStorage.setItem('hook-pageview-nav', 'pageview:nav');
  }
});

piko.hooks.on('form:dirty', (payload) => {
  const el = document.getElementById('hook-form-dirty');
  if (el) el.textContent = 'dirty:' + (payload.formId || '');
});

piko.hooks.on('form:clean', (payload) => {
  const el = document.getElementById('hook-form-clean');
  if (el) el.textContent = 'clean:' + (payload.formId || '');
});

piko.hooks.on('network:offline', (payload) => {
  const el = document.getElementById('hook-network-offline');
  if (el) el.textContent = 'offline:' + (typeof payload.timestamp);
});

piko.hooks.on('network:online', (payload) => {
  const el = document.getElementById('hook-network-online');
  if (el) el.textContent = 'online:' + (typeof payload.timestamp);
});

piko.hooks.on('navigation:start', (payload) => {
  sessionStorage.setItem('hook-nav-start', 'nav-start:ok');
});

piko.hooks.on('navigation:complete', (payload) => {
  sessionStorage.setItem('hook-nav-complete',
    'nav-complete:' + (payload.duration >= 0 ? 'yes' : 'no'));
});

</script>

<script type="application/x-go">
package main

import "piko.sh/piko"

func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{Title: "Hooks Test"}, nil
}
</script>
