{
  "description": "Tests that a mix of scalar and object literal args in p-event are correctly passed to a multi-param action",
  "requestURL": "/test",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
      "action": "comment",
      "value": "Wait for DOMBinder to bind the p-event handler"
    },
    {
      "action": "waitForSelector",
      "selector": "#target[pk-ev-bound]",
      "timeout": 5000
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "comment",
      "value": "Click the button to dispatch the do-register custom event"
    },
    {
      "action": "click",
      "selector": "#trigger-btn"
    },
    {
      "action": "wait",
      "value": "3000"
    },
    {
      "action": "comment",
      "value": "Verify both the scalar and object arg values arrived correctly"
    },
    {
      "action": "checkText",
      "selector": "#result-name",
      "expected": "Bob"
    },
    {
      "action": "checkText",
      "selector": "#result-city",
      "expected": "Manchester"
    },
    {
      "action": "checkText",
      "selector": "#result-postcode",
      "expected": "M1 1AA"
    }
  ]
}
