{
  "description": "Tests p-for loop with index variable access and dynamic array updates",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "p-for with Index Test"
    },
    {
      "action": "waitForSelector",
      "selector": "item-list"
    },
    {
      "action": "checkText",
      "selector": "item-list >>> #count",
      "expected": "Item count: 3"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "item-list >>> #add-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "item-list >>> #count",
      "expected": "Item count: 4"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_add.html"
    },
    {
      "action": "click",
      "selector": "item-list >>> #remove-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "item-list >>> #count",
      "expected": "Item count: 3"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_remove.html"
    }
  ]
}
