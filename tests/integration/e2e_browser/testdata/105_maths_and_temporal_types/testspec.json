      "expected": "en"
    },
    {
      "action": "checkText",
      "selector": "#locale-label",
      "expected": "Currency"
    },

    {
      "action": "comment",
      "value": "--- Section 19: LF() locale-aware formatting (en) ---"
    },
    {
      "action": "checkText",
      "selector": "#lf-dec",
      "expected": "19.99"
    },
    {
      "action": "checkText",
      "selector": "#lf-big",
      "expected": "42"
    },
    {
      "action": "checkText",
      "selector": "#lf-large",
      "expected": "1,234,567.89"
    },
    {
      "action": "checkText",
      "selector": "#lf-dec-prec",
      "expected": "3.14"
    },
    {
      "action": "checkText",
