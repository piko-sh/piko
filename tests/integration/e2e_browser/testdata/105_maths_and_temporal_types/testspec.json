{
  "description": "Verifies maths (Decimal, BigInt, Money) and temporal types render correctly in PK pages, partials with props, and PKC components. Also documents known rendering bugs with raw maths types via ValueToString.",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "Maths and Temporal Types Test"
    },

    {
      "action": "comment",
      "value": "--- Section 1: Raw Decimal rendering (MustString path) ---"
    },
    {
      "action": "waitForSelector",
      "selector": "#dec-raw"
    },

    {
      "action": "comment",
      "value": "--- Section 2: Pre-computed Decimal string (MustString control group - this path works) ---"
    },
    {
      "action": "checkText",
      "selector": "#dec-str",
      "expected": "19.99"
    },

    {
      "action": "comment",
      "value": "--- Section 3: Float precision proof (0.1 + 0.2 = 0.3 via Decimal, not 0.30000000000000004) ---"
    },
    {
      "action": "checkText",
      "selector": "#float-str",
      "expected": "0.3"
    },

    {
      "action": "comment",
      "value": "--- Section 4: Decimal arithmetic (pre-computed strings) ---"
    },
    {
      "action": "checkText",
      "selector": "#dec-sum-str",
      "expected": "30.8"
    },
    {
      "action": "checkText",
      "selector": "#dec-diff-str",
      "expected": "66.67"
    },
    {
      "action": "checkText",
      "selector": "#dec-prod-str",
      "expected": "22.5"
    },
    {
      "action": "checkTextContains",
      "selector": "#dec-div-str",
      "expected": "33.3"
    },

    {
      "action": "comment",
      "value": "--- Section 5: BigInt rendering ---"
    },
    {
      "action": "checkText",
      "selector": "#big-str",
      "expected": "42"
    },
    {
      "action": "checkText",
      "selector": "#big-overflow",
      "expected": "9223372036854775808"
    },

    {
      "action": "comment",
      "value": "--- Section 6: BigInt arithmetic ---"
    },
    {
      "action": "checkText",
      "selector": "#big-sum-str",
      "expected": "1000"
    },
    {
      "action": "checkText",
      "selector": "#big-prod-str",
      "expected": "56088"
    },

    {
      "action": "comment",
      "value": "--- Section 7: Money rendering ---"
    },
    {
      "action": "checkTextContains",
      "selector": "#money-str",
      "expected": "1500"
    },
    {
      "action": "checkTextContains",
      "selector": "#money-str",
      "expected": "USD"
    },
    {
      "action": "checkTextContains",
      "selector": "#money-gb",
      "expected": "1,500"
    },
    {
      "action": "checkTextContains",
      "selector": "#money-us",
      "expected": "1,500"
    },

    {
      "action": "comment",
      "value": "--- Section 8: Temporal types (pre-formatted strings) ---"
    },
    {
      "action": "checkText",
      "selector": "#temporal-date",
      "expected": "2026-01-15"
    },
    {
      "action": "checkText",
      "selector": "#temporal-datetime",
      "expected": "2026-01-15T10:30:00Z"
    },
    {
      "action": "checkText",
      "selector": "#temporal-time",
      "expected": "14:30:45"
    },
    {
      "action": "checkText",
      "selector": "#temporal-duration",
      "expected": "1h30m0s"
    },

    {
      "action": "comment",
      "value": "--- Section 9: Comparison results ---"
    },
    {
      "action": "checkText",
      "selector": "#cmp-dec-gt",
      "expected": "true"
    },
    {
      "action": "checkText",
      "selector": "#cmp-dec-eq",
      "expected": "true"
    },
    {
      "action": "checkText",
      "selector": "#cmp-big-lt",
      "expected": "true"
    },

    {
      "action": "comment",
      "value": "--- Section 10: Ternary with maths types ---"
    },
    {
      "action": "checkText",
      "selector": "#ternary-result",
      "expected": "19.99"
    },

    {
      "action": "comment",
      "value": "--- Section 11: Template literal interpolation ---"
    },
    {
      "action": "checkText",
      "selector": "#tpl-price",
      "expected": "Price: 19.99"
    },
    {
      "action": "checkText",
      "selector": "#tpl-bigint",
      "expected": "Items: 42"
    },

    {
      "action": "comment",
      "value": "--- Section 12: Attribute bindings ---"
    },
    {
      "action": "checkAttribute",
      "selector": "#attr-dec",
      "name": "data-value",
      "expected": "19.99"
    },
    {
      "action": "checkAttribute",
      "selector": "#attr-big",
      "name": "data-value",
      "expected": "42"
    },

    {
      "action": "comment",
