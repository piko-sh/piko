    },
    {
      "action": "waitForSelector",
      "selector": "#inline-dec-add"
    },
    {
      "action": "checkText",
      "selector": "#inline-dec-add",
      "expected": "0.3"
    },
    {
      "action": "checkText",
      "selector": "#inline-dec-sub",
      "expected": "66.67"
    },
    {
      "action": "checkText",
      "selector": "#inline-dec-mul",
      "expected": "22.5"
    },
    {
      "action": "checkText",
      "selector": "#inline-dec-div",
      "expected": "2.5"
    },
    {
      "action": "checkText",
      "selector": "#inline-big-add",
      "expected": "1000"
    },
    {
      "action": "checkText",
      "selector": "#inline-big-mul",
      "expected": "56088"
    },
    {
      "action": "checkText",
      "selector": "#inline-dec-gt",
      "expected": "true"
    },
    {
      "action": "checkText",
      "selector": "#inline-dec-lt",
      "expected": "true"
    },
    {
      "action": "checkText",
      "selector": "#inline-dec-eq-cmp",
      "expected": "true"
    },
    {
      "action": "checkText",
      "selector": "#inline-ternary-dec",
      "expected": "comparable"
    },
    {
      "action": "checkText",
      "selector": "#inline-ternary-price",
      "expected": "expensive"
    },
    {
      "action": "checkText",
      "selector": "#inline-tpl-sum",
      "expected": "Sum: 30.8"
    },

    {
      "action": "comment",
      "value": "--- Section 14: Partial with props ---"
    },
    {
      "action": "waitForSelector",
      "selector": "#partial-display"
    },
    {
      "action": "checkText",
      "selector": "#partial-price",
      "expected": "19.99"
    },
    {
      "action": "checkText",
      "selector": "#partial-quantity",
      "expected": "42"
    },
    {
      "action": "checkTextContains",
      "selector": "#partial-total",
      "expected": "19.99"
    },
    {
      "action": "checkTextContains",
      "selector": "#partial-total",
      "expected": "GBP"
    },
    {
      "action": "checkText",
      "selector": "#partial-date",
      "expected": "2026-01-15"
    },

    {
      "action": "comment",
      "value": "--- Section 14b: Partial raw maths types (MustString path) ---"
    },
    {
      "action": "checkText",
      "selector": "#partial-dec-raw",
      "expected": "19.99"
    },
    {
      "action": "checkText",
      "selector": "#partial-big-raw",
      "expected": "42"
    },

    {
      "action": "comment",
      "value": "--- Section 14c: Partial inline literal expressions ---"
    },
    {
      "action": "checkText",
      "selector": "#partial-inline-add",
      "expected": "0.3"
    },
    {
      "action": "checkText",
      "selector": "#partial-inline-mul",
      "expected": "22.5"
    },
    {
      "action": "checkText",
