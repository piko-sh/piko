      "expected": "true"
    },
    {
      "action": "checkText",
      "selector": "#partial-inline-bigadd",
      "expected": "1000"
    },

    {
      "action": "comment",
      "value": "--- Section 14d: Partial mixed state + literal expressions ---"
    },
    {
      "action": "checkText",
      "selector": "#partial-mixed-gt",
      "expected": "true"
    },
    {
      "action": "checkText",
      "selector": "#partial-mixed-tpl",
      "expected": "Price: 19.99"
    },
    {
      "action": "checkText",
      "selector": "#partial-mixed-ternary",
      "expected": "expensive"
    },

    {
      "action": "comment",
      "value": "--- Section 14e: Direct maths-typed props (passed through from parent) ---"
    },
    {
      "action": "checkText",
      "selector": "#partial-direct-dec",
      "expected": "0.3"
    },
    {
      "action": "checkText",
      "selector": "#partial-direct-big",
      "expected": "1000"
    },
    {
      "action": "checkText",
      "selector": "#partial-direct-dec-ptext",
      "expected": "0.3"
    },
    {
      "action": "checkText",
      "selector": "#partial-direct-dec-gt",
      "expected": "true"
    },
    {
      "action": "checkText",
      "selector": "#partial-direct-dec-tpl",
      "expected": "Direct: 0.3"
    },
    {
      "action": "checkText",
      "selector": "#partial-direct-dec-ternary",
      "expected": "above"
    },

    {
      "action": "comment",
      "value": "--- Section 15: PKC component (Go->JS boundary) ---"
    },
    {
      "action": "waitForSelector",
      "selector": "maths-viewer"
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "checkText",
      "selector": "maths-viewer >>> #pkc-decimal",
      "expected": "Decimal: 19.99"
    },
    {
      "action": "checkText",
      "selector": "maths-viewer >>> #pkc-bigint",
      "expected": "BigInt: 9223372036854775808"
    },
    {
      "action": "checkTextContains",
      "selector": "maths-viewer >>> #pkc-precision",
      "expected": "0.30000000000000004"
    },

    {
      "action": "comment",
      "value": "--- Section 16: F() format builder ---"
    },
    {
      "action": "checkText",
      "selector": "#f-dec",
      "expected": "19.99"
    },
    {
      "action": "checkText",
      "selector": "#f-big",
      "expected": "42"
    },
    {
      "action": "checkTextContains",
      "selector": "#f-money",
      "expected": "1500"
    },
    {
      "action": "checkText",
      "selector": "#f-string",
      "expected": "19.99"
    },
    {
      "action": "checkText",
      "selector": "#f-int",
      "expected": "42"
    },
    {
      "action": "checkTextContains",
      "selector": "#f-float",
      "expected": "3.14159"
    },
    {
      "action": "checkText",
      "selector": "#f-float-prec",
      "expected": "3.14"
    },
    {
      "action": "checkText",
      "selector": "#f-dec-prec0",
      "expected": "20"
    },

    {
      "action": "comment",
      "value": "--- Section 17: F() contexts ---"
    },
    {
      "action": "checkAttribute",
      "selector": "#f-attr",
      "attribute": "data-price",
      "expected": "19.99"
    },
    {
      "action": "checkText",
      "selector": "#f-tpl",
      "expected": "Price: 19.99"
    },

    {
      "action": "comment",
      "value": "--- Section 18: Locale detection (en) ---"
