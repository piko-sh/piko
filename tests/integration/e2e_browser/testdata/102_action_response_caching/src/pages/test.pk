<template>
  <div id="app">
    <h1>Response Caching Test</h1>
    <button id="test-btn" p-on:click="runTest()">Test Cache</button>
    <div id="result">idle</div>
    <div id="ts1">-</div>
    <div id="ts2">-</div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Response Caching Test",
    }, nil
}
</script>

<script lang="ts">
export async function runTest(): Promise<void> {
    const resultEl = document.getElementById('result')!;
    const ts1El = document.getElementById('ts1')!;
    const ts2El = document.getElementById('ts2')!;
    resultEl.textContent = 'testing';

    const data1 = await action.cached.Timestamp({}).call();
    ts1El.textContent = String(data1.timestamp);

    await new Promise(resolve => setTimeout(resolve, 100));

    const data2 = await action.cached.Timestamp({}).call();
    ts2El.textContent = String(data2.timestamp);

    if (data1.timestamp == data2.timestamp) {
        resultEl.textContent = 'cache_hit';
    } else {
        resultEl.textContent = 'cache_miss';
    }
}
</script>
