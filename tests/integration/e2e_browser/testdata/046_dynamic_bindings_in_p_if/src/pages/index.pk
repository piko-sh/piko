<template>
  <div>
    <h1>Dynamic Bindings in p-if Test</h1>
    <p>Tests that :src, :alt, :style bindings work correctly inside p-if blocks when loaded via RemoteRender</p>

    <button id="load-partial-btn" p-on:click="loadPartial()">Load Partial with Conditional Bindings</button>

    <div id="partial-container" class="partial-container">
      <p class="placeholder">Partial not loaded yet</p>
    </div>
  </div>
</template>

<style>
h1 {
    color: #1e293b;
}
#load-partial-btn {
    padding: 12px 24px;
    background: #6366f1;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
    margin-bottom: 1rem;
}
.partial-container {
    min-height: 200px;
    border: 2px dashed #cbd5e1;
    border-radius: 8px;
    padding: 1rem;
}
.placeholder {
    color: #94a3b8;
    text-align: center;
    padding: 2rem;
}
</style>

<script type="application/x-go">
package main

import "piko.sh/piko"

func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{
        Title: "Dynamic Bindings in p-if Test",
    }, nil
}
</script>

<script lang="ts">
export async function loadPartial() {
    const container = document.getElementById('partial-container');
    if (!container) {
        return;
    }

    container.innerHTML = '';

    await piko.partials.render({
        src: '/_piko/partials/conditional_bindings',
        patchLocation: container,
        patchMethod: 'replace',
        childrenOnly: false
    });
}
</script>
