<template>
    <div>
        <h1>PK Refs Across Slots Test</h1>
        <p>Tests that p-ref elements can be accessed across slot boundaries when a partial is loaded into a multi-slot component.</p>

        <button id="load-btn" p-on:click="loadPartialIntoCard()">Load Partial</button>

        <multi-slot-card id="card-container">
            <p class="placeholder">Click "Load Partial" to load content...</p>
        </multi-slot-card>
    </div>
</template>

<style>
h1 {
    color: #1e293b;
}
p {
    color: #64748b;
    margin-bottom: 1.5rem;
}
#load-btn {
    padding: 0.75rem 1.5rem;
    background: #10b981;
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 1rem;
    margin-bottom: 1rem;
}
#load-btn:hover {
    background: #059669;
}
.placeholder {
    color: #9ca3af;
    font-style: italic;
}
</style>

<script type="application/x-go">
package main

import "piko.sh/piko"

func Render(r *piko.RequestData, props piko.NoProps) (piko.NoResponse, piko.Metadata, error) {
    return piko.NoResponse{}, piko.Metadata{
        Title: "PK Refs Across Slots Test",
    }, nil
}
</script>

<script lang="ts">
/**
 * Loads the slotted_content partial into the multi-slot-card.
 * The partial provides content for both the default slot and the actions slot.
 */
export async function loadPartialIntoCard() {
    const card = document.getElementById('card-container');
    if (!card) {
        return;
    }

    card.innerHTML = '';

    await piko.partials.render({
        src: '/_piko/partials/slotted_content',
        patchLocation: card,
        patchMethod: 'replace',
        childrenOnly: false
    });
}
</script>
