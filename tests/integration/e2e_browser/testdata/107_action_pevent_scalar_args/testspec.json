{
  "description": "Tests that multiple scalar arguments in p-event action calls are correctly passed to the server action",
  "requestURL": "/test",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
      "action": "comment",
      "value": "Wait for DOMBinder to bind the p-event handler"
    },
    {
      "action": "waitForSelector",
      "selector": "#target[pk-ev-bound]",
      "timeout": 5000
    },
    {
      "action": "wait",
      "value": "500"
    },
    {
      "action": "comment",
      "value": "Click the button to dispatch the do-combine custom event"
    },
    {
      "action": "click",
      "selector": "#trigger-btn"
    },
    {
      "action": "wait",
      "value": "3000"
    },
    {
      "action": "comment",
      "value": "Verify the action received all three scalar values"
    },
    {
      "action": "checkText",
      "selector": "#result",
      "expected": "alpha-beta-gamma"
    }
  ]
}
