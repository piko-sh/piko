<template>
  <div id="app">
    <h1>Template Directive Test</h1>

    <form id="contact-form" p-on:submit.prevent="action.contact.Send($form)">
      <input id="name" name="name" value="Alice" />
      <input id="email" name="email" value="alice@test.com" />
      <textarea id="message" name="message">Hello World</textarea>
      <button id="send-btn" type="submit">Send</button>
    </form>

    <div id="result" style="display:none">
      <span id="result-summary"></span>
    </div>
    <span id="url-check" style="display:none"></span>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{
        Title: "Template Directive Test",
    }, nil
}
</script>

<script lang="ts">
piko.registerHelper('showResult', (el, ev, summary) => {
    const result = document.getElementById('result');
    const resultSummary = document.getElementById('result-summary');
    if (result && resultSummary) {
        resultSummary.textContent = summary;
        result.style.display = 'block';
    }
});
</script>
