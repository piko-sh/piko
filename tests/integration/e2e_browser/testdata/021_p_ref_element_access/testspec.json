{
  "description": "Tests p-ref for direct DOM element access via this.refs",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "p-ref Element Access Test"
    },
    {
      "action": "waitForSelector",
      "selector": "ref-component"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "ref-component >>> #focus-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "fill",
      "selector": "ref-component >>> #my-input",
      "value": "Test Input"
    },
    {
      "action": "click",
      "selector": "ref-component >>> #read-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "ref-component >>> #read-value",
      "expected": "Read value: Test Input"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_read.html"
    },
    {
      "action": "click",
      "selector": "ref-component >>> #set-btn"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkValue",
      "selector": "ref-component >>> #my-input",
      "expected": "Set via ref"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_set.html"
    }
  ]
}
