<template name="ref-component">
    <div class="container">
        <div class="input-section">
            <input type="text" id="my-input" p-ref="myInput" placeholder="Type here...">
            <button id="focus-btn" p-on:click="focusInput">Focus Input</button>
            <button id="read-btn" p-on:click="readValue">Read Value</button>
            <button id="set-btn" p-on:click="setValue">Set Value</button>
        </div>
        <div class="output">
            <p id="read-value">Read value: {{ state.readValue }}</p>
        </div>
    </div>
</template>

<style>
    .container {
        padding: 1rem;
    }
    .input-section {
        margin: 1rem 0;
    }
    input {
        padding: 0.5rem;
        margin-right: 0.5rem;
        border: 2px solid #ccc;
        font-size: 1rem;
    }
    input:focus {
        border-color: #2196f3;
        outline: none;
    }
    button {
        padding: 0.5rem 1rem;
        margin-right: 0.5rem;
        background: #2196f3;
        color: white;
        border: none;
        cursor: pointer;
    }
    .output {
        margin-top: 1rem;
        padding: 1rem;
        background: #f5f5f5;
    }
</style>

<script lang="ts">
    const state = {
        readValue: 'None' as string
    };

    function focusInput() {
        this.refs.myInput.focus();
    }

    function readValue() {
        state.readValue = this.refs.myInput.value || '(empty)';
    }

    function setValue() {
        this.refs.myInput.value = 'Set via ref';
    }
</script>
