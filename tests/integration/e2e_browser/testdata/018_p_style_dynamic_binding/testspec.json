{
  "description": "Tests p-style directive with object syntax for inline dynamic styles",
  "requestURL": "/main",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "h1"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "p-style Dynamic Binding Test"
    },
    {
      "action": "waitForSelector",
      "selector": "dynamic-style"
    },
    {
      "action": "checkText",
      "selector": "dynamic-style >>> #status",
      "expected": "Color: blue, Size: 16px"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "initial.html"
    },
    {
      "action": "click",
      "selector": "dynamic-style >>> #change-color"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "dynamic-style >>> #status",
      "expected": "Color: red, Size: 16px"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_color_change.html"
    },
    {
      "action": "click",
      "selector": "dynamic-style >>> #increase-size"
    },
    {
      "action": "wait",
      "value": "100"
    },
    {
      "action": "checkText",
      "selector": "dynamic-style >>> #status",
      "expected": "Color: red, Size: 20px"
    },
    {
      "action": "captureDOM",
      "selector": "#app",
      "goldenFile": "after_size_increase.html"
    }
  ]
}
