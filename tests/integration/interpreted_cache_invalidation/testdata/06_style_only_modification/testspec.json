{
  "description": "Style-only modification should hit Tier 1 cache",
  "requestURL": "/main",
  "isFragment": false,
  "stages": [
    {
      "stage": 0,
      "description": "Initial build with base styles",
      "expectedGolden": "stage_0.html",
      "expectTier1Miss": true,
      "expectTier2Miss": true,
      "expectFullBuild": true,
      "expectFastPath": false
    },
    {
      "stage": 1,
      "description": "Style block changed, script unchanged - should hit Tier 1 cache (fast path)",
      "expectedGolden": "stage_1.html",
      "expectTier1Hit": true,
      "expectTier2Miss": true,
      "expectFullBuild": false,
      "expectFastPath": true,
      "expectChange": true,
      "delayBeforeRenderMs": 10
    },
    {
      "stage": 2,
      "description": "Style block changed again, script unchanged - should hit Tier 1 cache (fast path)",
      "expectedGolden": "stage_2.html",
      "expectTier1Hit": true,
      "expectTier2Miss": true,
      "expectFullBuild": false,
      "expectFastPath": true,
      "expectChange": true,
      "delayBeforeRenderMs": 10
    }
  ]
}
