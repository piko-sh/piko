{
  "description": "Mixed modifications: template → script → template sequence",
  "requestURL": "/main",
  "isFragment": false,
  "stages": [
    {
      "stage": 0,
      "description": "Initial build",
      "expectedGolden": "stage_0.html",
      "expectTier1Miss": true,
      "expectTier2Miss": true,
      "expectFullBuild": true,
      "expectFastPath": false
    },
    {
      "stage": 1,
      "description": "Template changed, script unchanged - should hit Tier 1 cache (fast path)",
      "expectedGolden": "stage_1.html",
      "expectTier1Hit": true,
      "expectTier2Miss": true,
      "expectFullBuild": false,
      "expectFastPath": true,
      "expectChange": true,
      "delayBeforeRenderMs": 10
    },
    {
      "stage": 2,
      "description": "Script changed - should trigger full rebuild (both caches miss)",
      "expectedGolden": "stage_2.html",
      "expectTier1Miss": true,
      "expectTier2Miss": true,
      "expectFullBuild": true,
      "expectFastPath": false,
      "expectChange": true,
      "delayBeforeRenderMs": 10
    },
    {
      "stage": 3,
      "description": "Template changed again, script unchanged - should hit Tier 1 cache (fast path)",
      "expectedGolden": "stage_3.html",
      "expectTier1Hit": true,
      "expectTier2Miss": true,
      "expectFullBuild": false,
      "expectFastPath": true,
      "expectChange": true,
      "delayBeforeRenderMs": 10
    }
  ]
}
