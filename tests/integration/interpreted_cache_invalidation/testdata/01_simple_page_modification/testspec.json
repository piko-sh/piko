{
  "description": "Tests that modifying a simple page triggers cache invalidation and rebuild",
  "requestURL": "/main",
  "isFragment": false,
  "stages": [
    {
      "stage": 0,
      "description": "Initial render with base content",
      "expectedGolden": "stage_0.html",
      "expectCacheHit": false,
      "expectCacheMiss": true
    },
    {
      "stage": 1,
      "description": "After modifying main.pk content",
      "expectedGolden": "stage_1.html",
      "expectCacheHit": false,
      "expectCacheMiss": true,
      "expectChange": true,
      "delayBeforeRenderMs": 10
    }
  ]
}
