{
  "description": "Tests that modifying ONLY the template block (not script) triggers Tier 1 cache hit (fast path)",
  "requestURL": "/main",
  "isFragment": false,
  "stages": [
    {
      "stage": 0,
      "description": "Initial render - both caches cold",
      "expectedGolden": "stage_0.html",
      "expectTier2Miss": true,
      "expectTier1Miss": true,
      "expectFullBuild": true
    },
    {
      "stage": 1,
      "description": "Modify template ONLY - should hit Tier 1 (introspection cache), miss Tier 2",
      "expectedGolden": "stage_1.html",
      "expectTier2Miss": true,
      "expectTier1Hit": true,
      "expectFastPath": true,
      "expectChange": true,
      "delayBeforeRenderMs": 10
    },
    {
      "stage": 2,
      "description": "Modify template again - should still hit Tier 1",
      "expectedGolden": "stage_2.html",
      "expectTier2Miss": true,
      "expectTier1Hit": true,
      "expectFastPath": true,
      "expectChange": true,
      "delayBeforeRenderMs": 10
    }
  ]
}
