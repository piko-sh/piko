{
  "description": "Variant URL resolution: verify that transformed variants can be accessed via URL query parameter",
  "moduleName": "testmodule",
  "transformer": "vips",
  "assets": [
    {
      "sourcePath": "src/lib/images/test-image.bmp",
      "expectedArtefactID": "testmodule/lib/images/test-image.bmp"
    }
  ],
  "variantURLChecks": [
    {
      "description": "Generate and verify webp variant at 200px width",
      "sourceAssetIndex": 0,
      "profileName": "image_w200_webp",
      "transformParams": {
        "width": "200",
        "format": "webp",
        "quality": "85"
      },
      "expectedURLPattern": "/_piko/assets/{artefactID}?v={profile}",
      "expected": {
        "exactWidth": 200,
        "minSizeBytes": 500
      },
      "goldenFile": "variant-200w.webp"
    },
    {
      "description": "Generate and verify webp variant at 400px width (2x density)",
      "sourceAssetIndex": 0,
      "profileName": "image_w400_webp",
      "transformParams": {
        "width": "400",
        "format": "webp",
        "quality": "85"
      },
      "expectedURLPattern": "/_piko/assets/{artefactID}?v={profile}",
      "expected": {
        "exactWidth": 400,
        "minSizeBytes": 1000
      },
      "goldenFile": "variant-400w.webp"
    },
    {
      "description": "Generate and verify jpeg variant at 640px width",
      "sourceAssetIndex": 0,
      "profileName": "image_w640_jpeg",
      "transformParams": {
        "width": "640",
        "format": "jpeg",
        "quality": "80"
      },
      "expectedURLPattern": "/_piko/assets/{artefactID}?v={profile}",
      "expected": {
        "exactWidth": 639,
        "mimeType": "image/jpeg",
        "minSizeBytes": 5000
      },
      "goldenFile": "variant-640w.jpeg"
    }
  ]
}
