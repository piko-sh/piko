{
  "description": "Format conversion matrix: BMP source to JPEG, PNG, WebP with quality variations",
  "moduleName": "testmodule",
  "assets": [
    {
      "sourcePath": "src/lib/images/mercury.bmp",
      "expectedArtefactID": "testmodule/lib/images/mercury.bmp"
    }
  ],
  "transformations": [
    {
      "profileName": "jpeg-low-quality",
      "capabilityName": "image-transform",
      "description": "BMP to JPEG at quality 50",
      "params": {
        "width": "400",
        "height": "284",
        "format": "jpeg",
        "quality": "50",
        "fit": "fill"
      },
      "dependsOn": ["source"],
      "expected": {
        "mimeType": "image/jpeg",
        "outputNotEmpty": true,
        "exactWidth": 400,
        "exactHeight": 284
      },
      "goldenFile": "jpeg-q50.jpg"
    },
    {
      "profileName": "jpeg-high-quality",
      "capabilityName": "image-transform",
      "description": "BMP to JPEG at quality 95",
      "params": {
        "width": "400",
        "height": "284",
        "format": "jpeg",
        "quality": "95",
        "fit": "fill"
      },
      "dependsOn": ["source"],
      "expected": {
        "mimeType": "image/jpeg",
        "outputNotEmpty": true,
        "exactWidth": 400,
        "exactHeight": 284
      },
      "goldenFile": "jpeg-q95.jpg"
    },
    {
