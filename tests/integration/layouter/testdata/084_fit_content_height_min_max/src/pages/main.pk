<template>
  <!-- height: fit-content should behave like height: auto -->
  <div data-layout-id="fit-height" style="box-sizing: content-box; width: 300px; height: fit-content; margin: 0; padding: 10px; background: #eee;">
    <div data-layout-id="fit-height-child" style="box-sizing: content-box; width: 100px; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <!-- height: auto for comparison (should match fit-height) -->
  <div data-layout-id="auto-height" style="box-sizing: content-box; width: 300px; height: auto; margin: 0; padding: 10px; background: #ddd;">
    <div data-layout-id="auto-height-child" style="box-sizing: content-box; width: 100px; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <!-- min-width: fit-content should prevent shrinking below content width -->
  <div data-layout-id="min-width-fit" style="box-sizing: content-box; width: 50px; min-width: fit-content; margin: 0; padding: 10px;">
    <div data-layout-id="min-width-fit-child" style="box-sizing: content-box; width: 200px; height: 30px; margin: 0; padding: 0;"></div>
  </div>

  <!-- max-width: fit-content should cap at content width -->
  <div data-layout-id="max-width-fit" style="box-sizing: content-box; width: 800px; max-width: fit-content; margin: 0; padding: 10px;">
    <div data-layout-id="max-width-fit-child" style="box-sizing: content-box; width: 200px; height: 30px; margin: 0; padding: 0;"></div>
  </div>

  <!-- width: fit-content shrinks to content width -->
  <div data-layout-id="fit-content-arg" style="box-sizing: content-box; width: fit-content; margin: 0; padding: 10px;">
    <div data-layout-id="fit-content-arg-child" style="box-sizing: content-box; width: 500px; height: 30px; margin: 0; padding: 0;"></div>
  </div>

  <!-- flex item with height: fit-content in row direction -->
  <div style="box-sizing: content-box; display: flex; flex-direction: row; width: 400px; margin: 0; padding: 0;">
    <div data-layout-id="flex-fit-height" style="box-sizing: content-box; width: 100px; height: fit-content; margin: 0; padding: 5px;">
      <div data-layout-id="flex-fit-height-child" style="box-sizing: content-box; width: 80px; height: 40px; margin: 0; padding: 0;"></div>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Fit Content Height Min Max Test"}, nil
}
</script>
