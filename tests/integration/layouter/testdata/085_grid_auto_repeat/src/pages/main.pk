<template>
  <!-- auto-fill: 200px tracks in 800px container should produce 4 columns -->
  <div data-layout-id="auto-fill-basic" style="box-sizing: content-box; display: grid; grid-template-columns: repeat(auto-fill, 200px); width: 800px; margin: 0; padding: 0;">
    <div data-layout-id="af-item-1" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="af-item-2" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <!-- auto-fill with gap: 200px tracks + 20px gap in 800px = 3 columns (200+20+200+20+200=640) -->
  <div data-layout-id="auto-fill-gap" style="box-sizing: content-box; display: grid; grid-template-columns: repeat(auto-fill, 200px); gap: 20px; width: 800px; margin: 0; padding: 0;">
    <div data-layout-id="afg-item-1" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="afg-item-2" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <!-- auto-fill with fixed tracks: 100px + repeat(auto-fill, 200px) + 100px in 800px -->
  <div data-layout-id="auto-fill-fixed" style="box-sizing: content-box; display: grid; grid-template-columns: 100px repeat(auto-fill, 200px) 100px; width: 800px; margin: 0; padding: 0;">
    <div data-layout-id="aff-item-1" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="aff-item-2" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="aff-item-3" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="aff-item-4" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <!-- auto-fit: same as auto-fill but empty tracks collapse -->
  <div data-layout-id="auto-fit-collapse" style="box-sizing: content-box; display: grid; grid-template-columns: repeat(auto-fit, 200px); width: 800px; margin: 0; padding: 0;">
    <div data-layout-id="aft-item-1" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="aft-item-2" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Grid Auto Repeat Test"}, nil
}
</script>
