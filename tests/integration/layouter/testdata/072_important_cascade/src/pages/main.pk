<template>
  <!-- Test 1: !important in stylesheet beats normal rule at same specificity -->
  <div data-layout-id="important-beats-normal" class="wide-padding" style="box-sizing: content-box; width: 200px; height: 30px; margin: 0;"></div>

  <!-- Test 2: !important in inline style beats !important in stylesheet -->
  <div data-layout-id="inline-important-wins" style="box-sizing: content-box; width: 200px; height: 30px; margin: 0; padding-left: 30px !important;"></div>

  <!-- Test 3: !important in stylesheet beats normal inline style -->
  <div data-layout-id="stylesheet-important-beats-inline" style="box-sizing: content-box; width: 200px; height: 30px; margin: 0; padding-left: 50px;"></div>

  <!-- Test 4: Later !important rule beats earlier !important rule at same specificity -->
  <div data-layout-id="later-important-wins" style="box-sizing: content-box; width: 200px; height: 30px; margin: 0;"></div>

  <!-- Test 5: Normal cascade still works (later rule wins at same specificity) -->
  <div data-layout-id="normal-cascade" class="pad-20" style="box-sizing: content-box; width: 200px; height: 30px; margin: 0;"></div>
</template>

<style>
  .wide-padding { padding-left: 40px; }
  [data-layout-id="important-beats-normal"] { padding-left: 15px !important; }

  [data-layout-id="inline-important-wins"] { padding-left: 10px !important; }

  [data-layout-id="stylesheet-important-beats-inline"] { padding-left: 25px !important; }

  [data-layout-id="later-important-wins"] { padding-left: 100px !important; }
  [data-layout-id="later-important-wins"] { padding-left: 20px !important; }

  [data-layout-id="normal-cascade"] { padding-left: 10px; }
  .pad-20 { padding-left: 20px; }
</style>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Important Cascade Test"}, nil
}
</script>
