<template>
  <!-- Test 1: Long word with overflow-wrap: break-word wraps within the container -->
  <div data-layout-id="break-word-container" style="box-sizing: content-box; width: 100px; margin: 0; padding: 0; overflow-wrap: break-word;">ABCDEFGHIJKLMNOPQRSTUVWXYZ</div>

  <!-- Test 2: Same long word without overflow-wrap stays on one line (overflow-wrap: normal) -->
  <div data-layout-id="normal-container" style="box-sizing: content-box; width: 100px; margin: 0; padding: 0; overflow-wrap: normal;">ABCDEFGHIJKLMNOPQRSTUVWXYZ</div>

  <!-- Test 3: Short words that fit should not be broken even with overflow-wrap: break-word -->
  <div data-layout-id="no-break-needed" style="box-sizing: content-box; width: 200px; margin: 0; padding: 0; overflow-wrap: break-word;">Hello World</div>

  <!-- Test 4: word-wrap alias works the same as overflow-wrap -->
  <div data-layout-id="word-wrap-alias" style="box-sizing: content-box; width: 100px; margin: 0; padding: 0; word-wrap: break-word;">ABCDEFGHIJKLMNOPQRSTUVWXYZ</div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Overflow Wrap Test"}, nil
}
</script>
