<template>
  <!-- height: fit-content behaves like height: auto -->
  <div data-layout-id="fit-height" style="box-sizing: content-box; height: fit-content; width: 300px; margin: 0; padding: 10px; border: 0;">
    <div data-layout-id="fit-height-child" style="box-sizing: content-box; height: 80px; width: 100px; margin: 0; padding: 0;"></div>
  </div>

  <!-- min-width: fit-content ensures minimum is content width -->
  <div data-layout-id="min-w-fit" style="box-sizing: content-box; min-width: fit-content; width: 50px; margin: 0; padding: 10px; border: 0;">
    <div data-layout-id="min-w-fit-child" style="box-sizing: content-box; width: 200px; height: 40px; margin: 0; padding: 0;"></div>
  </div>

  <!-- max-width: fit-content caps at content width -->
  <div data-layout-id="max-w-fit" style="box-sizing: content-box; max-width: fit-content; width: 800px; margin: 0; padding: 10px; border: 0;">
    <div data-layout-id="max-w-fit-child" style="box-sizing: content-box; width: 200px; height: 40px; margin: 0; padding: 0;"></div>
  </div>

  <!-- width: fit-content shrinks to content -->
  <div data-layout-id="w-fit" style="box-sizing: content-box; width: fit-content; margin: 0; padding: 10px; border: 0;">
    <div data-layout-id="w-fit-child" style="box-sizing: content-box; width: 150px; height: 40px; margin: 0; padding: 0;"></div>
  </div>

  <!-- fit-content on flex cross-axis (height in row flex) -->
  <div data-layout-id="flex-fit-cross" style="box-sizing: content-box; display: flex; width: 400px; margin: 0; padding: 0;">
    <div data-layout-id="flex-fit-item" style="box-sizing: content-box; height: fit-content; width: 100px; margin: 0; padding: 0;">
      <div data-layout-id="flex-fit-inner" style="box-sizing: content-box; height: 60px; margin: 0; padding: 0;"></div>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Fit Content Dimensions Test"}, nil
}
</script>
