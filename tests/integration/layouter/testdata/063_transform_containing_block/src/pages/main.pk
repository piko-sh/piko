<template>
  <!-- A fixed element with no transformed ancestor: positioned relative to viewport -->
  <div data-layout-id="fixed-viewport" style="box-sizing: content-box; position: fixed; top: 10px; left: 10px; width: 80px; height: 30px; margin: 0; padding: 0;"></div>

  <!-- A transformed container that becomes the containing block for its fixed child -->
  <div data-layout-id="transform-parent" style="box-sizing: content-box; transform: translate(0px, 0px); width: 400px; height: 300px; margin: 50px 0 0 100px; padding: 20px;">
    <div data-layout-id="fixed-inside-transform" style="box-sizing: content-box; position: fixed; top: 10px; left: 10px; width: 80px; height: 30px; margin: 0; padding: 0;"></div>
  </div>

  <!-- A positioned ancestor between the fixed element and a transformed grandparent -->
  <div data-layout-id="transform-grandparent" style="box-sizing: content-box; transform: translate(0px, 0px); width: 300px; height: 200px; margin: 20px 0 0 50px; padding: 10px;">
    <div style="box-sizing: content-box; position: relative; width: 200px; height: 100px; margin: 0; padding: 15px;">
      <div data-layout-id="fixed-nested" style="box-sizing: content-box; position: fixed; bottom: 10px; right: 10px; width: 60px; height: 25px; margin: 0; padding: 0;"></div>
    </div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Transform Containing Block Test"}, nil
}
</script>
