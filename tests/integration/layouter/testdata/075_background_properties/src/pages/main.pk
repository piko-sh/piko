<template>
  <!-- Test 1: background-size and background-position do not affect layout -->
  <div data-layout-id="bg-size-position" style="box-sizing: content-box; width: 200px; height: 100px; margin: 0; padding: 0; background-color: #eee; background-size: cover; background-position: center center;"></div>

  <!-- Test 2: background-repeat and background-attachment do not affect layout -->
  <div data-layout-id="bg-repeat-attachment" style="box-sizing: content-box; width: 200px; height: 100px; margin: 0; padding: 0; background-color: #ddd; background-repeat: no-repeat; background-attachment: fixed;"></div>

  <!-- Test 3: background-origin and background-clip do not affect layout -->
  <div data-layout-id="bg-origin-clip" style="box-sizing: content-box; width: 200px; height: 100px; margin: 0; padding: 10px; background-color: #ccc; background-origin: content-box; background-clip: padding-box;"></div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Background Properties Test"}, nil
}
</script>
