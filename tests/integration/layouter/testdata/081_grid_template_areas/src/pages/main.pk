<template>
  <!-- Test 1: Named grid areas with 3-row layout -->
  <div data-layout-id="grid-areas-parent" style="box-sizing: content-box; display: grid; width: 400px; margin: 0; padding: 0; grid-template-columns: 100px 1fr; grid-template-rows: 50px 100px 50px; grid-template-areas: 'header header' 'sidebar main' 'footer footer';">
    <div data-layout-id="grid-header" style="box-sizing: content-box; grid-area: header; margin: 0; padding: 0; background-color: #eee;"></div>
    <div data-layout-id="grid-sidebar" style="box-sizing: content-box; grid-area: sidebar; margin: 0; padding: 0; background-color: #ddd;"></div>
    <div data-layout-id="grid-main" style="box-sizing: content-box; grid-area: main; margin: 0; padding: 0; background-color: #ccc;"></div>
    <div data-layout-id="grid-footer" style="box-sizing: content-box; grid-area: footer; margin: 0; padding: 0; background-color: #bbb;"></div>
  </div>

  <!-- Test 2: grid-area as line shorthand (row-start / col-start / row-end / col-end) -->
  <div data-layout-id="grid-line-parent" style="box-sizing: content-box; display: grid; width: 300px; margin: 10px 0 0 0; padding: 0; grid-template-columns: 100px 100px 100px; grid-template-rows: 50px 50px;">
    <div data-layout-id="grid-line-child" style="box-sizing: content-box; grid-area: 1 / 1 / 3 / 3; margin: 0; padding: 0; background-color: #aaa;"></div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Grid Template Areas Test"}, nil
}
</script>
