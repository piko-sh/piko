<template>
  <!-- Test 1: font shorthand with style, weight, size, and family -->
  <div data-layout-id="font-full" style="box-sizing: content-box; width: 400px; margin: 0; padding: 0; font: italic bold 16px Arial;">Font test italic bold 16px</div>

  <!-- Test 2: font shorthand with size/line-height and family -->
  <div data-layout-id="font-line-height" style="box-sizing: content-box; width: 400px; margin: 0; padding: 0; font: 14px/1.5 serif;">Font test 14px/1.5</div>

  <!-- Test 3: font shorthand with weight, size, and family -->
  <div data-layout-id="font-weight-size" style="box-sizing: content-box; width: 400px; margin: 0; padding: 0; font: bold 12px serif;">Font test bold 12px</div>

  <!-- Test 4: font shorthand with just size and family -->
  <div data-layout-id="font-size-family" style="box-sizing: content-box; width: 400px; margin: 0; padding: 0; font: 20px sans-serif;">Font test 20px</div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Font Shorthand Test"}, nil
}
</script>
