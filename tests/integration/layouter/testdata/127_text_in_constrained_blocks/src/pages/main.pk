<template>
  <div data-layout-id="indent-center" style="box-sizing: content-box; width: 300px; text-indent: 30px; text-align: center; margin: 0; padding: 5px; font-size: 14px;">The first line has indent and centering applied together</div>
  <div data-layout-id="justify-multi" style="box-sizing: content-box; width: 200px; text-align: justify; margin: 10px 0 0 0; padding: 5px; font-size: 14px;">This text is long enough to wrap onto multiple lines inside this box</div>
  <div data-layout-id="indent-right" style="box-sizing: content-box; width: 250px; text-indent: 20px; text-align: right; margin: 10px 0 0 0; padding: 5px; font-size: 14px;">Right aligned text with indent on first line only</div>
  <div data-layout-id="double-lh" style="box-sizing: content-box; width: 200px; line-height: 2; text-align: center; margin: 10px 0 0 0; padding: 5px; font-size: 14px;">Tall spacing between wrapping lines</div>
  <div data-layout-id="overflow-text" style="box-sizing: content-box; width: 150px; height: 40px; overflow: hidden; margin: 10px 0 0 0; padding: 5px; font-size: 14px;">This text is much longer than the box can contain</div>
  <div data-layout-id="indent-wrap" style="box-sizing: content-box; width: 200px; text-indent: 50px; margin: 10px 0 0 0; padding: 5px; font-size: 14px;">Indented first line wraps and second line starts at the left edge</div>
  <div data-layout-id="after-text" style="box-sizing: content-box; width: 300px; height: 30px; margin: 10px 0 0 0; padding: 0;"></div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Text In Constrained Blocks Test"}, nil
}
</script>
