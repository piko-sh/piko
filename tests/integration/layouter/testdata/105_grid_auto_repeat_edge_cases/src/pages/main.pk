<template>
  <div data-layout-id="tiny-container" style="box-sizing: content-box; display: grid; grid-template-columns: repeat(auto-fill, 200px); width: 100px; margin: 0; padding: 0;">
    <div data-layout-id="tc-item" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <div data-layout-id="exact-one" style="box-sizing: content-box; display: grid; grid-template-columns: repeat(auto-fill, 200px); width: 200px; margin: 0; padding: 0;">
    <div data-layout-id="eo-item-1" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="eo-item-2" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <!-- Large gap reduces available space for tracks -->
  <div data-layout-id="large-gap" style="box-sizing: content-box; display: grid; grid-template-columns: repeat(auto-fill, 100px); gap: 80px; width: 500px; margin: 0; padding: 0;">
    <div data-layout-id="lg-item-1" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="lg-item-2" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <!-- auto-fit with single item in large container: empty tracks collapse -->
  <div data-layout-id="fit-single" style="box-sizing: content-box; display: grid; grid-template-columns: repeat(auto-fit, 100px); width: 500px; margin: 0; padding: 0;">
    <div data-layout-id="fs-item" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <!-- auto-fill: container exactly fits 3 tracks with gaps: 100+20+100+20+100 = 340 -->
  <div data-layout-id="exact-fit-gap" style="box-sizing: content-box; display: grid; grid-template-columns: repeat(auto-fill, 100px); gap: 20px; width: 340px; margin: 0; padding: 0;">
    <div data-layout-id="efg-item-1" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="efg-item-2" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
    <div data-layout-id="efg-item-3" style="box-sizing: content-box; height: 50px; margin: 0; padding: 0;"></div>
  </div>

  <!-- auto-fill with many items causing multiple rows -->
  <div data-layout-id="multi-row" style="box-sizing: content-box; display: grid; grid-template-columns: repeat(auto-fill, 150px); width: 500px; margin: 0; padding: 0;">
    <div data-layout-id="mr-item-1" style="box-sizing: content-box; height: 40px; margin: 0; padding: 0;"></div>
    <div data-layout-id="mr-item-2" style="box-sizing: content-box; height: 40px; margin: 0; padding: 0;"></div>
    <div data-layout-id="mr-item-3" style="box-sizing: content-box; height: 40px; margin: 0; padding: 0;"></div>
    <div data-layout-id="mr-item-4" style="box-sizing: content-box; height: 40px; margin: 0; padding: 0;"></div>
    <div data-layout-id="mr-item-5" style="box-sizing: content-box; height: 40px; margin: 0; padding: 0;"></div>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Grid Auto Repeat Edge Cases Test"}, nil
}
</script>
