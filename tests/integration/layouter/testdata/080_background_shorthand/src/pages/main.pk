<template>
  <!-- Test 1: background shorthand with colour only -->
  <div data-layout-id="bg-colour" style="box-sizing: content-box; width: 200px; height: 50px; margin: 0; padding: 0; background: #eee;"></div>

  <!-- Test 2: background shorthand with none -->
  <div data-layout-id="bg-none" style="box-sizing: content-box; width: 200px; height: 50px; margin: 0; padding: 0; background: none;"></div>

  <!-- Test 3: background shorthand with transparent -->
  <div data-layout-id="bg-transparent" style="box-sizing: content-box; width: 200px; height: 50px; margin: 0; padding: 0; background: transparent;"></div>

  <!-- Test 4: background shorthand with named colour -->
  <div data-layout-id="bg-named-colour" style="box-sizing: content-box; width: 200px; height: 50px; margin: 0; padding: 0; background: lightblue;"></div>

  <!-- Test 5: background shorthand with no-repeat (layout-neutral) -->
  <div data-layout-id="bg-no-repeat" style="box-sizing: content-box; width: 200px; height: 50px; margin: 0; padding: 0; background: #ddd no-repeat;"></div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{}, piko.Metadata{Title: "Background Shorthand Test"}, nil
}
</script>
