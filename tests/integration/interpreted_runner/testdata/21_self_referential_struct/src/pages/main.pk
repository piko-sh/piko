<template>
  <div>
    <h1>{{ state.RootName }}</h1>
    <p>Child count: {{ state.ChildCount }}</p>
    <p>First child: {{ state.FirstChildName }}</p>
    <p>Nested child: {{ state.NestedChildName }}</p>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type TreeNode struct {
	Name     string
	Children []TreeNode
}

type Response struct {
	RootName        string
	ChildCount      int
	FirstChildName  string
	NestedChildName string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	leaf := TreeNode{Name: "leaf"}
	mid := TreeNode{Name: "mid", Children: []TreeNode{leaf}}
	root := TreeNode{Name: "root", Children: []TreeNode{mid}}

	return Response{
		RootName:        root.Name,
		ChildCount:      len(root.Children),
		FirstChildName:  root.Children[0].Name,
		NestedChildName: root.Children[0].Children[0].Name,
	}, piko.Metadata{}, nil
}
</script>
