<template>
  <page_layout is="page_layout" :username="state.Username">
    <div class="page-specific-content">
      <h2>Page Title</h2>
      <p>This is the content unique to the main page.</p>
    </div>
  </page_layout>
</template>

<script type="application/x-go">
  package main

  import (
    "piko.sh/piko"
    page_layout "testcase_21_deeply_nested_partials/partials/level1_layout.pk"
  )

  type Response struct {
    Username string
  }

  func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{Username: "Alice"}, piko.Metadata{}, nil
  }
</script>