	items = append(items, "item45")
	items = append(items, "item46")
	items = append(items, "item47")
	items = append(items, "item48")
	items = append(items, "item49")

	sum := v0 + v1 + v2 + v3 + v4 + v5 + v6 + v7 + v8 + v9 +
		v10 + v11 + v12 + v13 + v14 + v15 + v16 + v17 + v18 + v19 +
		v20 + v21 + v22 + v23 + v24 + v25 + v26 + v27 + v28 + v29

	return Response{
		Sum:   sum,
		Count: len(items),
		First: items[0],
		Last:  items[len(items)-1],
	}, piko.Metadata{}, nil
