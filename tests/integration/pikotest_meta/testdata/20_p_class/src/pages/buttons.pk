<script type="application/x-go">
package buttons

import "piko.sh/piko"

type Response struct {
	IsActive   bool
	IsDisabled bool
	IsPrimary  bool
	IsLarge    bool
	HasError   bool
	Status     string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	isActive := r.QueryParam("active") == "true"
	isDisabled := r.QueryParam("disabled") == "true"
	isPrimary := r.QueryParam("primary") == "true"
	isLarge := r.QueryParam("large") == "true"
	hasError := r.QueryParam("error") == "true"
	status := r.QueryParam("status")

	if status == "" {
		status = "default"
	}

	return Response{
		IsActive:   isActive,
		IsDisabled: isDisabled,
		IsPrimary:  isPrimary,
		IsLarge:    isLarge,
		HasError:   hasError,
		Status:     status,
	}, piko.Metadata{
		Title: "Button Styles",
	}, nil
}
</script>
<template>
	<div class="button-demo">
		<h1>Button Component</h1>
		<section class="buttons">
			<button class="btn" p-class:active="state.IsActive" p-class:disabled="state.IsDisabled">
				Basic Button
			</button>
			<button class="btn" p-class:primary="state.IsPrimary" p-class:large="state.IsLarge">
				Styled Button
			</button>
			<button class="btn" p-class:error="state.HasError" p-class:success="state.Status == 'success'" p-class:warning="state.Status == 'warning'">
				Status Button
			</button>
		</section>
		<section class="status-display">
			<span class="status-badge" p-class:active="state.IsActive" p-class:inactive="!state.IsActive">
				Status Indicator
			</span>
		</section>
	</div>
</template>
