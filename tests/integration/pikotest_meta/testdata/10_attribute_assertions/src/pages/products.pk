<script type="application/x-go">
package products

import "piko.sh/piko"

type Product struct {
	Name    string
	InStock bool
}

type Response struct {
	Products []Product
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Products: []Product{
			{Name: "Wireless Mouse", InStock: true},
			{Name: "USB Cable", InStock: true},
			{Name: "Desk Lamp", InStock: false},
		},
	}, piko.Metadata{
		Title: "Product Catalogue",
	}, nil
}
</script>
<template>
	<div class="product-catalogue" data-version="1.0" data-env="production" data-feature-flag="new-layout">
		<h1 id="page-title" class="title main-heading">Products</h1>
		<div class="product-grid" role="list" aria-label="Product listing">
			<article
				p-for="product in state.Products"
				class="product-card item"
				role="listitem"
				tabindex="0"
			>
				<h2 class="product-name heading-2">{{ product.Name }}</h2>
				<span p-if="product.InStock" class="stock-badge in-stock available" data-status="available">In Stock</span>
				<span p-if="!product.InStock" class="stock-badge out-of-stock unavailable" data-status="unavailable">Out of Stock</span>
			</article>
		</div>
		<footer class="catalogue-footer" data-copyright="2024" hidden>
			<p>End of catalogue</p>
		</footer>
	</div>
</template>
