<script type="application/x-go">
package categories

import "piko.sh/piko"

type Product struct {
	Name  string
	Price string
}

type Category struct {
	Name     string
	Products []Product
}

type Response struct {
	Categories []Category
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Categories: []Category{
			{
				Name: "Electronics",
				Products: []Product{
					{Name: "Laptop", Price: "$999"},
					{Name: "Phone", Price: "$599"},
				},
			},
			{
				Name: "Books",
				Products: []Product{
					{Name: "Go Programming", Price: "$39"},
					{Name: "Clean Code", Price: "$45"},
					{Name: "Design Patterns", Price: "$55"},
				},
			},
			{
				Name: "Clothing",
				Products: []Product{
					{Name: "T-Shirt", Price: "$25"},
				},
			},
		},
	}, piko.Metadata{
		Title: "Product Categories",
	}, nil
}
</script>
<template>
	<div class="catalogue">
		<h1>Product Catalogue</h1>
		<div class="categories">
			<section p-for="category in state.Categories" class="category">
				<h2 class="category-name">{{ category.Name }}</h2>
				<ul class="product-list">
					<li p-for="product in category.Products" class="product">
						<span class="product-name">{{ product.Name }}</span>
						<span class="product-price">{{ product.Price }}</span>
					</li>
				</ul>
			</section>
		</div>
	</div>
</template>
