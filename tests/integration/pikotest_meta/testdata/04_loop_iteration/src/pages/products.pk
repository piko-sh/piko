<script type="application/x-go">
package products

import "piko.sh/piko"

type Product struct {
	ID    string
	Name  string
	Price float64
	InStock bool
}

type Response struct {
	Products []Product
	Total    int
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	products := []Product{
		{ID: "p1", Name: "Widget", Price: 29.99, InStock: true},
		{ID: "p2", Name: "Gadget", Price: 49.99, InStock: true},
		{ID: "p3", Name: "Gizmo", Price: 19.99, InStock: false},
	}

	return Response{
		Products: products,
		Total:    len(products),
	}, piko.Metadata{
		Title: "Product Catalogue",
	}, nil
}
</script>
<template>
	<div class="catalogue">
		<h1>Products</h1>
		<p class="total">Total: {{ state.Total }} products</p>

		<ul class="product-list">
			<li p-for="product in state.Products" class="product-item" data-id="{{ product.ID }}">
				<span class="product-name">{{ product.Name }}</span>
				<span class="product-price">${{ product.Price }}</span>
				<span p-if="product.InStock" class="in-stock">In Stock</span>
				<span p-if="!product.InStock" class="out-of-stock">Out of Stock</span>
			</li>
		</ul>
	</div>
</template>
