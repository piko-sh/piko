<script type="application/x-go">
package search

import "piko.sh/piko"

type Response struct {
	Query      string
	Page       string
	Sort       string
	HasQuery   bool
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	query := r.QueryParam("q")
	page := r.QueryParam("page")
	sort := r.QueryParam("sort")

	if page == "" {
		page = "1"
	}
	if sort == "" {
		sort = "relevance"
	}

	return Response{
		Query:    query,
		Page:     page,
		Sort:     sort,
		HasQuery: query != "",
	}, piko.Metadata{
		Title: "Search Results",
	}, nil
}
</script>
<template>
	<div class="search-page">
		<h1>Search Results</h1>

		<div p-if="state.HasQuery" class="results-info">
			<span class="query-text">Showing results for: {{ state.Query }}</span>
			<span class="page-info">Page {{ state.Page }}</span>
			<span class="sort-info">Sorted by: {{ state.Sort }}</span>
		</div>

		<div p-if="!state.HasQuery" class="no-query">
			<p>Please enter a search query</p>
		</div>
	</div>
</template>
