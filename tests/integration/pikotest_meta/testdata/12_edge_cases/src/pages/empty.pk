<script type="application/x-go">
package empty

import "piko.sh/piko"

type Response struct {
	Items      []string
	ShowBanner bool
	Message    string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Items:      []string{},
		ShowBanner: false,
		Message:    "",
	}, piko.Metadata{
		Title:       "Edge Cases Test",
		Description: "",
	}, nil
}
</script>
<template>
	<div class="page" id="edge-case-page">
		<header class="page-header">
			<h1>Edge Cases</h1>
		</header>
		<main class="page-content">
			<section class="banner-section">
				<div p-if="state.ShowBanner" class="banner">
					<p class="banner-text">Banner Content</p>
				</div>
			</section>
			<section class="list-section">
				<h2>Items</h2>
				<ul class="item-list">
					<li p-for="item in state.Items" class="item">{{ item }}</li>
				</ul>
				<p p-if="len(state.Items) == 0" class="empty-message">No items to display</p>
			</section>
			<section class="message-section">
				<p p-if="state.Message != ''" class="message">{{ state.Message }}</p>
				<p p-if="state.Message == ''" class="no-message">No message provided</p>
			</section>
			<footer class="page-footer">
				<span class="single-element">Only one of these</span>
			</footer>
		</main>
	</div>
</template>
