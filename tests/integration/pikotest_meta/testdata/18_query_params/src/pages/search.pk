<script type="application/x-go">
package search

import (
	"strconv"

	"piko.sh/piko"
)

type Response struct {
	Query      string
	Category   string
	Sort       string
	Page       int
	HasQuery   bool
	HasFilters bool
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	query := r.QueryParam("q")
	category := r.QueryParam("category")
	sort := r.QueryParam("sort")
	pageStr := r.QueryParam("page")

	if sort == "" {
		sort = "relevance"
	}

	page := 1
	if pageStr != "" {
		if p, err := strconv.Atoi(pageStr); err == nil && p > 0 {
			page = p
		}
	}

	hasFilters := category != "" || sort != "relevance"

	return Response{
		Query:      query,
		Category:   category,
		Sort:       sort,
		Page:       page,
		HasQuery:   query != "",
		HasFilters: hasFilters,
	}, piko.Metadata{
		Title: "Search Results",
	}, nil
}
</script>
<template>
	<div class="search-page">
		<h1>Search</h1>
		<section class="search-status">
			<div p-if="state.HasQuery" class="has-query">
				<p class="query-display">Searching for: <span class="query-value">{{ state.Query }}</span></p>
			</div>
			<div p-else class="no-query">
				<p class="no-query-message">Enter a search term</p>
			</div>
		</section>
		<section class="filters">
			<div p-if="state.HasFilters" class="active-filters">
				<p class="filters-label">Active Filters:</p>
				<p p-if="state.Category != ''" class="category-filter">Category: <span class="category-value">{{ state.Category }}</span></p>
				<p class="sort-filter">Sort: <span class="sort-value">{{ state.Sort }}</span></p>
			</div>
			<div p-else class="no-filters">
				<p class="no-filters-message">No filters applied</p>
			</div>
		</section>
		<section class="pagination">
			<p class="page-info">Page: <span class="page-value">{{ state.Page }}</span></p>
		</section>
	</div>
</template>
