<script type="application/x-go">
package notifications

import "piko.sh/piko"

type Response struct {
	ShowSuccess bool
	ShowWarning bool
	ShowError   bool
	ShowInfo    bool
	MessageCount int
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	showSuccess := r.QueryParam("success") == "true"
	showWarning := r.QueryParam("warning") == "true"
	showError := r.QueryParam("error") == "true"
	showInfo := r.QueryParam("info") == "true"

	messageCount := 0
	if showSuccess {
		messageCount++
	}
	if showWarning {
		messageCount++
	}
	if showError {
		messageCount++
	}
	if showInfo {
		messageCount++
	}

	return Response{
		ShowSuccess:  showSuccess,
		ShowWarning:  showWarning,
		ShowError:    showError,
		ShowInfo:     showInfo,
		MessageCount: messageCount,
	}, piko.Metadata{
		Title: "Notifications",
	}, nil
}
</script>
<template>
	<div class="notification-panel">
		<h1>Notifications</h1>
		<p class="message-count">Messages: <span class="count-value">{{ state.MessageCount }}</span></p>
		<div class="notifications">
			<div p-show="state.ShowSuccess" class="notification success">
				<span class="icon">✓</span>
				<span class="message">Operation completed successfully</span>
			</div>
			<div p-show="state.ShowWarning" class="notification warning">
				<span class="icon">⚠</span>
				<span class="message">Please review your input</span>
			</div>
			<div p-show="state.ShowError" class="notification error">
				<span class="icon">✗</span>
				<span class="message">An error occurred</span>
			</div>
			<div p-show="state.ShowInfo" class="notification info">
				<span class="icon">ℹ</span>
				<span class="message">Here is some information</span>
			</div>
		</div>
		<div class="no-messages" p-show="state.MessageCount == 0">
			<p>No notifications to display</p>
		</div>
	</div>
</template>
