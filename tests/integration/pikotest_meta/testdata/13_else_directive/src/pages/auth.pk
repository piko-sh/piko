<script type="application/x-go">
package auth

import "piko.sh/piko"

type Response struct {
	IsLoggedIn bool
	IsAdmin    bool
	Username   string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	isLoggedIn := false
	isAdmin := false
	username := ""

	authState := r.QueryParam("auth")
	if authState == "user" {
		isLoggedIn = true
		username = "JohnDoe"
	} else if authState == "admin" {
		isLoggedIn = true
		isAdmin = true
		username = "AdminUser"
	}

	return Response{
		IsLoggedIn: isLoggedIn,
		IsAdmin:    isAdmin,
		Username:   username,
	}, piko.Metadata{
		Title: "Authentication State",
	}, nil
}
</script>
<template>
	<div class="auth-container">
		<header class="auth-header">
			<h1>Authentication Demo</h1>
		</header>
		<section class="user-status">
			<div p-if="state.IsLoggedIn" class="logged-in">
				<p class="welcome-message">Welcome, {{ state.Username }}!</p>
				<div p-if="state.IsAdmin" class="admin-badge">
					<span class="badge admin">Administrator</span>
				</div>
				<div p-else class="user-badge">
					<span class="badge user">Regular User</span>
				</div>
			</div>
			<div p-else class="logged-out">
				<p class="login-prompt">Please log in to continue</p>
				<button class="login-btn">Sign In</button>
			</div>
		</section>
		<section class="permissions">
			<h2>Access Level</h2>
			<p p-if="state.IsAdmin" class="access-admin">Full administrative access</p>
			<p p-else class="access-default">Standard access only</p>
		</section>
	</div>
</template>
