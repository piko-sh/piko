<script type="application/x-go">
package leaderboard

import "piko.sh/piko"

type Player struct {
	Rank   int
	Name   string
	Score  int
	Badge  string
}

type Response struct {
	Players []Player
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	players := []Player{
		{Rank: 1, Name: "Alice", Score: 1500, Badge: "gold"},
		{Rank: 2, Name: "Bob", Score: 1350, Badge: "silver"},
		{Rank: 3, Name: "Charlie", Score: 1200, Badge: "bronze"},
		{Rank: 4, Name: "Diana", Score: 1100, Badge: ""},
		{Rank: 5, Name: "Eve", Score: 1000, Badge: ""},
	}

	return Response{
		Players: players,
	}, piko.Metadata{
		Title: "Leaderboard",
	}, nil
}
</script>
<template>
	<div class="leaderboard">
		<h1>Game Leaderboard</h1>
		<table class="rankings">
			<thead>
				<tr class="header-row">
					<th class="col-rank">Rank</th>
					<th class="col-name">Player</th>
					<th class="col-score">Score</th>
					<th class="col-badge">Badge</th>
				</tr>
			</thead>
			<tbody>
				<tr p-for="player in state.Players" class="player-row" data-rank="{{ player.Rank }}">
					<td class="rank">{{ player.Rank }}</td>
					<td class="name">{{ player.Name }}</td>
					<td class="score">{{ player.Score }}</td>
					<td class="badge">
						<span p-if="player.Badge == 'gold'" class="medal gold">🥇</span>
						<span p-else-if="player.Badge == 'silver'" class="medal silver">🥈</span>
						<span p-else-if="player.Badge == 'bronze'" class="medal bronze">🥉</span>
						<span p-else class="no-medal">-</span>
					</td>
				</tr>
			</tbody>
		</table>
	</div>
</template>
