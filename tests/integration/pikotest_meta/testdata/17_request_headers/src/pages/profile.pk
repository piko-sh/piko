<script type="application/x-go">
package profile

import "piko.sh/piko"

type Response struct {
	UserID    string
	Username  string
	Section   string
	HasUserID bool
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	userID := r.PathParam("id")
	username := r.PathParam("username")
	section := r.PathParam("section")

	if section == "" {
		section = "overview"
	}

	return Response{
		UserID:    userID,
		Username:  username,
		Section:   section,
		HasUserID: userID != "",
	}, piko.Metadata{
		Title: "User Profile",
	}, nil
}
</script>
<template>
	<div class="profile-page">
		<h1>User Profile</h1>
		<section class="user-info">
			<div p-if="state.HasUserID" class="user-details">
				<p class="user-id">User ID: <span class="id-value">{{ state.UserID }}</span></p>
				<p p-if="state.Username != ''" class="username">Username: <span class="username-value">{{ state.Username }}</span></p>
			</div>
			<div p-else class="no-user">
				<p class="no-user-message">No user specified</p>
			</div>
		</section>
		<section class="section-info">
			<p class="current-section">Current Section: <span class="section-value">{{ state.Section }}</span></p>
			<nav class="section-nav">
				<span p-if="state.Section == 'overview'" class="nav-item active">Overview</span>
				<span p-else class="nav-item">Overview</span>
				<span p-if="state.Section == 'posts'" class="nav-item active">Posts</span>
				<span p-else class="nav-item">Posts</span>
				<span p-if="state.Section == 'settings'" class="nav-item active">Settings</span>
				<span p-else class="nav-item">Settings</span>
			</nav>
		</section>
	</div>
</template>
