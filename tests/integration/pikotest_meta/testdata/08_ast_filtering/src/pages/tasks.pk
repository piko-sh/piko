<script type="application/x-go">
package tasks

import "piko.sh/piko"

type Task struct {
	ID       string
	Title    string
	Status   string
	Priority string
}

type Response struct {
	Tasks []Task
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Tasks: []Task{
			{ID: "1", Title: "Fix login bug", Status: "done", Priority: "high"},
			{ID: "2", Title: "Add dark mode", Status: "in-progress", Priority: "medium"},
			{ID: "3", Title: "Write tests", Status: "pending", Priority: "high"},
			{ID: "4", Title: "Update docs", Status: "pending", Priority: "low"},
			{ID: "5", Title: "Review PR", Status: "in-progress", Priority: "high"},
		},
	}, piko.Metadata{
		Title: "Task List",
	}, nil
}
</script>
<template>
	<div class="task-list">
		<h1>Tasks</h1>
		<ul>
			<li p-for="task in state.Tasks" class="task-item" data-status="{{ task.Status }}" data-priority="{{ task.Priority }}">
				<span class="task-title">{{ task.Title }}</span>
				<span class="task-status status-{{ task.Status }}">{{ task.Status }}</span>
				<span class="task-priority priority-{{ task.Priority }}">{{ task.Priority }}</span>
			</li>
		</ul>
	</div>
</template>
