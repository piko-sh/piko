<script type="application/x-go">
package profile

import "piko.sh/piko"

type Response struct {
	Username    string
	Email       string
	MemberSince int
	PostCount   int
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Username:    "johndoe",
		Email:       "john@example.com",
		MemberSince: 2020,
		PostCount:   42,
	}, piko.Metadata{
		Title:       "User Profile",
		Description: "View user profile details",
	}, nil
}
</script>
<template>
	<article class="profile-card">
		<header>
			<h1 class="username">{{ state.Username }}</h1>
			<span class="email">{{ state.Email }}</span>
		</header>
		<div class="stats">
			<div class="stat">
				<span class="stat-value">{{ state.MemberSince }}</span>
				<span class="stat-label">Member Since</span>
			</div>
			<div class="stat">
				<span class="stat-value">{{ state.PostCount }}</span>
				<span class="stat-label">Posts</span>
			</div>
		</div>
	</article>
</template>
