<script type="application/x-go">
package alerts

import "piko.sh/piko"

type Response struct {
	HasErrors   bool
	HasWarnings bool
	ErrorCount  int
	WarningCount int
	ErrorMessage string
	WarningMessage string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		HasErrors:      true,
		HasWarnings:    true,
		ErrorCount:     3,
		WarningCount:   2,
		ErrorMessage:   "Critical system error",
		WarningMessage: "Disk space running low",
	}, piko.Metadata{
		Title: "System Alerts",
	}, nil
}
</script>
<template>
	<div class="alert-panel">
		<h1>System Status</h1>

		<div p-if="state.HasErrors" class="alert alert-error">
			<span class="icon">!</span>
			<span class="count">{{ state.ErrorCount }}</span>
			<span class="message">{{ state.ErrorMessage }}</span>
		</div>

		<div p-if="state.HasWarnings" class="alert alert-warning">
			<span class="icon">⚠</span>
			<span class="count">{{ state.WarningCount }}</span>
			<span class="message">{{ state.WarningMessage }}</span>
		</div>

		<div p-if="!state.HasErrors && !state.HasWarnings" class="alert alert-success">
			<span class="message">All systems operational</span>
		</div>
	</div>
</template>
