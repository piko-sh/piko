<script type="application/x-go">
package article

import "piko.sh/piko"

type Response struct {
	Title   string
	Author  string
	Content string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Title:   "Understanding Go Interfaces",
		Author:  "Jane Doe",
		Content: "Go interfaces are a powerful feature...",
	}, piko.Metadata{
		Title:        "Understanding Go Interfaces | Tech Blog",
		Description:  "Learn about Go interfaces and how to use them effectively in your code.",
		Language:     "en",
		CanonicalURL: "https://example.com/articles/go-interfaces",
		Status:       200,
	}, nil
}
</script>
<template>
	<article class="blog-post">
		<header>
			<h1>{{ state.Title }}</h1>
			<p class="author">By {{ state.Author }}</p>
		</header>
		<div class="content">
			<p>{{ state.Content }}</p>
		</div>
	</article>
</template>
