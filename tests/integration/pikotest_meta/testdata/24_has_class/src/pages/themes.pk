package themes

import "piko.sh/piko"

type Response struct{}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{}, piko.Metadata{
		Title: "Theme Demo",
	}, nil
}
</script>
<template>
	<div class="theme-demo">
		<h1>Theme Examples</h1>
		<section class="buttons-section">
			<button class="btn">Default</button>
			<button class="btn primary">Primary</button>
			<button class="btn secondary">Secondary</button>
			<button class="btn primary large">Large Primary</button>
			<button class="btn small outline">Small Outline</button>
			<button class="btn danger disabled">Disabled Danger</button>
		</section>
		<section class="cards-section">
			<div class="card">Basic Card</div>
			<div class="card featured">Featured Card</div>
			<div class="card shadow rounded">Shadow Rounded Card</div>
			<div class="card compact bordered highlighted">Compact Bordered Highlighted</div>
		</section>
		<section class="alerts-section">
			<div class="alert success">Success Alert</div>
			<div class="alert warning">Warning Alert</div>
			<div class="alert error critical">Critical Error</div>
			<div class="alert info dismissible">Dismissible Info</div>
