<template>
  <div id="content">
    <h1>{{ state.Title }}</h1>
    <p>Count: {{ state.Count }}</p>
    <p p-if="state.ShowExtra">Extra content is visible</p>
    <p p-else>Extra content is hidden</p>
    <ul>
      <li p-for="(i, item) in state.Items" p-key="i">{{ item }}</li>
    </ul>
    <span :data-value="state.Count">Static attribute test</span>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct {
	Title     string
	Count     int
	Items     []string
	ShowExtra bool
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Title:     "Cache Rendering Test",
		Count:     42,
		Items:     []string{"Alpha", "Beta", "Gamma"},
		ShowExtra: true,
	}, piko.Metadata{Title: "Cache Test"}, nil
}

func CachePolicy() piko.CachePolicy {
	return piko.CachePolicy{}
}
</script>
