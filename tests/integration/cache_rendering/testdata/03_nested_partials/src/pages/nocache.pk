<template>
  <div id="content">
    <h1>{{ state.Title }}</h1>
    <p>{{ state.Description }}</p>
    <card :heading="state.CardTitle" :body="state.CardBody" />
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct {
	Title       string
	Description string
	CardTitle   string
	CardBody    string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Title:       "Nested Partials Test",
		Description: "This page tests partial rendering across cache modes.",
		CardTitle:   "Test Card",
		CardBody:    "This is the card body content.",
	}, piko.Metadata{Title: "Partial Test"}, nil
}

func CachePolicy() piko.CachePolicy {
	return piko.CachePolicy{}
}
</script>
