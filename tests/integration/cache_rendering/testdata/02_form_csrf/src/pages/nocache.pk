<template>
  <div id="content">
    <h1>{{ state.Title }}</h1>
    <form id="test-form" method="post">
      <label for="name">{{ state.NameLabel }}</label>
      <input type="text" id="name" name="name" />
      <label for="email">{{ state.EmailLabel }}</label>
      <input type="email" id="email" name="email" />
      <button type="submit">{{ state.SubmitText }}</button>
    </form>
    <form id="second-form" method="post">
      <select name="option">
        <option value="a">Alpha</option>
        <option value="b">Beta</option>
      </select>
      <button type="submit">Choose</button>
    </form>
  </div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Response struct {
	Title      string
	NameLabel  string
	EmailLabel string
	SubmitText string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	return Response{
		Title:      "Form CSRF Test",
		NameLabel:  "Full Name",
		EmailLabel: "Email Address",
		SubmitText: "Send",
	}, piko.Metadata{Title: "Form Test"}, nil
}

func CachePolicy() piko.CachePolicy {
	return piko.CachePolicy{}
}
</script>
