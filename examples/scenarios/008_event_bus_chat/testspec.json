{
  "description": "Verifies event bus communication between a PKC component and a partial",
  "requestURL": "/",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
      "action": "checkText",
      "selector": "h1",
      "expected": "Event Bus Chat"
    },
    {
      "action": "waitForSelector",
      "selector": "pp-chat-input"
    },
    {
      "action": "waitForSelector",
      "selector": ".message-log"
    },
    {
      "action": "checkText",
      "selector": ".message-log .empty-state",
      "expected": "No messages yet - try sending one!"
    },
    {
      "action": "checkText",
      "selector": "[p-ref='total_count']",
      "expected": "0"
    },
    {
      "action": "waitForSelector",
      "selector": "pp-chat-input >>> #message-input"
    },
    {
      "action": "fill",
      "selector": "pp-chat-input >>> #message-input",
      "value": "Hello from Piko!"
    },
    {
      "action": "click",
      "selector": "pp-chat-input >>> #send-btn"
    },
    {
      "action": "wait",
      "value": "300"
    },
    {
      "action": "checkText",
      "selector": "[p-ref='total_count']",
      "expected": "1"
    },
    {
      "action": "checkText",
      "selector": ".message-log .message",
      "expected": "User: Hello from Piko!"
    },
    {
      "action": "fill",
      "selector": "pp-chat-input >>> #message-input",
      "value": "Second message"
    },
    {
      "action": "click",
      "selector": "pp-chat-input >>> #send-btn"
    },
    {
      "action": "wait",
      "value": "300"
    },
    {
      "action": "checkText",
      "selector": "[p-ref='total_count']",
      "expected": "2"
    }
  ]
}
