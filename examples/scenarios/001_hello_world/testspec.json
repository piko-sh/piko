{
  "description": "Verifies a minimal static PK page renders with server-side data and scoped styles",
  "requestURL": "/",
  "expectedStatus": 200,
  "browserSteps": [
    {
      "action": "waitForSelector",
      "selector": "#app"
    },
    {
