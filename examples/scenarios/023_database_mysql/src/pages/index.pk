  }

  .site-header {
    text-align: center;
    padding: 2.5rem 0 2rem;
    border-bottom: 2px solid #111;
    margin-bottom: 2.5rem;
  }

  .site-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
