    <div class="app-shell">
        <header class="top-bar">
            <piko:a href="/" class="brand">Piko Shop</piko:a>
            <nav class="nav-links">
                <piko:a href="/" class="nav-link" p-class="{ 'active': props.CurrentPage == 'home' }">Products</piko:a>
