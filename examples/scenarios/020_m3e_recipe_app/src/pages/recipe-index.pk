                    <m2-data-table-cell header numeric>Servings</m2-data-table-cell>
                    <m2-data-table-cell header numeric sortable column="calories" sort-direction="asc">Calories</m2-data-table-cell>
                    <m2-data-table-cell header numeric sortable column="protein">Protein</m2-data-table-cell>
                    <m2-data-table-cell header numeric sortable column="fat">Fat</m2-data-table-cell>
                    <m2-data-table-cell header numeric sortable column="carbs">Carbs</m2-data-table-cell>
