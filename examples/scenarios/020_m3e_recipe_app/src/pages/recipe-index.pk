<template>
    <div id="app">
        <piko:partial is="layout"
            server.title="Recipe Index"
            server.current-page="recipe-index">

            <h1 class="page-title">Recipe Index</h1>
            <p class="text-muted mb-lg">A whey to compare all our recipes at a glance &mdash; sort, select, and find the perfect dish for tonight.</p>

            <m2-data-table selectable aria-label="Complete recipe index">
                <m2-data-table-header slot="header" selectable>
                    <m2-data-table-cell header sortable column="recipe">Recipe</m2-data-table-cell>
                    <m2-data-table-cell header>Cheese</m2-data-table-cell>
                    <m2-data-table-cell header>Difficulty</m2-data-table-cell>
