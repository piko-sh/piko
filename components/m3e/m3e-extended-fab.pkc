<template name="m3e-extended-fab">
    <button class="extended-fab"
            p-class="{
                'surface': state.colour == 'surface',
                'primary': state.colour == 'primary',
                'secondary': state.colour == 'secondary',
                'tertiary': state.colour == 'tertiary'
            }"
            type="button">
        <span class="state-layer"></span>
        <span class="icon-slot"><slot name="icon"></slot></span>
        <span class="label"><slot></slot></span>
    </button>
</template>

<script lang="ts">
    const state = {
        colour: 'primary' as string,
    };
</script>

<style>
    :host {
        display: inline-flex;
        flex-shrink: 0;
        --_primary: var(--m3e-primary, #6750a4);
        --_on-primary: var(--m3e-on-primary, #ffffff);
        --_primary-container: var(--m3e-primary-container, #eaddff);
        --_on-primary-container: var(--m3e-on-primary-container, #21005d);
        --_secondary-container: var(--m3e-secondary-container, #e8def8);
        --_on-secondary-container: var(--m3e-on-secondary-container, #1d192b);
        --_tertiary-container: var(--m3e-tertiary-container, #ffd8e4);
        --_on-tertiary-container: var(--m3e-on-tertiary-container, #31111d);
        --_surface-container-high: var(--m3e-surface-container-high, #ece6f0);
        --_duration-short: var(--m3e-duration-short, 200ms);
        --_easing-standard: var(--m3e-easing-standard, cubic-bezier(0.2, 0, 0, 1));
        --_shape-lg: var(--m3e-shape-lg, 16px);
        font-family: system-ui, -apple-system, sans-serif;
    }

    .extended-fab {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        height: 56px;
        padding: 0 16px;
        border: none;
        border-radius: var(--_shape-lg);
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.1px;
        cursor: pointer;
        outline: none;
        overflow: hidden;
        -webkit-tap-highlight-color: transparent;
        box-shadow: 0px 4px 8px 3px rgba(0,0,0,0.15), 0px 1px 3px 0px rgba(0,0,0,0.30);
        transition: box-shadow var(--_duration-short) var(--_easing-standard);

        &:hover {
            box-shadow: 0px 6px 10px 4px rgba(0,0,0,0.15), 0px 2px 3px 0px rgba(0,0,0,0.30);
        }

        &:focus-visible .state-layer {
            opacity: 0.12;
        }

        &.surface {
            background: var(--_surface-container-high);
            color: var(--_primary);
        }

        &.primary {
            background: var(--_primary-container);
            color: var(--_on-primary-container);
        }

        &.secondary {
            background: var(--_secondary-container);
            color: var(--_on-secondary-container);
        }

        &.tertiary {
            background: var(--_tertiary-container);
            color: var(--_on-tertiary-container);
        }

        &:hover .state-layer {
            opacity: 0.08;
        }

        &:active .state-layer {
            opacity: 0.12;
        }
    }

    .icon-slot {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        z-index: 1;
    }

    .label {
        z-index: 1;
        white-space: nowrap;
    }

    .state-layer {
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: currentColor;
        opacity: 0;
        transition: opacity var(--_duration-short);
        pointer-events: none;
    }
</style>
