<template name="m3e-list">
    <div class="list"
         p-class="{ 'dividers': state.dividers }"
         role="list">
        <slot></slot>
    </div>
</template>

<script lang="ts">
    const state = {
        dividers: false as boolean,
    };

    pkc.onConnected(() => {
        pkc.addEventListener('keydown', handleKeydown);
    });

    pkc.onDisconnected(() => {
        pkc.removeEventListener('keydown', handleKeydown);
    });

    const handleKeydown = function(event) {
        const isDown = event.key === 'ArrowDown';
        const isUp = event.key === 'ArrowUp';
        const isHome = event.key === 'Home';
        const isEnd = event.key === 'End';

        if (!isDown && !isUp && !isHome && !isEnd) return;

        event.preventDefault();
        const items = Array.from(pkc.querySelectorAll('m3e-list-item[interactive]'));
        if (items.length < 2) return;

        const focused = document.activeElement;
        let index = items.indexOf(focused);
        if (index < 0) index = 0;

        let nextIndex;
        if (isHome) {
            nextIndex = 0;
        } else if (isEnd) {
            nextIndex = items.length - 1;
        } else if (isDown) {
            nextIndex = index < items.length - 1 ? index + 1 : 0;
        } else {
            nextIndex = index > 0 ? index - 1 : items.length - 1;
        }

        items[nextIndex].focus();
    };
</script>

<style>
    :host {
        display: block;
        --_surface: var(--m3e-surface, #fffbfe);
        font-family: system-ui, -apple-system, sans-serif;
    }

    .list {
        display: flex;
        flex-direction: column;
        background: var(--_surface);
        padding: 8px 0;

        &.dividers ::slotted(*:not(:last-child)) {
            border-bottom: 1px solid var(--m3e-outline-variant, #cac4d0);
        }
    }
</style>
