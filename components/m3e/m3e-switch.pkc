<template name="m3e-switch">
    <div class="switch"
         p-class="{
             'checked': state.checked,
             'disabled': state.disabled,
             'with-icons': state.icons
         }"
         role="switch"
         :aria-checked="state.checked ? 'true' : 'false'"
         :aria-disabled="state.disabled ? 'true' : 'false'"
         :tabindex="state.disabled ? '-1' : '0'"
         p-on:click="toggle"
         p-on:keydown="handleKeydown">
        <div class="track">
            <div class="track-outline"></div>
            <div class="track-background"></div>
            <div class="thumb-container">
                <div class="thumb">
                    <div class="icon" p-if="state.icons && state.checked">
                        <piko:svg src="piko.sh/piko/lib/icons/check.svg" fill="currentColor" width="16" height="16"></piko:svg>
                    </div>
                    <div class="icon" p-if="state.icons && !state.checked">
                        <piko:svg src="piko.sh/piko/lib/icons/close.svg" fill="currentColor" width="16" height="16"></piko:svg>
                    </div>
                </div>
                <div class="state-layer"></div>
            </div>
        </div>
        <input p-if="state.name"
               type="hidden"
               :name="state.name"
               :value="state.checked ? state.value : ''" />
    </div>
</template>

<script lang="ts">
    const state = {
        checked: false as boolean,
        disabled: false as boolean,
        icons: false as boolean,
        name: '' as string,
        value: 'on' as string,
        required: false as boolean,
    };

    function toggle() {
        if (state.disabled) return;

        state.checked = !state.checked;

        pkc.dispatchEvent(new CustomEvent('change', {
            detail: { checked: state.checked },
            bubbles: true,
            composed: true,
        }));
    }

    function handleKeydown(event) {
        if (event.key === ' ' || event.key === 'Enter') {
            event.preventDefault();
            toggle();
        }
    }
</script>

<style>
    :host {
        display: inline-flex;
        --_primary: var(--m3e-primary, #6750a4);
        --_on-primary: var(--m3e-on-primary, #ffffff);
        --_on-surface: var(--m3e-on-surface, #1c1b1f);
        --_on-surface-variant: var(--m3e-on-surface-variant, #49454f);
        --_outline: var(--m3e-outline, #79747e);
        --_surface-container-highest: var(--m3e-surface-container-highest, #e6e0e9);
        --_primary-container: var(--m3e-primary-container, #eaddff);
        --_on-primary-container: var(--m3e-on-primary-container, #21005d);
        --_duration-short: var(--m3e-duration-short, 200ms);
        --_easing-emphasized: var(--m3e-easing-emphasized, cubic-bezier(0.05, 0.7, 0.1, 1));
    }

    .switch {
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        outline: none;

        &:focus-visible .state-layer {
            opacity: 0.12;
        }

        &.disabled {
            cursor: default;
            opacity: 0.38;
            pointer-events: none;
        }

        &:hover .state-layer {
            opacity: 0.08;
        }

        &:active .thumb {
            width: 28px;
            height: 28px;
        }
    }

    .track {
        position: relative;
        width: 52px;
        height: 32px;
        border-radius: var(--m3e-shape-full, 9999px);
    }

    .track-outline {
        position: absolute;
        inset: 0;
        border: 2px solid var(--_outline);
        border-radius: inherit;
        transition: border-color var(--_duration-short) var(--_easing-emphasized),
                    opacity var(--_duration-short) var(--_easing-emphasized);
    }

    .track-background {
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: var(--_surface-container-highest);
        transition: background var(--_duration-short) var(--_easing-emphasized);
    }

    .thumb-container {
        position: absolute;
        top: 50%;
        left: 6px;
        transform: translateY(-50%);
        transition: left var(--_duration-short) var(--_easing-emphasized);
    }

    .thumb {
        position: relative;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--_outline);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: width var(--_duration-short) var(--_easing-emphasized),
                    height var(--_duration-short) var(--_easing-emphasized),
                    background var(--_duration-short) var(--_easing-emphasized);
        z-index: 1;
    }

    .icon {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--_surface-container-highest);
    }

    .state-layer {
        position: absolute;
        inset: -12px;
        border-radius: 50%;
        background: var(--_on-surface);
        opacity: 0;
        transition: opacity var(--_duration-short);
        pointer-events: none;
    }

    .checked {
        .track-outline {
            opacity: 0;
        }

        .track-background {
            background: var(--_primary);
        }

        .thumb-container {
            left: 26px;
        }

        .thumb {
            width: 24px;
            height: 24px;
            background: var(--_on-primary);
        }

        .icon {
            color: var(--_on-primary-container);
        }

        &:hover .state-layer {
            background: var(--_primary);
        }
    }

    .with-icons .thumb {
        width: 24px;
        height: 24px;
    }

    .with-icons:not(.checked) .thumb {
        background: var(--_on-surface-variant);
    }
</style>
