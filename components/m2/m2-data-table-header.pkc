<template name="m2-data-table-header">
    <div class="header-row"
         role="row"
         p-class="{ 'selectable': state.selectable }">
        <div class="checkbox-cell" p-if="state.selectable"
             role="columnheader"
             p-on:click="toggleSelectAll"
             p-on:keydown="handleCheckboxKeydown"
             :tabindex="'0'"
             :aria-checked="state.some_selected ? 'mixed' : (state.all_selected ? 'true' : 'false')"
             aria-label="Select all rows">
            <div class="checkbox-container"
                 p-class="{
                     'checked': state.all_selected && !state.some_selected,
                     'indeterminate': state.some_selected
                 }">
                <div class="cb-outline"></div>
                <div class="cb-background"></div>
                <div class="cb-icon-container">
                    <span class="cb-check" p-if="state.all_selected && !state.some_selected">
                        <piko:svg src="piko.sh/piko/lib/icons/check.svg" fill="currentColor" width="18" height="18"></piko:svg>
                    </span>
                    <span class="cb-indeterminate" p-if="state.some_selected">
                        <piko:svg src="piko.sh/piko/lib/icons/indeterminate.svg" fill="currentColor" width="18" height="18"></piko:svg>
                    </span>
                </div>
            </div>
            <div class="cb-state-layer"></div>
        </div>
        <slot></slot>
    </div>
</template>

<script lang="ts">
    const state = {
        selectable: false as boolean,
        all_selected: false as boolean,
        some_selected: false as boolean,
    };

    function toggleSelectAll(event) {
        event.stopPropagation();

        const newSelected = !state.all_selected;

        pkc.dispatchEvent(new CustomEvent('select-all-toggle', {
            detail: { selected: newSelected },
            bubbles: true,
            composed: true,
        }));
    }

    function handleCheckboxKeydown(event) {
        if (event.key === ' ' || event.key === 'Enter') {
            event.preventDefault();
            toggleSelectAll(event);
        }
    }
</script>

<style>
    :host {
        display: block;
        --_on-surface: var(--m3e-on-surface, #1c1b1f);
        --_on-surface-variant: var(--m3e-on-surface-variant, #49454f);
        --_outline-variant: var(--m3e-outline-variant, #cac4d0);
        --_primary: var(--m3e-primary, #6750a4);
        --_on-primary: var(--m3e-on-primary, #ffffff);
        --_duration-short: var(--m3e-duration-short, 200ms);
        --_easing-standard: var(--m3e-easing-standard, cubic-bezier(0.2, 0, 0, 1));
        --_shape-xs: var(--m3e-shape-xs, 4px);
        font-family: system-ui, -apple-system, sans-serif;
    }

    .header-row {
        display: flex;
        align-items: center;
        min-height: 56px;
        border-bottom: 1px solid var(--_outline-variant);
    }

    .checkbox-cell {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 52px;
        height: 56px;
        flex-shrink: 0;
        cursor: pointer;
        position: relative;
        outline: none;
        -webkit-tap-highlight-color: transparent;

        &:hover .cb-state-layer {
            opacity: 0.08;
        }

        &:focus-visible .cb-state-layer {
            opacity: 0.12;
        }
    }

    .checkbox-container {
        position: relative;
        width: 18px;
        height: 18px;
        border-radius: var(--_shape-xs);
    }

    .cb-outline {
        position: absolute;
        inset: 0;
        border: 2px solid var(--_on-surface-variant);
        border-radius: inherit;
        transition: border-color var(--_duration-short) var(--_easing-standard),
                    opacity var(--_duration-short) var(--_easing-standard);
    }

    .cb-background {
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: var(--_primary);
        opacity: 0;
        transition: opacity var(--_duration-short) var(--_easing-standard);
    }

    .checked,
    .indeterminate {
        .cb-outline {
            border-color: var(--_primary);
            opacity: 0;
        }

        .cb-background {
            opacity: 1;
        }

        .cb-icon-container {
            opacity: 1;
            transform: scale(1);
        }
    }

    .cb-icon-container {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--_on-primary);
        opacity: 0;
        transform: scale(0.6);
        transition: opacity var(--_duration-short) var(--_easing-standard),
                    transform var(--_duration-short) var(--_easing-standard);
    }

    .cb-check,
    .cb-indeterminate {
        display: contents;
    }

    .cb-state-layer {
        position: absolute;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--_on-surface);
        opacity: 0;
        transition: opacity var(--_duration-short) var(--_easing-standard);
        pointer-events: none;
    }
</style>
