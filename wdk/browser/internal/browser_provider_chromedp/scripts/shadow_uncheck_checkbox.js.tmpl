(() => {
    const host = document.querySelector({{jsStr .Host}});
    if (!host || !host.shadowRoot) return false;
    const el = host.shadowRoot.querySelector({{jsStr .Shadow}});
    if (!el) return false;
    if (el.type !== 'checkbox') return false;
    if (el.checked) {
        el.checked = false;
        el.dispatchEvent(new Event('change', { bubbles: true, composed: true }));
    }
    return true;
})()
