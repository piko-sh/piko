(() => {
    const host = document.querySelector({{jsStr .Host}});
    if (!host || !host.shadowRoot) return false;
    const el = host.shadowRoot.querySelector({{jsStr .Shadow}});
    if (!el) return false;
    el.scrollIntoView({behavior: 'instant', block: 'center', inline: 'center'});
    return true;
})()
