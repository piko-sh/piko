(() => {
    const el = document.querySelector({{jsStr .Selector}});
    if (!el) return false;
    if (el.tagName === 'FORM') {
        el.submit();
        return true;
    }
    const form = el.closest('form');
    if (form) {
        form.submit();
        return true;
    }
    return false;
})()
