    "SQL": "-- piko.name: TopLevelWithChildren\n-- piko.command: many\nWITH top_level AS (\n    SELECT id, name FROM categories WHERE parent_id IS NULL\n)\nSELECT c.id, c.name, t.name AS parent_name\nFROM categories c\nINNER JOIN top_level t ON c.parent_id = t.id;",
