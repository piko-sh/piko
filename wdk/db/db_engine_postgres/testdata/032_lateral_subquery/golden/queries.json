    "Filename": "latest_books.sql",
    "SQL": "-- piko.name: LatestBooks\n-- piko.command: many\nSELECT a.name, latest.title, latest.published\nFROM authors a\nLEFT JOIN LATERAL (\n    SELECT b.title, b.published\n    FROM books b\n    WHERE b.author_id = a.id\n    ORDER BY b.published DESC\n    LIMIT 1\n) latest ON TRUE;",
