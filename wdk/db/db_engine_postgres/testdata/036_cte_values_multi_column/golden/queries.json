    "SQL": "-- piko.name: ValuesJoin\n-- piko.command: many\nWITH filter(target_id, target_status) AS (VALUES (1, 'active'), (2, 'pending'))\nSELECT i.id, i.name, i.status\nFROM items i\nJOIN filter f ON f.target_id = i.id AND f.target_status = i.status;",
