  <template name="ppartial" value="&lt;template&gt;&#10;  &lt;div&gt;&#10;    $END$&#10;  &lt;/div&gt;&#10;&lt;/template&gt;&#10;&#10;&lt;script type=&quot;application/x-go&quot;&gt;&#10;package main&#10;&#10;import &quot;piko.sh/piko&quot;&#10;&#10;type Props struct {&#10;}&#10;&#10;type Response struct {&#10;}&#10;&#10;func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {&#10;  return Response{}, piko.Metadata{}, nil&#10;}&#10;&lt;/script&gt;&#10;&#10;&lt;style&gt;&#10;&lt;/style&gt;" description="Full Piko partial with Props" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="PIKO" value="true"/>
    </context>
  </template>
  <template name="ppage" value="&lt;template&gt;&#10;  &lt;div&gt;&#10;    $END$&#10;  &lt;/div&gt;&#10;&lt;/template&gt;&#10;&#10;&lt;script type=&quot;application/x-go&quot;&gt;&#10;package main&#10;&#10;import &quot;piko.sh/piko&quot;&#10;&#10;type Response struct {&#10;  Title string&#10;}&#10;&#10;func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {&#10;  return Response{&#10;    Title: &quot;$TITLE$&quot;,&#10;  }, piko.Metadata{}, nil&#10;}&#10;&lt;/script&gt;&#10;&#10;&lt;style&gt;&#10;&lt;/style&gt;&#10;&#10;&lt;i18n lang=&quot;json&quot;&gt;&#10;{&#10;  &quot;en&quot;: {&#10;  },&#10;  &quot;fr&quot;: {&#10;  }&#10;}&#10;&lt;/i18n&gt;" description="Full Piko page with NoProps and i18n" toReformat="false" toShortenFQNames="true">
    <variable name="TITLE" expression="" defaultValue="Page Title" alwaysStopAt="true"/>
    <context>
      <option name="PIKO" value="true"/>
    </context>
  </template>
  <template name="slot" value="&lt;piko:slot&gt;$END$&lt;/piko:slot&gt;" description="Piko slot element" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="PIKO" value="true"/>
