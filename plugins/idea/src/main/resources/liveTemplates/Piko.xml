      <option name="PIKO" value="true"/>
    </context>
  </template>
  <template name="pfor" value="p-for=&quot;$ITEM$ in $ITEMS$&quot;" description="List rendering directive" toReformat="false" toShortenFQNames="true">
    <variable name="ITEM" expression="" defaultValue="item" alwaysStopAt="true"/>
