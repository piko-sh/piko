<templateSet group="Piko">
  <template name="ptemplate" value="&lt;template&gt;&#10;  $END$&#10;&lt;/template&gt;" description="Template block" toReformat="false" toShortenFQNames="true">
    <context>
      <option name="PIKO" value="true"/>
    </context>
  </template>
  <template name="pscript" value="&lt;script type=&quot;application/x-go&quot;&gt;&#10;package main&#10;&#10;import &quot;piko.sh/piko&quot;&#10;&#10;type Props struct {&#10;}&#10;&#10;type Response struct {&#10;}&#10;&#10;func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {&#10;  return Response{}, piko.Metadata{}, nil&#10;}&#10;$END$&#10;&lt;/script&gt;" description="Go script block" toReformat="false" toShortenFQNames="true">
