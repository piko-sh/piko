    <variable name="EXPR" expression="" defaultValue="" alwaysStopAt="true"/>
    <context>
      <option name="PIKO" value="true"/>
    </context>
  </template>
  <template name="pon" value="@$EVENT$=&quot;$HANDLER$&quot;" description="Event handler shorthand" toReformat="false" toShortenFQNames="true">
