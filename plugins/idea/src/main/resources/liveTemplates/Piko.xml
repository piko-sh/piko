  </template>
  <template name="ul:for" value="&lt;ul&gt;&#10;  &lt;li p-for=&quot;$ITEM$ in $ITEMS$&quot; p-text=&quot;$ITEM$&quot;&gt;&lt;/li&gt;&#10;&lt;/ul&gt;" description="Unordered list with iteration" toReformat="false" toShortenFQNames="true">
