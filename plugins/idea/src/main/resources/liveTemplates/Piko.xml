  <template name="pi18n" value="&lt;i18n lang=&quot;json&quot;&gt;&#10;{&#10;  &quot;en&quot;: {&#10;    $END$&#10;  },&#10;  &quot;fr&quot;: {&#10;  }&#10;}&#10;&lt;/i18n&gt;" description="Internationalisation block" toReformat="false" toShortenFQNames="true">
