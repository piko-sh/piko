  <template name="table:for" value="&lt;table&gt;&#10;  &lt;thead&gt;&#10;    &lt;tr&gt;&#10;      &lt;th&gt;$HEADER$&lt;/th&gt;&#10;    &lt;/tr&gt;&#10;  &lt;/thead&gt;&#10;  &lt;tbody&gt;&#10;    &lt;tr p-for=&quot;$ROW$ in $ROWS$&quot;&gt;&#10;      &lt;td p-text=&quot;$ROW$.$FIELD$&quot;&gt;&lt;/td&gt;&#10;    &lt;/tr&gt;&#10;  &lt;/tbody&gt;&#10;&lt;/table&gt;" description="Table with row iteration" toReformat="false" toShortenFQNames="true">
