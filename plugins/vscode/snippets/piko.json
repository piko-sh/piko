{
  "Piko Page": {
    "prefix": "ppage",
    "body": [
      "<template>",
      "  <div>",
      "    $0",
      "  </div>",
      "</template>",
      "",
      "<script type=\"application/x-go\">",
      "package main",
      "",
      "import \"piko.sh/piko\"",
      "",
      "type Response struct {",
      "  Title string",
      "}",
      "",
      "func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {",
      "  return Response{",
      "    Title: \"${1:Page Title}\",",
      "  }, piko.Metadata{}, nil",
      "}",
      "</script>",
      "",
      "<style>",
      "</style>",
      "",
      "<i18n lang=\"json\">",
      "{",
      "  \"en\": {",
      "  }",
      "}",
      "</i18n>"
    ],
    "description": "Full Piko page with NoProps and i18n"
  },
