.git/**
.github/**

# Test files
test/**
**/*.test.ts
**/*.test.js

# Editor files
.DS_Store
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/**
temp/**

# esbuild files
esbuild.js
