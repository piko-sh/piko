{
  "name": "piko",
  "displayName": "Piko Language Support",
  "description": "Language support for Piko template files (.pk) with embedded Go, CSS, and JSON support",
  "version": "0.0.0",
  "publisher": "politepixels",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://piko.sh/piko"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "piko",
    "pk",
    "pkc",
    "template",
    "go",
    "lsp"
  ],
  "activationEvents": [
    "onLanguage:piko"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "piko",
        "aliases": [
          "Piko",
          "PK"
        ],
        "extensions": [
          ".pk",
          ".pkc"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/piko.svg",
          "dark": "./icons/piko.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "piko",
        "scopeName": "source.piko",
        "path": "./syntaxes/piko.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.go": "go",
          "meta.embedded.block.css": "css",
          "meta.embedded.block.json": "json",
          "meta.embedded.block.javascript": "javascript",
          "meta.embedded.block.typescript": "typescript"
        }
      }
    ],
    "breakpoints": [
      {
        "language": "piko"
      }
    ],
    "snippets": [
      {
        "language": "piko",
        "path": "./snippets/piko.json"
      }
    ],
    "commands": [
      {
        "command": "piko.newFile",
        "title": "Piko: New Piko File"
      },
      {
        "command": "piko.restartServer",
        "title": "Piko: Restart Language Server"
      },
      {
        "command": "piko.showOutput",
        "title": "Piko: Show Output"
      },
      {
        "command": "piko.openLogs",
        "title": "Piko: Open LSP Logs"
      },
      {
        "command": "piko.toggleLineComment",
        "title": "Piko: Toggle Line Comment"
      },
      {
        "command": "piko.toggleBlockComment",
        "title": "Piko: Toggle Block Comment"
      }
    ],
    "keybindings": [
      {
        "command": "piko.toggleLineComment",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "editorTextFocus && editorLangId == piko"
      },
      {
        "command": "piko.toggleBlockComment",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "editorTextFocus && editorLangId == piko"
      }
    ],
    "configurationDefaults": {
      "[piko]": {
        "editor.suggest.insertMode": "replace"
      },
      "emmet.includeLanguages": {
        "piko": "html"
      }
    },
    "configuration": {
      "title": "Piko",
      "properties": {
        "piko.lspPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the piko-lsp binary. Leave empty to use the bundled binary.",
          "scope": "machine-overridable"
        },
        "piko.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the communication between VS Code and the Piko language server for debugging.",
          "scope": "window"
        },
        "piko.enableTemplateSupport": {
          "type": "boolean",
          "default": true,
          "description": "Enable Piko LSP for <template> blocks. Disable if experiencing issues.",
          "scope": "resource"
        },
        "piko.useExternalServer": {
          "type": "boolean",
          "default": false,
          "description": "Connect to an external LSP server instead of starting one automatically. For debugging.",
          "scope": "machine-overridable"
        },
        "piko.externalServerPort": {
          "type": "number",
          "default": 4389,
          "description": "Port for external LSP server (used when useExternalServer is enabled).",
          "scope": "machine-overridable"
        },
        "piko.useStdioTransport": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**⚠️ Experimental:** Use stdio transport instead of TCP. This may cause IDE freezes on some systems due to pipe buffer deadlocks. Only enable for debugging.",
          "scope": "machine-overridable"
        },
        "piko.enablePprof": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable pprof profiling server for the LSP. Access at `http://localhost:<port>/debug/pprof/`. For debugging only.",
          "scope": "machine-overridable"
        },
        "piko.pprofPort": {
          "type": "number",
          "default": 6060,
          "description": "Port for the pprof HTTP server (used when enablePprof is enabled).",
          "scope": "machine-overridable"
        },
        "piko.enableFormatting": {
          "type": "boolean",
          "default": false,
          "description": "Enable document formatting from the Piko LSP server.",
          "scope": "machine-overridable"
        },
        "piko.enableFileLogging": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable file logging to `/tmp/piko-lsp-<pid>.log`. Useful for debugging LSP issues.",
          "scope": "machine-overridable"
        },
        "piko.goBinPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the directory containing the Go binary (e.g., `/usr/local/go/bin`). Leave empty for auto-detection.",
          "scope": "machine-overridable"
        },
        "piko.detectGoFromExtension": {
          "type": "boolean",
          "default": true,
          "description": "Detect Go path from the VSCode Go extension settings (go.goroot, go.alternateTools).",
          "scope": "machine-overridable"
        },
        "piko.searchGlobalGoLocations": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Search common Go installation locations like `/usr/local/go/bin`, Homebrew paths, and `~/sdk/go*/bin`.",
          "scope": "machine-overridable"
        }
      }
    }
  },
  "scripts": {
    "copy:types": "mkdir -p src/fallbackTypes && cp ../../internal/typegen/typegen_frontend/built/piko-ide.d.ts src/fallbackTypes/piko-ide.txt && cp ../../internal/typegen/typegen_adapters/embedded/piko-actions-stub.d.ts src/fallbackTypes/piko-actions.txt",
    "precompile": "npm run copy:types",
    "vscode:prepublish": "npm run compile:production",
    "compile": "node esbuild.js",
    "compile:production": "npm run copy:types && node esbuild.js --production",
    "watch": "npm run copy:types && node esbuild.js --watch",
    "lint": "npm run lint:eslint && npm run lint:typecheck && npm run lint:cpd",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "lint:typecheck": "tsc --noEmit",
    "lint:cpd": "jscpd src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run compile && node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "release": "cd ../.. && make plugin-vscode-build",
    "release:install": "cd ../.. && make plugin-vscode-install",
    "release:clean": "cd ../.. && make plugin-vscode-clean"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.107.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-promise": "^7.2.1",
    "typescript": "^5.9.3",
    "jscpd": "^4",
    "vitest": "^4.0.0"
  }
}
