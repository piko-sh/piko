{
    "description": "Response with style block should inject styles into document head",
    "mockResponse": {
        "status": 200,
        "headers": {
            "Content-Type": "text/html",
            "X-PP-Response-Support": "fragment-patch"
        }
    },
    "renderOptions": {
        "src": "/api/themed",
        "patchMethod": "morph",
        "childrenOnly": true,
        "querySelector": "#content"
    },
    "assertions": [
        {
            "selector": "#content .themed-box",
            "exists": true,
            "description": "Themed box element should exist after render"
        },
        {
            "selector": "#content .themed-box",
            "textContent": "Themed Content",
            "description": "Themed box should have correct text content"
        }
    ],
    "sideEffects": {
        "stylesAdded": [
            { "contains": ".themed-box" }
        ]
    }
}
