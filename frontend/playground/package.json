{
  "name": "@piko/playground",
  "version": "1.0.0",
  "description": "Piko WDK WASM playground - TypeScript client for Go code analysis",
  "main": "dist/piko.playground.es.js",
  "module": "dist/piko.playground.es.js",
  "types": "dist/piko.playground.d.ts",
  "exports": {
    ".": {
      "types": "./dist/piko.playground.d.ts",
      "import": "./dist/piko.playground.es.js",
      "require": "./dist/piko.playground.umd.js"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "npm run copy:wasm-exec && vite build --mode production",
    "build:dev": "npm run copy:wasm-exec && vite build --mode development",
    "build:wasm": "cd ../.. && GOOS=js GOARCH=wasm go build -o frontend/playground/assets/piko.wasm ./cmd/wasm",
    "copy:wasm-exec": "node scripts/copy-wasm-exec.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "lint": "npm run lint:eslint && npm run lint:typecheck && npm run lint:cpd",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "lint:typecheck": "tsc --noEmit",
    "lint:cpd": "jscpd src/"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-promise": "^7.2.1",
    "jsdom": "^27.3.0",
    "terser": "^5.44.1",
    "typescript": "~5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-dts": "^4.5.0",
    "jscpd": "^4",
    "vitest": "^4.0.15"
  },
  "keywords": [
    "piko",
    "wasm",
    "go",
    "playground",
    "code-analysis",
    "lsp"
  ],
  "author": "PolitePixels Limited",
  "license": "Apache-2.0"
}
