func TestIndex_HeroStructure(t *testing.T) {
	tester := piko.NewComponentTester(t, index.BuildAST)
	req := piko.NewTestRequest("GET", "/").Build()
	view := tester.Render(req, piko.NoProps{})

	view.QueryAST(".hero-badge").Exists()
	view.QueryAST(".hero-subtitle").Exists().ContainsText("Go web framework")
	view.QueryAST(".btn-primary").Exists().ContainsText("Get Started")
