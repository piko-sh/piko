<template>
  <piko:partial is="layout" :server.page_title="state.Title">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        Your app is running
      </div>
      <h1 class="hero-title">{{ "{{ state.Title }}" }}</h1>
      <p class="hero-subtitle">{{ "{{ state.Subtitle }}" }}</p>
      <p p-if="state.Name != ''" class="hero-greeting">Nice to meet you, {{ "{{ state.Name }}" }}.</p>
      <div class="hero-actions">
        <a href="https://piko.sh/docs/get-started/introduction" target="_blank" rel="noopener" class="btn btn-primary">
          Get Started
          <piko:svg src="@/lib/icons/arrow-right.svg" class="btn-icon" aria-hidden="true"></piko:svg>
        </a>
        <a href="https://piko.sh/docs" target="_blank" rel="noopener" class="btn btn-secondary">
          Documentation
        </a>
      </div>
    </section>

    <!-- Features - demonstrates p-for and piko:partial with server props -->
    <section class="features">
      <div class="features-grid">
        <div p-for="(i, feature) in state.Features" p-key="feature.Title">
          <piko:partial is="featureCard"
            :server.icon="feature.Icon"
            :server.title="feature.Title"
            :server.description="feature.Description">
          </piko:partial>
        </div>
      </div>
    </section>

    <!-- Code Preview -->
    <section class="code-preview">
      <h2 class="section-title">What you'll be writing</h2>
      <p class="section-subtitle">A single <code>.pk</code> file contains your template, styles, and type-safe Go logic.</p>
      <div class="code-window">
        <div class="code-titlebar">
          <div class="code-dots">
            <span class="code-dot code-dot--red"></span>
            <span class="code-dot code-dot--yellow"></span>
            <span class="code-dot code-dot--green"></span>
          </div>
          <span class="code-filename">pages/hello.pk</span>
        </div>
        <pre class="code-block"><code>&lt;template&gt;
  &lt;h1&gt;{{ "{{ state.Greeting }}" }}&lt;/h1&gt;
&lt;/template&gt;

&lt;script type="application/x-go"&gt;
package main

import "piko.sh/piko"

type Response struct {
    Greeting string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    return Response{Greeting: "Hello, world!"}, piko.Metadata{}, nil
}
&lt;/script&gt;</code></pre>
      </div>
    </section>

    <!-- Quick Start - demonstrates p-for with simple data -->
    <section class="quickstart">
      <h2 class="section-title">Get started in seconds</h2>
      <div class="steps">
        <div class="step" p-for="(i, step) in state.Steps" p-key="step.Command">
          <div class="step-number">{{ "{{ step.Number }}" }}</div>
          <div class="step-content">
            <code class="step-command" p-text="step.Command"></code>
            <p class="step-description">{{ "{{ step.Description }}" }}</p>
          </div>
        </div>
      </div>
    </section>

  </piko:partial>
</template>

<script type="application/x-go">
package main

import (
    "piko.sh/piko"
    layout "{{ .ModuleName }}/partials/layout.pk"
    featureCard "{{ .ModuleName }}/partials/feature-card.pk"
)

type Feature struct {
    Icon        string
    Title       string
    Description string
}

type Step struct {
    Number      int
    Command     string
    Description string
}

type Response struct {
    Title    string
    Subtitle string
    Name     string
    Features []Feature
    Steps    []Step
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    name := r.QueryParam("name")
    title := "Welcome to Piko"
    if name != "" {
        title = "Welcome, " + name
    }

    return Response{
        Title:    title,
        Subtitle: "The Go web framework for building fast, type-safe, server-rendered applications.",
        Name:     name,
        Features: []Feature{
            {
                Icon:        "@/lib/icons/bolt.svg",
                Title:       "Server-Rendered",
                Description: "Pages are rendered on the server in Go. Fast cold starts, instant content, SEO-ready out of the box.",
            },
            {
                Icon:        "@/lib/icons/shield.svg",
                Title:       "Type-Safe",
                Description: "Go structs define your data. Props are validated at compile time. No runtime surprises.",
            },
            {
                Icon:        "@/lib/icons/puzzle.svg",
                Title:       "Component-Based",
                Description: "Build with composable partials and client components. Slots, props, and scoped styles.",
            },
            {
                Icon:        "@/lib/icons/zap.svg",
                Title:       "Zero Config",
                Description: "File-based routing, automatic code generation, and hot reload. Start building immediately.",
            },
        },
        Steps: []Step{
            {Number: 1, Command: "pages/index.pk", Description: "Edit this page"},
            {Number: 2, Command: "air", Description: "Start the dev server"},
            {Number: 3, Command: "piko.sh/docs", Description: "Read the docs"},
        },
    }, piko.Metadata{}, nil
}
</script>

