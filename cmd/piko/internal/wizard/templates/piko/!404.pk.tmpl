<template>
  <piko:partial is="layout" :server.page_title="state.Title">
    <section class="error-page">
      <div class="error-code" p-text="state.StatusCode"></div>
      <h1 class="error-title" p-text="state.Title"></h1>
      <p class="error-message" p-text="state.Message"></p>
      <a href="/" class="error-link">Go home</a>
    </section>
  </piko:partial>
</template>

<script type="application/x-go">
package main

import (
    "fmt"

    "piko.sh/piko"
    layout "{{ .ModuleName }}/partials/layout.pk"
)

type Response struct {
    StatusCode string
    Title      string
    Message    string
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
    statusCode := 404
    message := "The page you are looking for does not exist."

    if errCtx := piko.GetErrorContext(r); errCtx != nil {
        statusCode = errCtx.StatusCode
        if errCtx.Message != "" {
            message = errCtx.Message
        }
    }

    title := fmt.Sprintf("%d - Page Not Found", statusCode)

    return Response{
        StatusCode: fmt.Sprintf("%d", statusCode),
        Title:      title,
        Message:    message,
    }, piko.Metadata{Title: title}, nil
}
</script>

