<script type="application/x-go">
package main

import (
    "piko.sh/piko"
    "time"
)

// Props received from the page that uses this layout.
type Props struct {
    PageTitle string `prop:"page_title"`
}

// Response is available as "state" in the template above.
type Response struct {
    PageTitle   string
    CurrentYear int
}

func Render(r *piko.RequestData, props Props) (Response, piko.Metadata, error) {
    title := "{{ .ProjectName }}"
    if props.PageTitle != "" {
        title = props.PageTitle + " | {{ .ProjectName }}"
    }

    metadata := piko.Metadata{
        Title: title,
    }

    return Response{
        PageTitle:   title,
        CurrentYear: time.Now().Year(),
    }, metadata, nil
}
</script>

