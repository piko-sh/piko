      </a>
      <nav class="main-nav">
        <a href="https://piko.sh/docs" target="_blank" rel="noopener">Documents</a>
        <a href="https://github.com/piko-sh/piko" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </div>
  </header>

  <main>
    <piko:slot></piko:slot>
