<template>
	<div class="container">
		<h1>{{ state.Title }}</h1>
		<div p-for="item in state.Items">
			<p>{{ item.Name }}</p>
			<span>{{ item.Value }}</span>
		</div>
		<button p-if="state.ShowButton">Click me</button>
	</div>
</template>

<script type="application/x-go">
package main

import "piko.sh/piko"

type Item struct {
	Name  string
	Value int
}

type Response struct {
	Title      string
	Items      []Item
	ShowButton bool
}

func Render(r *piko.RequestData, props piko.NoProps) (Response, piko.Metadata, error) {
	items := []Item{
		{Name: "First", Value: 1},
		{Name: "Second", Value: 2},
	}
	return Response{
		Title:      "Hello World",
		Items:      items,
		ShowButton: len(items) > 0,
	}, piko.Metadata{}, nil
}
</script>

<style>
.container {
	padding: 20px;
	background-color: #f0f0f0;
}

h1 {
	color: #333333;
	font-size: 24px;
}
</style>
